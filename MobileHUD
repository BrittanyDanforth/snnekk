-- 📱 MOBILE HUD SYSTEM - Optimized for Slither.io
-- Place in StarterPlayerScripts as LocalScript
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local GuiService = game:GetService("GuiService")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- 🔍 BETTER MOBILE DETECTION
local function isMobileDevice()
	-- Multiple detection methods for reliability
	if UserInputService.TouchEnabled then
		return true
	end
	
	-- Check platform
	if GuiService:IsTenFootInterface() then
		return false -- Console
	end
	
	-- Check viewport size (mobile devices typically have specific aspect ratios)
	local viewport = workspace.CurrentCamera.ViewportSize
	local aspectRatio = viewport.X / viewport.Y
	
	-- Mobile devices typically have portrait or narrow landscape ratios
	if viewport.X < 1024 or (aspectRatio < 1.5 and viewport.Y > viewport.X) then
		return true
	end
	
	-- Check for gyroscope (mobile-specific)
	if UserInputService.GyroscopeEnabled or UserInputService.AccelerometerEnabled then
		return true
	end
	
	return false
end

-- Only run on mobile
if not isMobileDevice() then
	print("Not a mobile device, MobileHUD disabled")
	return
end

print("Mobile device detected! Initializing MobileHUD...")

-- 🚫 DISABLE DEFAULT MOBILE CONTROLS
pcall(function()
	StarterGui:SetCore("TouchGui", false)
	UserInputService.ModalEnabled = false
end)

-- Create HUD
local hudGui = Instance.new("ScreenGui")
hudGui.Name = "MobileHUD"
hudGui.ResetOnSpawn = false
hudGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
hudGui.IgnoreGuiInset = true -- Ensure full screen usage
hudGui.Parent = playerGui

-- 🚀 BOOST BUTTON (Primary mobile control)
local boostButton = Instance.new("ImageButton")
boostButton.Name = "BoostButton"
boostButton.Size = UDim2.new(0, 100, 0, 100)
boostButton.Position = UDim2.new(1, -120, 1, -120)
boostButton.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
boostButton.BackgroundTransparency = 0.3
boostButton.Image = "rbxassetid://6034983856" -- Speed boost icon
boostButton.ImageTransparency = 0.2
boostButton.Parent = hudGui

local boostCorner = Instance.new("UICorner")
boostCorner.CornerRadius = UDim.new(0.5, 0)
boostCorner.Parent = boostButton

local boostStroke = Instance.new("UIStroke")
boostStroke.Thickness = 3
boostStroke.Color = Color3.new(1, 1, 1)
boostStroke.Transparency = 0.5
boostStroke.Parent = boostButton

-- Boost visual feedback
local isBoostPressed = false

-- 📊 SIMPLE SCORE DISPLAY
local scoreFrame = Instance.new("Frame")
scoreFrame.Size = UDim2.new(0, 150, 0, 40)
scoreFrame.Position = UDim2.new(0.5, -75, 0, 10)
scoreFrame.BackgroundColor3 = Color3.new(0, 0, 0)
scoreFrame.BackgroundTransparency = 0.5
scoreFrame.BorderSizePixel = 0
scoreFrame.Parent = hudGui

local scoreCorner = Instance.new("UICorner")
scoreCorner.CornerRadius = UDim.new(0, 20)
scoreCorner.Parent = scoreFrame

local scoreLabel = Instance.new("TextLabel")
scoreLabel.Size = UDim2.new(1, 0, 1, 0)
scoreLabel.BackgroundTransparency = 1
scoreLabel.Text = "Length: 10"
scoreLabel.TextColor3 = Color3.new(1, 1, 1)
scoreLabel.Font = Enum.Font.SourceSansBold
scoreLabel.TextScaled = true
scoreLabel.Parent = scoreFrame

-- 🎮 BOOST BUTTON FUNCTIONALITY
boostButton.MouseButton1Down:Connect(function()
	if not isBoostPressed then
		isBoostPressed = true
		
		-- Visual feedback
		boostButton.BackgroundColor3 = Color3.fromRGB(255, 200, 100)
		boostStroke.Color = Color3.fromRGB(255, 255, 100)
		boostStroke.Thickness = 5
		
		-- Send boost signal
		if _G.PlayerSnakes and _G.PlayerSnakes[player] then
			_G.PlayerSnakes[player].isBoosting = true
		end
		
		-- Haptic feedback if available
		if UserInputService.IsVibrationSupported then
			UserInputService:SetMotor(Enum.VibrationMotor.Small, 0.5)
			task.wait(0.1)
			UserInputService:SetMotor(Enum.VibrationMotor.Small, 0)
		end
	end
end)

boostButton.MouseButton1Up:Connect(function()
	if isBoostPressed then
		isBoostPressed = false
		
		-- Reset visual
		boostButton.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
		boostStroke.Color = Color3.new(1, 1, 1)
		boostStroke.Thickness = 3
		
		-- Stop boost
		if _G.PlayerSnakes and _G.PlayerSnakes[player] then
			_G.PlayerSnakes[player].isBoosting = false
		end
	end
end)

-- Handle touch end outside button
UserInputService.TouchEnded:Connect(function()
	if isBoostPressed then
		boostButton.MouseButton1Up:Fire()
	end
end)

-- 📈 UPDATE SCORE
local function updateScore()
	if _G.PlayerSnakes and _G.PlayerSnakes[player] then
		local snake = _G.PlayerSnakes[player]
		local length = snake.currentLength or 10
		scoreLabel.Text = "Length: " .. tostring(length)
		
		-- Color based on size
		if length > 1000 then
			scoreLabel.TextColor3 = Color3.fromRGB(255, 215, 0)  -- Gold
		elseif length > 500 then
			scoreLabel.TextColor3 = Color3.fromRGB(255, 100, 100)  -- Red
		elseif length > 200 then
			scoreLabel.TextColor3 = Color3.fromRGB(100, 200, 255)  -- Blue
		else
			scoreLabel.TextColor3 = Color3.new(1, 1, 1)  -- White
		end
	end
end

-- 🎯 MOVEMENT HINT (Optional)
local movementHint = Instance.new("TextLabel")
movementHint.Size = UDim2.new(0, 300, 0, 30)
movementHint.Position = UDim2.new(0.5, -150, 1, -200)
movementHint.BackgroundTransparency = 1
movementHint.Text = "Drag anywhere to move"
movementHint.TextColor3 = Color3.new(1, 1, 1)
movementHint.TextTransparency = 0.5
movementHint.Font = Enum.Font.SourceSans
movementHint.TextScaled = true
movementHint.Parent = hudGui

-- Fade out hint after a few seconds
task.spawn(function()
	task.wait(5)
	local fade = TweenService:Create(movementHint, TweenInfo.new(1), {
		TextTransparency = 1
	})
	fade:Play()
	fade.Completed:Connect(function()
		movementHint:Destroy()
	end)
end)

-- 🔄 UPDATE LOOP
RunService.Heartbeat:Connect(function()
	updateScore()
end)

-- 📱 TOUCH-BASED MOVEMENT (Slither.io style)
local touchGui = Instance.new("Frame")
touchGui.Size = UDim2.new(1, 0, 1, 0)
touchGui.BackgroundTransparency = 1
touchGui.Parent = hudGui

local isMoving = false
local moveDirection = Vector2.new()

touchGui.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		isMoving = true
		local touchPos = Vector2.new(input.Position.X, input.Position.Y)
		local center = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y / 2)
		moveDirection = (touchPos - center).Unit
		
		-- Update snake movement
		if _G.PlayerSnakes and _G.PlayerSnakes[player] then
			_G.PlayerSnakes[player].mobileInput = moveDirection
		end
	end
end)

touchGui.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch and isMoving then
		local touchPos = Vector2.new(input.Position.X, input.Position.Y)
		local center = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y / 2)
		moveDirection = (touchPos - center).Unit
		
		-- Update snake movement
		if _G.PlayerSnakes and _G.PlayerSnakes[player] then
			_G.PlayerSnakes[player].mobileInput = moveDirection
		end
	end
end)

touchGui.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		isMoving = false
		-- Don't stop movement, let snake continue in last direction
	end
end)

print("MobileHUD initialized successfully!")