-- 🎯 MOBILE GESTURES
local gestureFrame = Instance.new("Frame")
gestureFrame.Size = UDim2.new(1, 0, 1, 0)
gestureFrame.BackgroundTransparency = 1
gestureFrame.ZIndex = -1
gestureFrame.Parent = hudGui

local touchStartPos = nil
local touchStartTime = 0

gestureFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		touchStartPos = input.Position
		touchStartTime = tick()
	end
end)

gestureFrame.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch and touchStartPos then
		local swipeDistance = (input.Position - touchStartPos).Magnitude
		local swipeTime = tick() - touchStartTime
		
		-- Double tap to boost
		if swipeDistance < 50 and swipeTime < 0.3 then
			showNotification("BOOST!", Color3.fromRGB(255, 200, 0))
		end
		
		touchStartPos = nil
	end
end)

-- 🔄 UPDATE LOOP
RunService.Heartbeat:Connect(function()
	updateScore()
end)

-- Update leaderboard less frequently
local leaderboardTimer = 0
RunService.Heartbeat:Connect(function(dt)
	leaderboardTimer = leaderboardTimer + dt
	if leaderboardTimer > 5 then  -- Update every 5 seconds
		leaderboardTimer = 0
		updateLeaderboard()
	end
end)

-- Initial updates
updateScore()
updateLeaderboard()

