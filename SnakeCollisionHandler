												spawnOrbDirect(spawnPos, valuePerOrb)
												spawnedOrbs = spawnedOrbs + 1
											end)

											if not success then
												warn("Failed to spawn orb for AI death")
											end
										end
									end
								end

								-- Ensure at least some orbs spawn
								if spawnedOrbs == 0 and totalLength > 0 then
									local firstSeg = segments[1]
									if firstSeg and firstSeg.Parent and firstSeg.Position then
										pcall(function()
											local spawnPos = Vector3.new(
												firstSeg.Position.X,
												groundY + ORB_SPAWN_HEIGHT,
												firstSeg.Position.Z
											)
											spawnOrbDirect(spawnPos, valuePerOrb)
										end)
									end
								end
							end

							if snake.Destroy then
								snake:Destroy()
							end
							break
						end
					end
				end
			end

			isProcessingDeaths = false
		end
	end
end)

-- === NETWORK-AWARE COLLISION DETECTION ===
local function checkBoundsOverlap(bounds1, bounds2, margin)
	return not (
		bounds1.max.X + margin < bounds2.min.X or
			bounds1.min.X - margin > bounds2.max.X or
			bounds1.max.Z + margin < bounds2.min.Z or
			bounds1.min.Z - margin > bounds2.max.Z
	)
end

-- === ENHANCED COLLISION VALIDATION ===
local function isValidCollision(headPos, segmentPos, collisionDist)
	-- Basic distance check
	local dist = (headPos - segmentPos).Magnitude
	if dist >= collisionDist then
		return false
	end

	-- Additional validation to prevent false positives
	if dist < MIN_COLLISION_DISTANCE then
		return true -- Very close collision is always valid
	end

	-- For medium distances, add extra validation
	local heightDiff = math.abs(headPos.Y - segmentPos.Y)
	if heightDiff > 3.0 then
		return false -- Too much height difference
	end

	return true
end

-- === DEBUG COLLISION TRACKING ===
local function debugCollision(headPos, segmentPos, collisionType, playerName)
	if not DEBUG_COLLISIONS then return end

	local dist = (headPos - segmentPos).Magnitude
	local heightDiff = math.abs(headPos.Y - segmentPos.Y)

	table.insert(collisionDebugData, {
		timestamp = tick(),
		headPos = headPos,
		segmentPos = segmentPos,
		distance = dist,
		heightDiff = heightDiff,
		collisionType = collisionType,
		playerName = playerName or "Unknown"
	})

	-- Keep only last 50 debug entries
	if #collisionDebugData > 50 then
		table.remove(collisionDebugData, 1)
	end

	print(string.format("[COLLISION DEBUG] %s hit %s at distance %.2f, height diff %.2f", 
		playerName or "Unknown", collisionType, dist, heightDiff))
end

local function findCollisionInChunks(headPos, chunks, collisionDist)
	local effectiveDist = collisionDist + NETWORK_COMPENSATION

	for _, chunk in ipairs(chunks) do
		-- Optimized broad phase with pre-calculated values
		if (headPos - chunk.center).Magnitude <= chunk.radius + effectiveDist then
			-- Narrow phase
			for _, seg in ipairs(chunk.segments) do
				local segPos = seg.Position or seg.position
				if segPos and isValidCollision(headPos, segPos, effectiveDist) then
					return true
				end
			end
		end
	end
	return false
end

local function findCollisionInSegments(headPos, segments, collisionDist, useGrid)
	local effectiveDist = collisionDist + NETWORK_COMPENSATION

	if useGrid and CollisionCache.spatialGrid.objectCount == 0 then
		-- Build spatial grid if empty
		for _, seg in ipairs(segments) do
			local pos = seg.Position or seg.position
			if pos then
				CollisionCache.spatialGrid:insert(seg, pos)
			end
		end
	end

	if useGrid then
		local nearby = CollisionCache.spatialGrid:query(headPos, effectiveDist * 1.5)
		for _, seg in ipairs(nearby) do
			local segPos = seg.Position or seg.position
			if segPos and isValidCollision(headPos, segPos, effectiveDist) then
				return true
			end
		end
	else
		-- Direct iteration for smaller segment counts
		for _, seg in ipairs(segments) do
			local segPos = seg.Position or seg.position
			if segPos and isValidCollision(headPos, segPos, effectiveDist) then
				return true
			end
		end
	end
	return false
end

