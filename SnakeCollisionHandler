-- === NETWORK-AWARE COLLISION DETECTION ===
local function checkBoundsOverlap(bounds1, bounds2, margin)
	return not (
		bounds1.max.X + margin < bounds2.min.X or
			bounds1.min.X - margin > bounds2.max.X or
			bounds1.max.Z + margin < bounds2.min.Z or
			bounds1.min.Z - margin > bounds2.max.Z
	)
end

-- === ENHANCED COLLISION VALIDATION ===
local function isValidCollision(headPos, segmentPos, collisionDist)
	-- Basic distance check
	local dist = (headPos - segmentPos).Magnitude
	if dist >= collisionDist then
		return false
	end

	-- Additional validation to prevent false positives
	if dist < MIN_COLLISION_DISTANCE then
		return true -- Very close collision is always valid
	end

	-- For medium distances, add extra validation
	local heightDiff = math.abs(headPos.Y - segmentPos.Y)
	if heightDiff > 3.0 then
		return false -- Too much height difference
	end

	return true
end

-- === DEBUG COLLISION TRACKING ===
local function debugCollision(headPos, segmentPos, collisionType, playerName)
	if not DEBUG_COLLISIONS then return end

	local dist = (headPos - segmentPos).Magnitude
	local heightDiff = math.abs(headPos.Y - segmentPos.Y)

	table.insert(collisionDebugData, {
		timestamp = tick(),
		headPos = headPos,
		segmentPos = segmentPos,
		distance = dist,
		heightDiff = heightDiff,
		collisionType = collisionType,
		playerName = playerName or "Unknown"
	})

	-- Keep only last 50 debug entries
	if #collisionDebugData > 50 then
		table.remove(collisionDebugData, 1)
	end

	print(string.format("[COLLISION DEBUG] %s hit %s at distance %.2f, height diff %.2f", 
		playerName or "Unknown", collisionType, dist, heightDiff))
end

local function findCollisionInChunks(headPos, chunks, collisionDist)
	local effectiveDist = collisionDist + NETWORK_COMPENSATION

	for _, chunk in ipairs(chunks) do
		-- Optimized broad phase with pre-calculated values
		if (headPos - chunk.center).Magnitude <= chunk.radius + effectiveDist then
			-- Narrow phase
			for _, seg in ipairs(chunk.segments) do
				local segPos = seg.Position or seg.position
				if segPos and isValidCollision(headPos, segPos, effectiveDist) then
					return true
				end
			end
		end
	end
	return false
end

local function findCollisionInSegments(headPos, segments, collisionDist, useGrid)
	local effectiveDist = collisionDist + NETWORK_COMPENSATION

	if useGrid and CollisionCache.spatialGrid.objectCount == 0 then
		-- Build spatial grid if empty
		for _, seg in ipairs(segments) do
			local pos = seg.Position or seg.position
			if pos then
				CollisionCache.spatialGrid:insert(seg, pos)
			end
		end
	end

	if useGrid then
		local nearby = CollisionCache.spatialGrid:query(headPos, effectiveDist * 1.5)
		for _, seg in ipairs(nearby) do
			local segPos = seg.Position or seg.position
			if segPos and isValidCollision(headPos, segPos, effectiveDist) then
				return true
			end
		end
	else
		-- Direct iteration for smaller segment counts
		for _, seg in ipairs(segments) do
			local segPos = seg.Position or seg.position
			if segPos and isValidCollision(headPos, segPos, effectiveDist) then
				return true
			end
		end
	end
	return false
end

-- === IMPROVED HEAD-TO-HEAD COLLISION LOGIC ===
local function determineHeadToHeadWinner(headA, headB, velA, velB)
	-- Calculate collision angle
	local dirAB = (headB.Position - headA.Position).Unit
	local dirBA = -dirAB

	-- Calculate how directly each snake is moving toward the collision point
	local dotA = velA.Unit:Dot(dirAB)
	local dotB = velB.Unit:Dot(dirBA)

	-- Calculate speeds
	local speedA = velA.Magnitude
	local speedB = velB.Magnitude

	-- Check if both are moving toward each other (true head-on)
	if dotA > HEAD_TO_HEAD_ANGLE_THRESHOLD and dotB > HEAD_TO_HEAD_ANGLE_THRESHOLD then
		-- True head-on collision
		-- Winner is determined by aggression score (speed * directness)
		local aggressionA = speedA * dotA
		local aggressionB = speedB * dotB

		-- Add small randomness to break ties
		aggressionA = aggressionA + math.random() * 0.1
		aggressionB = aggressionB + math.random() * 0.1

		if DEBUG_COLLISIONS then
			print(string.format("[HEAD-TO-HEAD] Aggression - A: %.2f, B: %.2f", aggressionA, aggressionB))
		end

		return aggressionA > aggressionB and "B" or "A"
	else
		-- One hit the other from the side
		if dotA > dotB then
			-- A hit B from the side more directly
			return "B"
		else
			-- B hit A from the side more directly
			return "A"
		end
	end
end

-- === COLLISION DETECTION WITH RECENT TRACKING ===
local function isRecentCollision(entityA, entityB)
	local key = tostring(entityA) .. "-" .. tostring(entityB)
	local reverseKey = tostring(entityB) .. "-" .. tostring(entityA)

	local currentTime = tick()

	-- Check both directions with longer cooldown
	if recentCollisions[key] and currentTime - recentCollisions[key] < 1.0 then -- Increased from 0.5 to 1.0
		return true
	end
	if recentCollisions[reverseKey] and currentTime - recentCollisions[reverseKey] < 1.0 then
		return true
	end

	-- Mark as recent
	recentCollisions[key] = currentTime
	recentCollisions[reverseKey] = currentTime

	-- Clean old entries
	for k, time in pairs(recentCollisions) do
		if currentTime - time > 2 then -- Increased from 1 to 2
			recentCollisions[k] = nil
		end
	end

	return false
end

-- === DEATH EXCLUSION CHECK ===
local function isEitherDead(entityA, entityB)
	-- Check if either entity is already marked as dead
	if type(entityA) == "userdata" and entityA:IsA("Player") then
		if deadPlayers[entityA] then
			return true
		end
		-- Also check death queue
		for _, death in ipairs(deathQueue) do
			if death.type == "player" and death.target == entityA then
				return true
			end
		end
	end

	if type(entityB) == "userdata" and entityB:IsA("Player") then
		if deadPlayers[entityB] then
			return true
		end
		-- Also check death queue
		for _, death in ipairs(deathQueue) do
			if death.type == "player" and death.target == entityB then
				return true
			end
		end
	end

	-- Check AI deaths
	if type(entityA) ~= "userdata" and deadAISnakes[entityA] then
		return true
	end

	if type(entityB) ~= "userdata" and deadAISnakes[entityB] then
		return true
	end

	return false
end

