local function spawnOrbDirect(position, value)
	-- Direct spawn with minimal processing
	local success, err = pcall(function()
		-- Ensure position is valid
		if not position or position ~= position then -- NaN check
			position = Vector3.new(0, ORB_SPAWN_HEIGHT, 0)
		end

		-- Clamp value to reasonable range
		value = math.clamp(value or 1, 1, 50)

		OrbUtils.spawnOrbAt(position, value)
	end)

	if not success then
		warn("Orb spawn failed:", err, "at position:", position)
	end

	return success
end

