-- Periodically clean up dead player marks to prevent permanent death
task.spawn(function()
	while true do
		task.wait(10) -- Check every 10 seconds

		-- Clean up disconnected players
		for player, _ in pairs(deadPlayers) do
			if not player.Parent then
				deadPlayers[player] = nil
				if DEBUG_COLLISIONS then
					print("[CLEANUP] Removed disconnected player from dead list")
				end
			end
		end

		-- Clean up players who have respawned
		for player, _ in pairs(deadPlayers) do
			if player.Parent and player.Character then
				local humanoid = player.Character:FindFirstChild("Humanoid")
				if humanoid and humanoid.Health > 0 then
					deadPlayers[player] = nil
					if DEBUG_COLLISIONS then
						print("[CLEANUP] Removed respawned player from dead list:", player.Name)
					end
				end
			end
		end

		-- Clean up old AI snake references
		for head, timestamp in pairs(deadAISnakes) do
			if not head.Parent or (type(timestamp) == "number" and tick() - timestamp > 30) then
				deadAISnakes[head] = nil
			end
		end

		-- Clean up old death marks (failsafe - max 30 seconds)
		local currentTime = tick()
		for player, timestamp in pairs(deadPlayers) do
			if type(timestamp) == "number" and currentTime - timestamp > 30 then
				deadPlayers[player] = nil
				if DEBUG_COLLISIONS then
					print("[CLEANUP] Removed old death mark for:", player.Name)
				end
			end
		end
	end
end)

