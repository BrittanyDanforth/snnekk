							-- Use appropriate collision method with proper distance
							if segmentData.chunks then
								collision = findCollisionInChunks(headPos, segmentData.chunks, BODY_COLLISION_DISTANCE)
							else
								collision = findCollisionInSegments(
									headPos, 
