-- === WALL COLLISION FUNCTIONS ===
local function checkWallCollision(position)
	-- Check if position is near any wall
	local mapHalf = 400 -- Half of MAP_SIZE from MapBuilder
	local wallThreshold = mapHalf - 3 -- Only trigger when very close to wall (3 studs)
	
	if math.abs(position.X) > wallThreshold or math.abs(position.Z) > wallThreshold then
		return true
	end
	return false
end

local function handleWallCollision(entity, isPlayer)
	-- Validate entity
	if not entity then return end
	
	local key
	if isPlayer then
		key = entity
	else
		key = entity.Name or tostring(entity)
	end
	
	-- Ensure we have a valid key
	if not key then return end
	
	local currentTime = tick()
	
	-- Check cooldown
	if wallCollisionCooldowns[key] and currentTime - wallCollisionCooldowns[key] < WALL_ORB_DROP_COOLDOWN then
		return
	end
	
	wallCollisionCooldowns[key] = currentTime
	
	-- Get snake data
	local snakeData
	if isPlayer then
		snakeData = _G.PlayerSnakes and _G.PlayerSnakes[entity]
	else
		snakeData = entity
	end
	
	if not snakeData or not snakeData.segments then return end
	
	-- Check minimum length to prevent errors
	local currentLength = #snakeData.segments
	if currentLength <= 10 then
		-- Don't process wall collisions for very small snakes
		return
	end
	
	-- Drop orbs at head position
	local headPos = snakeData.segments[1] and snakeData.segments[1].Position
	if headPos then
		-- Spawn wall collision orbs near the snake
		local mapBoundary = 395 -- Keep orbs inside the 400 boundary
		
		-- Calculate orb value based on snake size
		local orbValue = 1
		if currentLength > 50 then
			orbValue = 2
		end
		if currentLength > 100 then
			orbValue = 3
		end
		if currentLength > 200 then
			orbValue = 5
		end
		if currentLength > 500 then
			orbValue = 10
		end
		if currentLength > 1000 then
			orbValue = 15
		end
		
		for i = 1, WALL_ORB_DROP_AMOUNT do
			-- Random offset around the snake's head
			local randomOffset = Vector3.new(
				math.random(-10, 10),
				0,
				math.random(-10, 10)
			)
			
			local orbPos = headPos + randomOffset
			
			-- Only clamp if the orb would be outside map
			orbPos = Vector3.new(
				math.clamp(orbPos.X, -mapBoundary, mapBoundary),
				5, -- Match orb spawn height
				math.clamp(orbPos.Z, -mapBoundary, mapBoundary)
			)
			
			-- Spawn orb with scaled value
			OrbUtils.spawnOrbAt(orbPos, orbValue)
		end
		
		-- Remove segments (lose length) for players - scales with size
		if isPlayer and snakeData.shrink and currentLength > 10 then
			-- Scale segments lost based on size (bigger snakes lose more)
			local baseLoss = WALL_ORB_DROP_AMOUNT
			if currentLength > 100 then
				baseLoss = 5
			end
			if currentLength > 300 then
				baseLoss = 8
			end
			if currentLength > 500 then
				baseLoss = 12
			end
			if currentLength > 1000 then
				baseLoss = 20
			end
			
			-- Only shrink if we have enough segments
			local segmentsToRemove = math.min(baseLoss, currentLength - 10)
			if segmentsToRemove > 0 then
				snakeData.shrink(segmentsToRemove)
			end
		end
		
		-- Visual feedback
		if DEBUG_COLLISIONS then
			print("[WALL] " .. tostring(key) .. " hit the wall and dropped " .. WALL_ORB_DROP_AMOUNT .. " orbs!")
		end
	end
end

