RunService.Stepped:Connect(function()
	frameCounter = frameCounter + 1
	if frameCounter % COLLISION_FRAME_SKIP ~= 0 then return end

	-- Throttle collision checks to prevent lag
	local currentTime = tick()
	if currentTime - lastCollisionCheck < 0.05 then -- 20fps max collision checks
		return
	end
	lastCollisionCheck = currentTime

	-- Clear frame cache
	CollisionCache.frameCache = {}

	local playerHeads = getPlayerHeads()
	local aiHeads = getAISnakeHeads()

	-- Early exit if no players or AI
	if #playerHeads == 0 and #aiHeads == 0 then
		return
	end

	-- Player vs AI body collisions
	for _, headData in ipairs(playerHeads) do
		local player = headData.player
		local head = headData.part

		-- Check player invincibility FIRST - skip if player is invincible
		if isPlayerInvincible(player) then
			continue
		end

		if head and head.Parent then
			local headPos = head.Position
			
			-- Throttle wall checks for performance
			local currentTime = tick()
			local lastCheck = wallLastCheck[player] or 0
			if currentTime - lastCheck < WALL_CHECK_INTERVAL then
				continue -- Skip this wall check
			end
			wallLastCheck[player] = currentTime
			
			-- Check wall collision (skip if being pushed or has immunity)
			local hasImmunity = wallPushImmunity[player] and currentTime - wallPushImmunity[player] < WALL_PUSH_IMMUNITY_TIME
			if checkWallCollision(headPos) and not player:GetAttribute("BeingPushedFromWall") and not hasImmunity then
				handleWallCollision(player, true)
				
				-- Track wall contact time
				local key = player
				if not wallContactTime[key] then
					wallContactTime[key] = tick()
				end
				
				local contactDuration = tick() - wallContactTime[key]
				
				-- Push player away if they've been at wall too long
				if contactDuration > WALL_PUSH_TIME then
					local character = player.Character
					if character and character:FindFirstChild("HumanoidRootPart") then
						local root = character.HumanoidRootPart
						local pushDirection = -root.CFrame.LookVector
						
						-- Determine push direction based on which wall
						local pos = root.Position
						if math.abs(pos.X) > 390 then
							pushDirection = Vector3.new(-math.sign(pos.X) * WALL_PUSH_FORCE, 0, 0)
						elseif math.abs(pos.Z) > 390 then
							pushDirection = Vector3.new(0, 0, -math.sign(pos.Z) * WALL_PUSH_FORCE)
						end
						
						-- Apply balanced push force
						local bodyVelocity = Instance.new("BodyVelocity")
						bodyVelocity.MaxForce = Vector3.new(100000, 0, 100000) -- High force to overcome snake movement
						bodyVelocity.Velocity = pushDirection * 0.6 -- Reduced velocity
						bodyVelocity.Parent = root
						
						-- Also apply BodyPosition for guaranteed movement
						local bodyPosition = Instance.new("BodyPosition")
						bodyPosition.MaxForce = Vector3.new(50000, 0, 50000) -- Strong enough to move
						bodyPosition.Position = root.Position + pushDirection.Unit * 7 -- Only 7 studs away
						bodyPosition.D = 3500 -- Higher damping for quicker stop
						bodyPosition.P = 20000 -- Strong power to ensure movement
						bodyPosition.Parent = root
						
						-- Remove after push completes
						game:GetService("Debris"):AddItem(bodyVelocity, 0.5)
						game:GetService("Debris"):AddItem(bodyPosition, 0.7)
						
						-- Reset contact time
						wallContactTime[key] = nil
						
						-- Grant temporary immunity
						wallPushImmunity[player] = tick()
						
						-- Mark player as being pushed to prevent re-collision
						player:SetAttribute("BeingPushedFromWall", true)
						task.spawn(function()
							task.wait(1.5) -- Wait for push to complete
							player:SetAttribute("BeingPushedFromWall", false)
						end)
						
						-- Visual feedback
						print("[WALL PUSH] Pushed " .. player.Name .. " away from wall!")
						
						-- Force drop extra orbs when pushed
						local mapBoundary = 395
						
						-- Get snake length for orb scaling
						local snakeLength = 10
						if _G.PlayerSnakes and _G.PlayerSnakes[player] then
							local snake = _G.PlayerSnakes[player]
							if snake.length then
								snakeLength = snake.length()
							elseif snake.segments then
								snakeLength = #snake.segments
							end
						end
						
						-- Scale orb value based on size
						local pushOrbValue = math.max(1, math.floor(snakeLength / 50))
						
						for i = 1, 2 do
							-- Random offset near the snake
							local randomOffset = Vector3.new(
								math.random(-8, 8),
								0,
								math.random(-8, 8)
							)
							local orbPos = headPos + randomOffset
							
							-- Only clamp to keep inside map
							orbPos = Vector3.new(
								math.clamp(orbPos.X, -mapBoundary, mapBoundary),
								5,
								math.clamp(orbPos.Z, -mapBoundary, mapBoundary)
							)
							
							OrbUtils.spawnOrbAt(orbPos, pushOrbValue)
						end
						
						-- Also lose segments when pushed
						if _G.PlayerSnakes and _G.PlayerSnakes[player] then
							local snake = _G.PlayerSnakes[player]
							if snake.shrink then
								-- Remove 2 extra segments for being pushed
								snake.shrink(2)
							end
						end
					end
				elseif contactDuration > WALL_WARNING_TIME then
					-- Warning phase - make snake segments shake and flash
					if _G.PlayerSnakes and _G.PlayerSnakes[player] then
						local snake = _G.PlayerSnakes[player]
						if snake.segments then
							-- Calculate warning intensity
							local warningIntensity = (contactDuration - WALL_WARNING_TIME) / (WALL_PUSH_TIME - WALL_WARNING_TIME)
							
							for i = 1, math.min(10, #snake.segments) do
								local segment = snake.segments[i]
								if segment and segment.Parent then
									-- Shake effect that gets stronger
									local shake = Vector3.new(
										math.random(-1, 1) * 0.7 * warningIntensity,
										0,
										math.random(-1, 1) * 0.7 * warningIntensity
									)
									segment.Position = segment.Position + shake
								end
							end
						end
						
						-- Warning message (once)
						if not player:GetAttribute("WallWarningShown") then
							player:SetAttribute("WallWarningShown", true)
							-- You could fire a remote event here to show a GUI warning
							print("[WALL WARNING] " .. player.Name .. " - Move away from wall!")
						end
					end
				else
					-- Reset warning
					if player:GetAttribute("WallWarningShown") then
						player:SetAttribute("WallWarningShown", false)
					end
				end
			else
				-- Reset wall contact time if not touching wall
				wallContactTime[player] = nil
			end

			-- Check each AI snake
			if AISnakeModule._activeSnakes then
				for _, snake in AISnakeModule._activeSnakes do
					if snake and snake._active then
						-- Skip if this AI snake is already dead
						if snake.HeadParts and snake.HeadParts.head and deadAISnakes[snake.HeadParts.head] then
							continue
						end
						local segmentData = getAISnakeSegments(snake)
						if segmentData and segmentData.segments then
							local collision = false

							-- Use appropriate collision method with proper distance
							if segmentData.chunks then
								collision = findCollisionInChunks(headPos, segmentData.chunks, BODY_COLLISION_DISTANCE)
							else
								collision = findCollisionInSegments(
									headPos, 
									segmentData.segments, 
									BODY_COLLISION_DISTANCE,
									segmentData.length > 200
								)
							end

							if collision then
								queuePlayerDeath(player)
								break
							end
						end
					end
				end
			end
		end
	end

	-- Player vs Player body collisions (FIXED: Was missing!)
	for i = 1, #playerHeads do
		local headDataA = playerHeads[i]
		local playerA = headDataA.player
		local headA = headDataA.part

		-- Skip if player A is invincible or dead
		if isPlayerInvincible(playerA) or deadPlayers[playerA] then
			continue
		end

		if headA and headA.Parent then
			local headPosA = headA.Position

			-- Check against all other players' bodies
			for j = 1, #playerHeads do
				if i ~= j then -- Don't check against self
					local headDataB = playerHeads[j]
					local playerB = headDataB.player

					-- Don't need to check invincibility for playerB's body
					local segmentData = getPlayerSegments(playerB)
					if segmentData and segmentData.segments then
						local collision = false

						-- Use appropriate collision method
						if segmentData.chunks then
							collision = findCollisionInChunks(headPosA, segmentData.chunks, BODY_COLLISION_DISTANCE)
						else
							collision = findCollisionInSegments(
								headPosA,
								segmentData.segments,
								BODY_COLLISION_DISTANCE,
								segmentData.length > 200
							)
						end

						if collision then
							-- Debug collision
							if DEBUG_COLLISIONS then
								debugCollision(headPosA, headPosA, "PlayerBody", playerA.Name .. " hit " .. playerB.Name .. "'s body")
							end
							queuePlayerDeath(playerA)
							break
						end
					end
				end
			end
		end
	end

	-- AI vs Player body collisions
	for _, aiHead in ipairs(aiHeads) do
		if aiHead and aiHead.Parent then
			-- Skip if AI is spawn protected
			if isAIProtected(aiHead) then
				continue
			end

			local aiPos = aiHead.Position
			
			-- Check wall collision for AI
			local aiSnake = nil
			for _, snake in AISnakeModule._activeSnakes do
				if snake and snake.HeadParts and snake.HeadParts.head == aiHead then
					aiSnake = snake
					break
				end
			end
			if aiSnake and checkWallCollision(aiPos) then
				handleWallCollision(aiSnake, false)
				
				-- Track wall contact time for AI
				local key = aiSnake.Name or aiSnake
				if not wallContactTime[key] then
					wallContactTime[key] = tick()
				end
				
				local contactDuration = tick() - wallContactTime[key]
				
				-- Make AI turn away from wall if too long
				if contactDuration > WALL_PUSH_TIME then
					-- Force AI to turn away
					if aiSnake.TurnAwayFromWall then
						aiSnake:TurnAwayFromWall()
					else
						-- Manual turn if method doesn't exist
						local pos = aiPos
						local newDirection
						if math.abs(pos.X) > 390 then
							newDirection = Vector3.new(-math.sign(pos.X), 0, math.random(-1, 1)).Unit
						elseif math.abs(pos.Z) > 390 then
							newDirection = Vector3.new(math.random(-1, 1), 0, -math.sign(pos.Z)).Unit
						end
						if newDirection and aiSnake.Direction then
							aiSnake.Direction = newDirection
						end
					end
					wallContactTime[key] = nil
				end
			else
				-- Reset AI wall contact
				if aiSnake then
					local key = aiSnake.Name or aiSnake
					wallContactTime[key] = nil
				end
			end

			for _, headData in ipairs(playerHeads) do
				local player = headData.player

				if not isPlayerInvincible(player) then
					local segmentData = getPlayerSegments(player)
					if segmentData and segmentData.segments then
						local collision = false

						if segmentData.chunks then
							collision = findCollisionInChunks(aiPos, segmentData.chunks, BODY_COLLISION_DISTANCE)
						else
							collision = findCollisionInSegments(
								aiPos,
								segmentData.segments,
								BODY_COLLISION_DISTANCE,
								segmentData.length > 200
							)
						end

						if collision then
							-- FIXED: When AI head hits player body, PLAYER dies, not AI!
							queuePlayerDeath(player)
							break
						end
					end
				end
			end
		end
	end

	-- Head-to-head collisions
	-- Player vs Player
	for i = 1, #playerHeads - 1 do
		local dataA = playerHeads[i]
		local playerA = dataA.player
		local headA = dataA.part

		for j = i + 1, #playerHeads do
			local dataB = playerHeads[j]
			local playerB = dataB.player
			local headB = dataB.part

			-- Check invincibility for both players
			local playerAInvincible = isPlayerInvincible(playerA)
			local playerBInvincible = isPlayerInvincible(playerB)

			if playerAInvincible or playerBInvincible then
				if DEBUG_COLLISIONS then
					print(string.format("[INVINCIBILITY] Skipping collision - PlayerA: %s (invincible: %s), PlayerB: %s (invincible: %s)", 
						playerA.Name, tostring(playerAInvincible), playerB.Name, tostring(playerBInvincible)))
				end
				continue
			end

			-- Safety checks
			if not headA or not headA.Parent or not headB or not headB.Parent then
				continue
			end

			-- Check if already processed recently
			if isRecentCollision(playerA, playerB) then
				continue
			end

			-- Check if either player is already dead
			if isEitherDead(playerA, playerB) then
				continue
			end

			local dist = (headA.Position - headB.Position).Magnitude

			if dist < HEAD_COLLISION_DISTANCE + NETWORK_COMPENSATION then
				-- Get velocities
				local velA = headA.AssemblyLinearVelocity or headA.Velocity or Vector3.zero
				local velB = headB.AssemblyLinearVelocity or headB.Velocity or Vector3.zero

				-- Check if they're actually moving
				if velA.Magnitude < HEAD_TO_HEAD_SPEED_THRESHOLD and velB.Magnitude < HEAD_TO_HEAD_SPEED_THRESHOLD then
					-- Both barely moving, skip collision
					continue
				end

				-- Check for body collisions first
				local playerADies = false
				local playerBDies = false

				-- Check if Player A's head is touching Player B's body
				local segDataB = getPlayerSegments(playerB)
				if segDataB and segDataB.segments and #segDataB.segments > 3 then
					for i = 4, #segDataB.segments do
						local seg = segDataB.segments[i]
						if seg and seg.Parent then
							local segPos = seg.Position
							if (headA.Position - segPos).Magnitude < BODY_COLLISION_DISTANCE then
								playerADies = true
								if DEBUG_COLLISIONS then
									print(string.format("[COLLISION] %s hit %s's body at segment %d", playerA.Name, playerB.Name, i))
								end
								break
							end
						end
					end
				end

				-- Check if Player B's head is touching Player A's body
				local segDataA = getPlayerSegments(playerA)
				if segDataA and segDataA.segments and #segDataA.segments > 3 then
					for i = 4, #segDataA.segments do
						local seg = segDataA.segments[i]
						if seg and seg.Parent then
							local segPos = seg.Position
							if (headB.Position - segPos).Magnitude < BODY_COLLISION_DISTANCE then
								playerBDies = true
								if DEBUG_COLLISIONS then
									print(string.format("[COLLISION] %s hit %s's body at segment %d", playerB.Name, playerA.Name, i))
								end
								break
							end
						end
					end
				end

				-- Process deaths
				if playerADies and playerBDies then
					-- Both hit bodies - determine winner based on who hit first/harder
					local winner = determineHeadToHeadWinner(headA, headB, velA, velB)
					if winner == "A" then
						if DEBUG_COLLISIONS then
							print(string.format("[DEATH] %s dies (mutual collision, lost)", playerB.Name))
						end
						queuePlayerDeath(playerB)
					else
						if DEBUG_COLLISIONS then
							print(string.format("[DEATH] %s dies (mutual collision, lost)", playerA.Name))
						end
						queuePlayerDeath(playerA)
					end
				elseif playerADies then
					-- Only A hit B's body
					if DEBUG_COLLISIONS then
						print(string.format("[DEATH] %s dies (hit %s's body)", playerA.Name, playerB.Name))
					end
					queuePlayerDeath(playerA)
				elseif playerBDies then
					-- Only B hit A's body
					if DEBUG_COLLISIONS then
						print(string.format("[DEATH] %s dies (hit %s's body)", playerB.Name, playerA.Name))
					end
					queuePlayerDeath(playerB)
				else
					-- Pure head-to-head collision
					local loser = determineHeadToHeadWinner(headA, headB, velA, velB)
					if loser == "A" then
						if DEBUG_COLLISIONS then
							print(string.format("[DEATH] %s dies (head-to-head collision)", playerA.Name))
						end
						queuePlayerDeath(playerA)
					else
						if DEBUG_COLLISIONS then
							print(string.format("[DEATH] %s dies (head-to-head collision)", playerB.Name))
						end
						queuePlayerDeath(playerB)
					end
				end
				break
			end
		end
	end

	-- Player vs AI head
	for _, headData in ipairs(playerHeads) do
		local player = headData.player
		local head = headData.part

		-- Check player invincibility - skip if player is invincible
		local playerInvincible = isPlayerInvincible(player)
		if playerInvincible then
			-- Debug: Log when invincibility prevents collision
			if DEBUG_COLLISIONS then
				print(string.format("[INVINCIBILITY] Skipping Player vs AI collision - Player: %s (invincible: %s)", 
					player.Name, tostring(playerInvincible)))
			end
			continue
		end

		for _, aiHead in ipairs(aiHeads) do
			if aiHead and aiHead.Parent then
				-- Skip if this AI is already dead
				if deadAISnakes[aiHead] then
					continue
				end

				-- Check AI invincibility
				local aiSnake = nil
				if AISnakeModule and AISnakeModule._activeSnakes then
					for _, snake in AISnakeModule._activeSnakes do
						if snake.HeadParts and snake.HeadParts.head == aiHead then
							aiSnake = snake
							break
						end
					end
				end

				if aiSnake and aiSnake.IsInvincible then
					continue -- Skip if AI is invincible
				end

				-- Additional safety checks
				if not head or not head.Parent then
					continue
				end

				local dist = (head.Position - aiHead.Position).Magnitude
				if dist < HEAD_COLLISION_DISTANCE + NETWORK_COMPENSATION then
					-- Real slither.io logic: check who hit whose body
					local playerDies = false
					local aiDies = false

					-- Check if player's head hit AI's body
					if aiSnake and aiSnake.Segments then
						for i = 4, #aiSnake.Segments do
							local seg = aiSnake.Segments[i]
							if seg and seg.Parent then
								if (head.Position - seg.Position).Magnitude < BODY_COLLISION_DISTANCE then
									playerDies = true
									break
								end
							end
						end
					end

					-- Check if AI's head hit player's body
					local segData = getPlayerSegments(player)
					if segData and segData.segments and #segData.segments > 3 then
						for i = 4, #segData.segments do
							local seg = segData.segments[i]
							if seg and seg.Parent then
								if (aiHead.Position - seg.Position).Magnitude < BODY_COLLISION_DISTANCE then
									aiDies = true
									break
								end
							end
						end
					end

					-- Apply deaths - FIXED: Only one should die when hitting body
					if playerDies and aiDies then
						-- RARE: Both somehow hit each other's body at exact same time
						-- In this case, check who was moving faster/more aggressively
						local velPlayer = head.AssemblyLinearVelocity or head.Velocity or Vector3.zero
						local velAI = aiHead.AssemblyLinearVelocity or aiHead.Velocity or Vector3.zero
						
						if velPlayer.Magnitude > velAI.Magnitude then
							-- Player was more aggressive, only AI dies
							queueAIDeath(aiHead)
						else
							-- AI was more aggressive, only player dies
							queuePlayerDeath(player)
						end
					elseif playerDies then
						-- Player hit AI's body - ONLY PLAYER DIES
						queuePlayerDeath(player)
					elseif aiDies then
						-- AI hit player's body - ONLY AI DIES
						queueAIDeath(aiHead)
					else
						-- Pure head-to-head - only ONE dies
						local velPlayer = head.AssemblyLinearVelocity or head.Velocity or Vector3.zero
						local velAI = aiHead.AssemblyLinearVelocity or aiHead.Velocity or Vector3.zero
						local dirToAI = (aiHead.Position - head.Position).Unit
						local dirToPlayer = -dirToAI

						local dotPlayer = velPlayer:Dot(dirToAI)
						local dotAI = velAI:Dot(dirToPlayer)

						-- Check speeds
						local speedPlayer = velPlayer.Magnitude
						local speedAI = velAI.Magnitude

						-- Calculate aggression scores
						local scorePlayer = dotPlayer * speedPlayer
						local scoreAI = dotAI * speedAI

						if scorePlayer > scoreAI then
							-- Player more aggressive, AI dies
							queueAIDeath(aiHead)
						else
							-- AI more aggressive or equal, player dies
							queuePlayerDeath(player)
						end
					end
				end
			end
		end
	end

	-- AI vs AI head
	for i = 1, #aiHeads - 1 do
		local headA = aiHeads[i]
		if headA and headA.Parent then
			-- Skip if AI A is spawn protected
			if isAIProtected(headA) then
				continue
			end

			for j = i + 1, #aiHeads do
				local headB = aiHeads[j]
				if headB and headB.Parent then
					-- Skip if AI B is spawn protected
					if isAIProtected(headB) then
						continue
					end
					local dist = (headA.Position - headB.Position).Magnitude
					if dist < HEAD_COLLISION_DISTANCE + NETWORK_COMPENSATION then
						local velA = headA.AssemblyLinearVelocity or headA.Velocity
						local velB = headB.AssemblyLinearVelocity or headB.Velocity
						local dirAB = (headB.Position - headA.Position).Unit
						local dirBA = -dirAB

						local dotA = velA:Dot(dirAB)
						local dotB = velB:Dot(dirBA)

						-- True slither.io head-to-head logic: body-hit detection
						if dotA > 2 and not (dotB > 2) then
							-- AI A's head hit AI B's body first
							queueAIDeath(headA)
						elseif dotB > 2 and not (dotA > 2) then
							-- AI B's head hit AI A's body first
							queueAIDeath(headB)
						elseif dotA > 2 and dotB > 2 then
							-- Rare simultaneous case: both die
							queueAIDeath(headA)
							task.spawn(function()
								task.wait(0.05)
								queueAIDeath(headB)
							end)
						end
					end
				end
			end
		end
	end

	-- AI vs other AI bodies
	for _, aiHead in ipairs(aiHeads) do
		if aiHead and aiHead.Parent and AISnakeModule._activeSnakes then
			-- Skip if AI is spawn protected
			if isAIProtected(aiHead) then
				continue
			end

			for _, snake in AISnakeModule._activeSnakes do
				-- Skip self-collision
				if snake and snake._active and snake.HeadParts and snake.HeadParts.head == aiHead then
					continue
				end

				if snake and snake._active then
					local segmentData = getAISnakeSegments(snake)
					if segmentData and segmentData.segments then
						local collision = false

						if segmentData.chunks then
							collision = findCollisionInChunks(aiHead.Position, segmentData.chunks, BODY_COLLISION_DISTANCE)
						else
							collision = findCollisionInSegments(
								aiHead.Position,
								segmentData.segments,
								BODY_COLLISION_DISTANCE,
								segmentData.length > 200
							)
						end

						if collision then
							queueAIDeath(aiHead)
							break
						end
					end
				end
			end
		end
	end

	-- Clear spatial grid for next frame
	CollisionCache.spatialGrid:clear()
end)

-- Cache cleanup (less aggressive)
task.spawn(function()
	while true do
		task.wait(30) -- Increased from 15s

		-- Only clear old entries
		local currentTime = tick()
		for player, cache in pairs(CollisionCache.playerSegments) do
			if currentTime - cache.lastUpdate > 5 then
				CollisionCache.playerSegments[player] = nil
			end
		end

		for snake, cache in pairs(CollisionCache.aiSegments) do
			if currentTime - cache.lastUpdate > 5 then
				CollisionCache.aiSegments[snake] = nil
			end
		end

		-- Clean up dead AI tracking (clear after 10 seconds)
		for aiHead, _ in pairs(deadAISnakes) do
			if not aiHead or not aiHead.Parent then
				deadAISnakes[aiHead] = nil
			end
		end
	end
end)

