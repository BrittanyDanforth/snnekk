						-- Use appropriate collision method
						if segmentData.chunks then
							collision = findCollisionInChunks(headPosA, segmentData.chunks, BODY_COLLISION_DISTANCE)
						else
							collision = findCollisionInSegments(
								headPosA,
								segmentData.segments,
								BODY_COLLISION_DISTANCE,
								segmentData.length > 200
							)
						end

						if collision then
							-- Debug collision
							if DEBUG_COLLISIONS then
								debugCollision(headPosA, headPosA, "PlayerBody", playerA.Name .. " hit " .. playerB.Name .. "'s body")
							end
							queuePlayerDeath(playerA)
							break
						end
					end
				end
			end
		end
	end

	-- AI vs Player body collisions
	for _, aiHead in ipairs(aiHeads) do
		if aiHead and aiHead.Parent then
			-- Skip if AI is spawn protected
			if isAIProtected(aiHead) then
				continue
			end

			local aiPos = aiHead.Position

			for _, headData in ipairs(playerHeads) do
				local player = headData.player

				if not isPlayerInvincible(player) then
					local segmentData = getPlayerSegments(player)
					if segmentData and segmentData.segments then
						local collision = false

						if segmentData.chunks then
							collision = findCollisionInChunks(aiPos, segmentData.chunks, BODY_COLLISION_DISTANCE)
						else
							collision = findCollisionInSegments(
								aiPos,
								segmentData.segments,
								BODY_COLLISION_DISTANCE,
								segmentData.length > 200
							)
						end

						if collision then
							queueAIDeath(aiHead)
							break
						end
					end
				end
			end
		end
	end

	-- Head-to-head collisions
	-- Player vs Player
	for i = 1, #playerHeads - 1 do
		local dataA = playerHeads[i]
		local playerA = dataA.player
		local headA = dataA.part

		for j = i + 1, #playerHeads do
			local dataB = playerHeads[j]
			local playerB = dataB.player
			local headB = dataB.part

			-- Check invincibility for both players - skip if either is invincible
			local playerAInvincible = isPlayerInvincible(playerA)
			local playerBInvincible = isPlayerInvincible(playerB)

			if playerAInvincible or playerBInvincible then
				-- Debug: Log when invincibility prevents collision
				if DEBUG_COLLISIONS then
					print(string.format("[INVINCIBILITY] Skipping collision - PlayerA: %s (invincible: %s), PlayerB: %s (invincible: %s)", 
						playerA.Name, tostring(playerAInvincible), playerB.Name, tostring(playerBInvincible)))
				end
				continue
			end

			-- Additional safety checks
			if not headA or not headA.Parent or not headB or not headB.Parent then
				continue
			end

			local dist = (headA.Position - headB.Position).Magnitude

			-- Debug: Log when collision is detected
			if DEBUG_COLLISIONS then
				print(string.format("[COLLISION] Head-to-head detected - PlayerA: %s, PlayerB: %s, Distance: %.2f", 
					playerA.Name, playerB.Name, dist))
			end
			if dist < HEAD_COLLISION_DISTANCE + NETWORK_COMPENSATION then
				-- Real slither.io logic: check if either head hit the other's body
				local playerADies = false
				local playerBDies = false

				-- Check if Player A's head is touching Player B's body
				local segDataB = getPlayerSegments(playerB)
				if segDataB and segDataB.segments and #segDataB.segments > 3 then
					for i = 4, #segDataB.segments do
						local seg = segDataB.segments[i]
						if seg and seg.Parent then
							local segPos = seg.Position
							if (headA.Position - segPos).Magnitude < BODY_COLLISION_DISTANCE then
								playerADies = true
								break
							end
						end
					end
				end

				-- Check if Player B's head is touching Player A's body
				local segDataA = getPlayerSegments(playerA)
				if segDataA and segDataA.segments and #segDataA.segments > 3 then
					for i = 4, #segDataA.segments do
						local seg = segDataA.segments[i]
						if seg and seg.Parent then
							local segPos = seg.Position
							if (headB.Position - segPos).Magnitude < BODY_COLLISION_DISTANCE then
								playerBDies = true
								break
							end
						end
					end
				end

				-- Apply deaths based on who hit what
				if playerADies and playerBDies then
					-- Both hit each other's bodies simultaneously (very rare)
					if DEBUG_COLLISIONS then
						print(string.format("[DEATH] Both die (mutual body hit): %s and %s", 
							playerA.Name, playerB.Name))
					end
					queuePlayerDeath(playerA)
					queuePlayerDeath(playerB)
				elseif playerADies then
					-- Player A's head hit B's body - A dies
					if DEBUG_COLLISIONS then
						print(string.format("[DEATH] %s dies (hit %s's body)", 
							playerA.Name, playerB.Name))
					end
					queuePlayerDeath(playerA)
				elseif playerBDies then
					-- Player B's head hit A's body - B dies
					if DEBUG_COLLISIONS then
						print(string.format("[DEATH] %s dies (hit %s's body)", 
							playerB.Name, playerA.Name))
					end
					queuePlayerDeath(playerB)
				else
					-- Pure head-to-head collision - only ONE dies
					local velA = headA.AssemblyLinearVelocity or headA.Velocity
					local velB = headB.AssemblyLinearVelocity or headB.Velocity
					local dirAB = (headB.Position - headA.Position).Unit
					local dirBA = -dirAB

					local dotA = velA:Dot(dirAB)
					local dotB = velB:Dot(dirBA)

					-- Also check if they're actually moving (not just sitting there)
					local speedA = velA.Magnitude
					local speedB = velB.Magnitude

					-- Determine winner based on who's more aggressive
					local scoreA = dotA * speedA
					local scoreB = dotB * speedB

					if scoreA > scoreB then
						-- A is more aggressive, B dies
						if DEBUG_COLLISIONS then
							print(string.format("[DEATH] %s dies (less aggressive, score %.1f < %.1f)", 
								playerB.Name, scoreB, scoreA))
						end
						queuePlayerDeath(playerB)
					else
						-- B is more aggressive or equal, A dies
						-- In case of tie, we just pick one (A)
						if DEBUG_COLLISIONS then
							print(string.format("[DEATH] %s dies (less aggressive, score %.1f <= %.1f)", 
								playerA.Name, scoreA, scoreB))
						end
						queuePlayerDeath(playerA)
					end
				end
				break
			end
		end
	end

	-- Player vs AI head
	for _, headData in ipairs(playerHeads) do
		local player = headData.player
		local head = headData.part

		-- Check player invincibility - skip if player is invincible
		local playerInvincible = isPlayerInvincible(player)
		if playerInvincible then
