-- === COLLISION VALIDATION ===
local function validateCollision(posA, posB, expectedDistance)
	-- Extra validation to prevent phantom collisions
	if not posA or not posB then return false end

	local dist = (posA - posB).Magnitude

	-- Check if distance is reasonable
	if dist > expectedDistance * 2 then
		return false
	end

	-- Check for NaN
	if dist ~= dist then
		return false
	end

	return true
end

-- === DEATH HANDLERS (QUEUE-BASED) ===
local function queuePlayerDeath(player)
	-- Additional safety checks to prevent random deaths
	if not player or not player.Parent then
		if DEBUG_COLLISIONS then
			print(string.format("[SAFETY] Blocked death - invalid player object"))
		end
		return
	end

	-- Check if player has valid character
	local character = player.Character
	if not character then
		if DEBUG_COLLISIONS then
			print(string.format("[SAFETY] Blocked death - no character for %s", player.Name))
		end
		return
	end

	-- Check if player is actually in the game
	local humanoid = character:FindFirstChild("Humanoid")
	if not humanoid or humanoid.Health <= 0 then
		if DEBUG_COLLISIONS then
			print(string.format("[SAFETY] Blocked death - player already dead: %s", player.Name))
		end
		return
	end

	-- Prevent double deaths
	if deadPlayers[player] then
		return
	end

	if isPlayerInvincible(player) then 
		-- Debug: Log when invincibility prevents death
		if DEBUG_COLLISIONS then
			print(string.format("[INVINCIBILITY] Blocked death for player: %s (invincible)", player.Name))
		end
		return 
	end

	-- Prevent duplicate death entries
	for _, death in ipairs(deathQueue) do
		if death.type == "player" and death.target == player then
			if DEBUG_COLLISIONS then
				print(string.format("[DUPLICATE] Blocked duplicate death for player: %s", player.Name))
			end
			return
		end
	end

	-- IMMEDIATELY mark as dead to prevent mutual deaths (with timestamp)
	deadPlayers[player] = tick()

	if DEBUG_COLLISIONS then
		print(string.format("[QUEUE] Adding death to queue for player: %s", player.Name))
	end

	table.insert(deathQueue, {
		type = "player",
		target = player,
		timestamp = tick()
	})
end

local function queueAIDeath(head)
	-- Validate head exists and is a proper AI snake head
	if not head or not head.Parent or head.Name ~= "AISnakeHead" then
		if DEBUG_COLLISIONS then
			print("[SAFETY] Blocked AI death - invalid head")
		end
		return
	end
	
	-- Check if this AI is already marked as dead
	if deadAISnakes[head] then
		return
	end
	
	-- Find the actual AI snake instance
	local aiSnake = nil
	for _, snake in AISnakeModule._activeSnakes do
		if snake and snake._active and snake.HeadParts and snake.HeadParts.head == head then
			aiSnake = snake
			break
		end
	end
	
	-- If we can't find the snake, don't process death
	if not aiSnake then
		if DEBUG_COLLISIONS then
			print("[SAFETY] Blocked AI death - no snake instance found")
		end
		return
	end
	
	-- Check if snake is spawn protected
	if isAIProtected(head) then
		if DEBUG_COLLISIONS then
			print("[SAFETY] Blocked AI death - spawn protected")
		end
		return
	end

	-- Prevent duplicate death entries
	for _, death in ipairs(deathQueue) do
		if death.type == "ai" and death.target == head then
			return
		end
	end

	-- Mark this AI as dead immediately (with timestamp)
	deadAISnakes[head] = tick()

	if DEBUG_COLLISIONS then
		print(string.format("[QUEUE] Adding death to queue for AI: %s", tostring(head)))
	end

