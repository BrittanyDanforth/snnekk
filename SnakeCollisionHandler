-- === DEATH HANDLERS (QUEUE-BASED) ===
local function queuePlayerDeath(player)
	-- Additional safety checks to prevent random deaths
	if not player or not player.Parent then
		if DEBUG_COLLISIONS then
			print(string.format("[SAFETY] Blocked death - invalid player object"))
		end
		return
	end

	-- Prevent double deaths
	if deadPlayers[player] then
		return
	end

	if isPlayerInvincible(player) then 
		-- Debug: Log when invincibility prevents death
		if DEBUG_COLLISIONS then
			print(string.format("[INVINCIBILITY] Blocked death for player: %s (invincible)", player.Name))
		end
		return 
	end

	-- Prevent duplicate death entries
	for _, death in ipairs(deathQueue) do
		if death.type == "player" and death.target == player then
			if DEBUG_COLLISIONS then
				print(string.format("[DUPLICATE] Blocked duplicate death for player: %s", player.Name))
			end
			return
		end
	end

	if DEBUG_COLLISIONS then
		print(string.format("[QUEUE] Adding death to queue for player: %s", player.Name))
	end

	table.insert(deathQueue, {
		type = "player",
		target = player,
		timestamp = tick()
	})
end

local function queueAIDeath(head)
	-- Check if this AI is already marked as dead
	if deadAISnakes[head] then
		return
	end

	-- Prevent duplicate death entries
	for _, death in ipairs(deathQueue) do
		if death.type == "ai" and death.target == head then
			return
		end
	end

	-- Mark this AI as dead immediately
	deadAISnakes[head] = true

	table.insert(deathQueue, {
		type = "ai",
		target = head,
		timestamp = tick()
	})
end

-- Death processing coroutine with PROPER orb spawning
task.spawn(function()
	while true do
		task.wait(0.1) -- Reduced from 0.033 to 0.1 for better performance

		if #deathQueue > 0 and not isProcessingDeaths then
			isProcessingDeaths = true

			local death = table.remove(deathQueue, 1)

			-- Add small delay for head-to-head collisions to ensure proper orb spawning
			if death.type == "player" or death.type == "ai" then
				task.wait(0.02) -- Small delay to prevent orb spawning conflicts
			end

			if death.type == "player" then
				local player = death.target
				local character = player.Character
				if character then
					local humanoid = character:FindFirstChild("Humanoid")
					if humanoid and humanoid.Health > 0 then
						-- Get actual snake segments
						local snakeInstance = _G.PlayerSnakes and _G.PlayerSnakes[player]
						if snakeInstance and snakeInstance.segments then
							local segments = snakeInstance.segments
							local totalLength = #segments

							-- Calculate orb distribution
							local orbsPerSegment = 1 / 2.5 -- One orb every 2.5 segments
							local totalOrbs = math.clamp(math.floor(totalLength * orbsPerSegment), 3, 30)

							-- Dynamic value calculation based on snake length
							local baseValue = 1
							if totalLength <= 100 then
								-- Small snakes: give back 30% of length
								local totalValue = math.floor(totalLength * 0.30)
								baseValue = math.max(1, math.floor(totalValue / totalOrbs))
							elseif totalLength <= 200 then
								-- Medium snakes: give back 25% of length
								local totalValue = math.floor(totalLength * 0.25)
								baseValue = math.max(1, math.floor(totalValue / totalOrbs))
							elseif totalLength <= 500 then
								-- Large snakes: give back 20% of length
								local totalValue = math.floor(totalLength * 0.20)
								baseValue = math.max(1, math.floor(totalValue / totalOrbs))
							else
								-- Very large snakes: give back 15% of length with cap
								local totalValue = math.min(math.floor(totalLength * 0.15), 150)
								baseValue = math.max(1, math.floor(totalValue / totalOrbs))
							end

							local valuePerOrb = baseValue

							-- Spawn orbs along the snake path with error handling
							local spawnedOrbs = 0
							for i = 1, totalLength do
								if math.random() < orbsPerSegment then
									local seg = segments[i]
									if seg and seg.Parent and seg.Position then
										local pos = seg.Position

										-- Small random offset to prevent perfect stacking
										local offset = Vector3.new(
											(math.random() - 0.5) * 2,
											0,
											(math.random() - 0.5) * 2
										)

										-- Spawn at proper height so AI can collect
										local spawnPos = Vector3.new(
											pos.X + offset.X,
											ORB_SPAWN_HEIGHT,  -- Use standard orb height!
											pos.Z + offset.Z
										)

										local success = pcall(function()
											-- Just spawn regular orbs that AI can eat
											spawnOrbDirect(spawnPos, valuePerOrb)
											spawnedOrbs = spawnedOrbs + 1
										end)

										if not success then
											warn("Failed to spawn orb for player death")
										end
									end
								end
							end

							-- Ensure at least some orbs spawn
							if spawnedOrbs == 0 and totalLength > 0 then
								local firstSeg = segments[1]
								if firstSeg and firstSeg.Parent and firstSeg.Position then
									pcall(function()
										local spawnPos = Vector3.new(
											firstSeg.Position.X,
											ORB_SPAWN_HEIGHT,
											firstSeg.Position.Z
										)
										spawnOrbDirect(spawnPos, valuePerOrb)
