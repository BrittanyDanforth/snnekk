		for _, aiHead in ipairs(aiHeads) do
			if aiHead and aiHead.Parent then
				-- Skip if this AI is already dead
				if deadAISnakes[aiHead] then
					continue
				end

				-- Check AI invincibility
				local aiSnake = nil
				if AISnakeModule and AISnakeModule._activeSnakes then
					for _, snake in AISnakeModule._activeSnakes do
						if snake.HeadParts and snake.HeadParts.head == aiHead then
							aiSnake = snake
							break
						end
					end
				end

				if aiSnake and aiSnake.IsInvincible then
					continue -- Skip if AI is invincible
				end

				-- Additional safety checks
				if not head or not head.Parent then
					continue
				end

				local dist = (head.Position - aiHead.Position).Magnitude
				if dist < HEAD_COLLISION_DISTANCE + NETWORK_COMPENSATION then
					-- Real slither.io logic: check who hit whose body
					local playerDies = false
					local aiDies = false

					-- Check if player's head hit AI's body
					if aiSnake and aiSnake.Segments then
						for i = 4, #aiSnake.Segments do
							local seg = aiSnake.Segments[i]
							if seg and seg.Parent then
								if (head.Position - seg.Position).Magnitude < BODY_COLLISION_DISTANCE then
									playerDies = true
									break
								end
							end
						end
					end

					-- Check if AI's head hit player's body
					local segData = getPlayerSegments(player)
					if segData and segData.segments and #segData.segments > 3 then
						for i = 4, #segData.segments do
							local seg = segData.segments[i]
							if seg and seg.Parent then
								if (aiHead.Position - seg.Position).Magnitude < BODY_COLLISION_DISTANCE then
									aiDies = true
									break
								end
							end
						end
					end

					-- Apply deaths
					if playerDies and aiDies then
						-- Both hit bodies
						queuePlayerDeath(player)
						queueAIDeath(aiHead)
					elseif playerDies then
						-- Player hit AI's body
						queuePlayerDeath(player)
					elseif aiDies then
						-- AI hit player's body
						queueAIDeath(aiHead)
					else
						-- Pure head-to-head - only ONE dies
						local velPlayer = head.AssemblyLinearVelocity or head.Velocity
						local velAI = aiHead.AssemblyLinearVelocity or aiHead.Velocity
						local dirToAI = (aiHead.Position - head.Position).Unit
						local dirToPlayer = -dirToAI

						local dotPlayer = velPlayer:Dot(dirToAI)
						local dotAI = velAI:Dot(dirToPlayer)

						-- Check speeds
						local speedPlayer = velPlayer.Magnitude
						local speedAI = velAI.Magnitude

						-- Calculate aggression scores
						local scorePlayer = dotPlayer * speedPlayer
						local scoreAI = dotAI * speedAI

						if scorePlayer > scoreAI then
							-- Player more aggressive, AI dies
							queueAIDeath(aiHead)
						else
							-- AI more aggressive or equal, player dies
							queuePlayerDeath(player)
						end
					end
				end
			end
		end
	end

	-- AI vs AI head
	for i = 1, #aiHeads - 1 do
		local headA = aiHeads[i]
		if headA and headA.Parent then
			-- Skip if AI A is spawn protected
			if isAIProtected(headA) then
				continue
			end

			for j = i + 1, #aiHeads do
				local headB = aiHeads[j]
				if headB and headB.Parent then
					-- Skip if AI B is spawn protected
					if isAIProtected(headB) then
						continue
					end
					local dist = (headA.Position - headB.Position).Magnitude
					if dist < HEAD_COLLISION_DISTANCE + NETWORK_COMPENSATION then
						local velA = headA.AssemblyLinearVelocity or headA.Velocity
						local velB = headB.AssemblyLinearVelocity or headB.Velocity
						local dirAB = (headB.Position - headA.Position).Unit
						local dirBA = -dirAB

						local dotA = velA:Dot(dirAB)
						local dotB = velB:Dot(dirBA)

						-- True slither.io head-to-head logic: body-hit detection
						if dotA > 2 and not (dotB > 2) then
							-- AI A's head hit AI B's body first
							queueAIDeath(headA)
						elseif dotB > 2 and not (dotA > 2) then
							-- AI B's head hit AI A's body first
							queueAIDeath(headB)
						elseif dotA > 2 and dotB > 2 then
							-- Rare simultaneous case: both die
							queueAIDeath(headA)
							task.spawn(function()
								task.wait(0.05)
								queueAIDeath(headB)
							end)
						end
					end
				end
			end
		end
	end

	-- AI vs other AI bodies
	for _, aiHead in ipairs(aiHeads) do
		if aiHead and aiHead.Parent and AISnakeModule._activeSnakes then
			-- Skip if AI is spawn protected
			if isAIProtected(aiHead) then
				continue
			end

			for _, snake in AISnakeModule._activeSnakes do
				-- Skip self-collision
				if snake and snake._active and snake.HeadParts and snake.HeadParts.head == aiHead then
					continue
				end

				if snake and snake._active then
					local segmentData = getAISnakeSegments(snake)
					if segmentData and segmentData.segments then
						local collision = false

						if segmentData.chunks then
							collision = findCollisionInChunks(aiHead.Position, segmentData.chunks, BODY_COLLISION_DISTANCE)
						else
							collision = findCollisionInSegments(
								aiHead.Position,
								segmentData.segments,
								BODY_COLLISION_DISTANCE,
								segmentData.length > 200
							)
						end

						if collision then
							queueAIDeath(aiHead)
							break
						end
					end
				end
			end
		end
	end

	-- Clear spatial grid for next frame
	CollisionCache.spatialGrid:clear()
end)

