-- LOD (Level of Detail) settings for performance
-- Server uses default high settings, clients handle their own graphics
local RENDER_DISTANCE = 250  -- Increased from 150
local FAR_DISTANCE = 400     -- Increased from 300
local FADE_DISTANCE = 100    -- Increased from 50
local MIN_ORB_SIZE = 0.3
local MAX_ORB_SIZE = 2.0
local LOD_UPDATE_RATE = 0.1

---------------------------------------------------------------------
-- Dynamic spawn area
---------------------------------------------------------------------
local function getOrbSpawnArea()
	local groundPart = Workspace:FindFirstChild("SlitherIOGround")
	if groundPart and groundPart:IsA("BasePart") then
		local size, pos = groundPart.Size, groundPart.Position
		local hx, hz    = size.X / 2, size.Z / 2
		return {
			minX = math.floor(pos.X - hx) + 5, maxX = math.ceil(pos.X + hx) - 5,
			minZ = math.floor(pos.Z - hz) + 5, maxZ = math.ceil(pos.Z + hz) - 5,
			y    = pos.Y + size.Y / 2 + 2  -- Match death orb height
		}
	end
	return {minX = -600, maxX = 150, minZ = -600, maxZ = 600, y = 5}  -- Also increased default
end

