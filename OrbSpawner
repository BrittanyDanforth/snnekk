-- VFX (no attachments) - FIXED: Completely standalone
---------------------------------------------------------------------
local function createOrbCollectVFX(pos, color)
	-- Create a completely standalone part for VFX
	local part = Instance.new("Part")
	part.Name = "OrbVFX"
	part.Size = Vector3.new(0.1, 0.1, 0.1)
	part.Position = pos
	part.Anchored = true
	part.CanCollide = false
	part.Transparency = 1
	part.Parent = Workspace

	-- Create particle emitter directly on the part (no attachments)
	local pe = Instance.new("ParticleEmitter")
	pe.Parent = part
	pe.Color = ColorSequence.new(color or Color3.new(1, 1, 0))
	pe.LightEmission = 1
	pe.Size = NumberSequence.new{
		NumberSequenceKeypoint.new(0, 0.5), 
		NumberSequenceKeypoint.new(1, 2)
	}
	pe.Transparency = NumberSequence.new{
		NumberSequenceKeypoint.new(0, 0), 
		NumberSequenceKeypoint.new(0.7, 0.5),
		NumberSequenceKeypoint.new(1, 1)
	}
	pe.Lifetime = NumberRange.new(0.4, 0.8)
	pe.Speed = NumberRange.new(8, 15)
	pe.Rate = 0
	pe.SpreadAngle = Vector2.new(360, 360)
	pe:Emit(25)

	-- Clean up after 2 seconds
	Debris:AddItem(part, 2)
end

---------------------------------------------------------------------
-- Safe orb creation (no attachments/constraints) - Now starts hidden
---------------------------------------------------------------------
local function createSafeOrb(position, value, name, color, material)
	-- Ensure minimum height to prevent unreachable orbs
	local minHeight = 4  -- Increased from 3 to ensure orbs are grabbable
	if position.Y < minHeight then
		position = Vector3.new(position.X, minHeight, position.Z)
	end
	
	local orb = Instance.new("Part")
	orb.Name = name or "Orb"
	orb.Shape = Enum.PartType.Ball
	orb.Size = Vector3.new(0.1, 0.1, 0.1)  -- Start tiny
	orb.Anchored = true
	orb.CanCollide = false
	orb.CanTouch = true -- Explicitly enable touch detection
	orb.Material = material or Enum.Material.Neon
	orb.Color = color or Color3.new(1, 1, 0)
	orb.Position = position
	orb.TopSurface = Enum.SurfaceType.Smooth
	orb.BottomSurface = Enum.SurfaceType.Smooth
	orb.Transparency = 1  -- Start invisible
	orb.Parent = Workspace

	local val = Instance.new("NumberValue")
	val.Name = "Value"
	val.Value = value or 1  -- REDUCED from 10 to 1
	val.Parent = orb

	local light = Instance.new("PointLight")
	light.Parent = orb
	light.Color = orb.Color
	light.Brightness = 0
	light.Range = 0
	light.Enabled = false  -- Start disabled

	-- Initialize as hidden
	orbStates[orb] = {state = "hidden", fade = 0}
	addOrbToGrid(orb) -- Add to grid
	
	-- Register with SpatialGrid for AI detection
	pcall(function()
		local SpatialGrid = require(game.ServerScriptService:FindFirstChild("SpatialGrid"))
		if SpatialGrid then
			SpatialGrid.RegisterEntity(orb, "ORB")
		end
	end)

	return orb
end

---------------------------------------------------------------------
-- Death-orb burst - FIXED: No attachments
---------------------------------------------------------------------
local function spawnDeathOrbs(pos, count)
	local spawned = {}
	for i = 1, count do
		local angle, dist = math.random() * math.pi * 2, math.random(3, 8)
		local off = Vector3.new(math.cos(angle) * dist, 0, math.sin(angle) * dist)
		local orb = createSafeOrb(pos + off, 2, "DeathOrb", Color3.fromRGB(255, 100, 100))  -- REDUCED from 10 to 2
		
		-- Make death orbs bigger for better collision detection
		if orb then
			orb.Size = Vector3.new(2.5, 2.5, 2.5) -- Bigger than normal orbs
			-- Ensure they're at snake height
			local yPos = math.max(4, pos.Y)
			orb.Position = Vector3.new(orb.Position.X, yPos, orb.Position.Z)
		end
		
		table.insert(orbs, orb)
		table.insert(spawned, orb)
		attachOrbTouched(orb)
		
		-- CRITICAL: Add death orbs to spatial grid so AI can find them!
		addOrbToGrid(orb)

		-- Death orbs should be immediately visible where they spawn
		applyOrbLOD(orb, "full", 1.0)
	end
	return spawned
end

---------------------------------------------------------------------
-- Remove orb from tables
---------------------------------------------------------------------
local function removeOrb(orb)
	-- Remove from OrbUtils tracking
	OrbUtils.removeOrb(orb)
	
	-- CRITICAL FIX: Remove from OrbSpawner's main orbs array
	for i = #orbs, 1, -1 do
		if orbs[i] == orb then
			table.remove(orbs, i)
			break
		end
	end
	
	-- Remove from upgrade orbs if applicable
	for i = #upgradeOrbs, 1, -1 do 
		if upgradeOrbs[i] == orb then 
			table.remove(upgradeOrbs, i) 
		end 
	end
	
	orbDebounce[orb] = nil
	orbStates[orb] = nil
	removeOrbFromGrid(orb) -- Remove from grid
	
	-- Unregister from SpatialGrid
	pcall(function()
		local SpatialGrid = require(game.ServerScriptService:FindFirstChild("SpatialGrid"))
		if SpatialGrid then
			SpatialGrid.UnregisterEntity(orb)
		end
	end)
	if orbTweens[orb] then
		orbTweens[orb]:Cancel()
		orbTweens[orb] = nil
	end
end

---------------------------------------------------------------------
-- Head identification helpers (players / AI)
---------------------------------------------------------------------
local function getPlayerFromTouchedPart(part)
	-- Direct check for HumanoidRootPart
	for _, h in getPlayerHeads() do
		if h.part == part then return h.player end
	end
	
	-- Check if part belongs to a player's character
	local character = part.Parent
	if character then
		local humanoid = character:FindFirstChildOfClass("Humanoid")
		if humanoid then
			local player = Players:GetPlayerFromCharacter(character)
			if player then return player end
		end
	end
	
	-- Check if it's a snake head or segment
	if part.Name == "SnakeHead" or part:GetAttribute("IsSnakeSegment") then
		-- Find the owner player
		local model = part.Parent
		while model and model.Parent do
			local userId = model:GetAttribute("OwnerUserId")
			if userId then
				for _, player in Players:GetPlayers() do
					if player.UserId == userId then
						return player
					end
				end
			end
			model = model.Parent
		end
	end
	
	return nil
end

local function isPartAISnakeHead(part)
	if part.Name == "AISnakeHead" then return part end
	if part.Parent then
		local head = part.Parent:FindFirstChild("AISnakeHead")
		if head then return head end
	end
	return nil
end

local function getAISnakeHeadFromPart(part)
	local simple = isPartAISnakeHead(part)
	if simple then return simple end

	local ASM = getAISnakeModule()
	if not ASM or not ASM._activeSnakes then return nil end

	for _, s in ASM._activeSnakes do
		local head = s.HeadParts and s.HeadParts.head
		if head and (part == head or (head.Parent and part:IsDescendantOf(head.Parent))) then
			return head
		end
	end
	return nil
end

---------------------------------------------------------------------
-- Atomic orb collection - FIXED: Safe remote event firing
---------------------------------------------------------------------
local function atomicCollectOrb(orb, collType, collObj)
	if not orb or not orb.Parent or orbDebounce[orb] then return end
	orbDebounce[orb] = true

	createOrbCollectVFX(orb.Position, orb.Color)

	if collType == "player" then
		local p = collObj
		-- FIXED: Only fire remote event if it exists and player is valid
		if OrbCollectedEvent and p and p:IsA("Player") then
			-- Use pcall to prevent errors if client doesn't handle it
			pcall(function()
				OrbCollectedEvent:FireClient(p, orb.Position, orb.Name)
			end)
		end
		if orb.Name == "UpgradeOrb" then
			giveUpgradeToPlayerSnake(p)
		else
			local valObj = orb:FindFirstChild("Value")
			local val = (valObj and valObj.Value) or 10
			growPlayerSnake(p, val)
		end
	else -- "ai"
		local head = collObj
		if orb.Name == "UpgradeOrb" then
			giveUpgradeToAISnake(head)
		else
			local valObj = orb:FindFirstChild("Value")
			local val = (valObj and valObj.Value) or 10
			growAISnake(head, val)
		end
	end

	removeOrb(orb)
	if orb and orb.Parent then 
		pcall(function() orb:Destroy() end) 
	end
end

---------------------------------------------------------------------
-- Attach .Touched listener
---------------------------------------------------------------------
attachOrbTouched = function(orb)
	orb.Touched:Connect(function(hit)
		if not orb or not orb.Parent or orbDebounce[orb] then return end



		local player = getPlayerFromTouchedPart(hit)
		if player then
			atomicCollectOrb(orb, "player", player)
			return
		end

		local aiHead = getAISnakeHeadFromPart(hit)
		if aiHead then

			atomicCollectOrb(orb, "ai", aiHead)
			return
		end
		
		-- Clear debounce if no valid collector
		orbDebounce[orb] = nil
	end)
end

---------------------------------------------------------------------
-- LOD Update Loop - Updates visibility of all orbs
---------------------------------------------------------------------
local lastLODUpdate = 0
task.spawn(function()
	RunService.Heartbeat:Connect(function()
		local now = tick()
		if now - lastLODUpdate < LOD_UPDATE_RATE then return end
		lastLODUpdate = now

		local viewPositions = getAllViewingPositions()
		if #viewPositions == 0 then return end

		-- Update LOD for all orbs
		for i = #orbs, 1, -1 do
			local orb = orbs[i]
			if orb and orb.Parent then
				local state, fade = calculateOrbLOD(orb, viewPositions)
				applyOrbLOD(orb, state, fade)
			end
		end
	end)
end)

---------------------------------------------------------------------
-- Backup proximity scan (runs every 0.2 s) - only for visible orbs
---------------------------------------------------------------------
task.spawn(function()
	while true do 
		task.wait(0.2)
		local aiHeads = {}
		for _, obj in Workspace:GetDescendants() do
			if obj:IsA("BasePart") and obj.Name == "AISnakeHead" then
				aiHeads[#aiHeads + 1] = obj
			end
		end
		local players = getPlayerHeads()

		-- OPTIMIZATION: Use spatial grid for efficient proximity checks
		for _, ph in ipairs(players) do
			if ph and ph.Parent then
				local nearbyOrbs = getOrbsNearPosition(ph.Position, 12)
				for _, orb in ipairs(nearbyOrbs) do
					if orb and orb.Parent and not orbDebounce[orb] then
						local orbState = orbStates[orb]
						if orbState and orbState.state ~= "hidden" then
							local dist = (orb.Position - ph.Position).Magnitude
							if dist < orb.Size.X * 0.8 + 3 then
								local p = getPlayerFromTouchedPart(ph)
								if p then atomicCollectOrb(orb, "player", p) end
							end
						end
					end
				end
			end
		end

		for _, ah in ipairs(aiHeads) do
			if ah and ah.Parent then
				local nearbyOrbs = getOrbsNearPosition(ah.Position, 12)
				for _, orb in ipairs(nearbyOrbs) do
					if orb and orb.Parent and not orbDebounce[orb] then
						local orbState = orbStates[orb]
						if orbState and orbState.state ~= "hidden" then
							local dist = (orb.Position - ah.Position).Magnitude
							if dist < orb.Size.X * 0.8 + 3 then
								atomicCollectOrb(orb, "ai", ah)
							end
						end
					end
				end
			end
		end
	end
end)

---------------------------------------------------------------------
-- Orb spawning helpers
---------------------------------------------------------------------
local function randomPosition()
	local a = getOrbSpawnArea()
	
	-- Try to find a gap area (up to 5 attempts)
	for attempt = 1, 5 do
		local testX = math.random(a.minX, a.maxX)
		local testZ = math.random(a.minZ, a.maxZ)
		local testPos = Vector3.new(testX, a.y, testZ)
		
		-- Use the existing getOrbsNearPosition function
		local nearbyOrbs = getOrbsNearPosition(testPos, 40) -- Check within 40 studs
		
		-- If this area has few orbs, use it (fills gaps)
		if #nearbyOrbs < 3 then
			return testPos
		end
	end
	
	-- Fallback to completely random position
	return Vector3.new(math.random(a.minX, a.maxX), a.y, math.random(a.minZ, a.maxZ))
end

local function createOrb()
	local orb
	if math.random() < UPGRADE_ORB_CHANCE then
		orb = createSafeOrb(randomPosition(), 0, "UpgradeOrb",
			Color3.fromRGB(0, 200, 255), Enum.Material.ForceField)
		upgradeOrbs[#upgradeOrbs + 1] = orb
		orbs[#orbs + 1] = orb
	else
		orb = OrbUtils.spawnOrbAt(randomPosition(), 1)  -- REDUCED from 10 to 1
		if orb then
			-- CRITICAL FIX: Add regular orbs to the orbs array!
			orbs[#orbs + 1] = orb
			
			-- Start orbs visible at medium distance
			orb.Transparency = 0.3
			orb.Size = Vector3.new(1.5, 1.5, 1.5)
			orbStates[orb] = {state = "far", fade = 0.7}
			local light = orb:FindFirstChild("PointLight")
			if light then 
				light.Enabled = true
				light.Brightness = 1.4
				light.Range = 5.6
			end
			addOrbToGrid(orb) -- Add to grid
		end
	end
	if orb then attachOrbTouched(orb) end
	return orb
end

