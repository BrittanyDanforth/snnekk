-- Function to register orbs created outside of OrbSpawner
local function registerExternalOrb(orb)
	if not orb or not orb.Parent then return end
	
	-- Add to orbs table
	table.insert(orbs, orb)
	
	-- Add to spatial grid
	addOrbToGrid(orb)
	
	-- Initialize state - death orbs should be visible immediately
	orbStates[orb] = {state = "full", fade = 1}
	orb.Transparency = 0
	orb.Size = orb.Size or Vector3.new(1.5, 1.5, 1.5)
	local light = orb:FindFirstChild("PointLight")
	if light then light.Enabled = true end
	
	-- Attach our touch handler if not already attached
	if not orbDebounce[orb] then
		attachOrbTouched(orb)
	end
end

local OrbSpawner = {
	spawnDeathOrbsForSnake = spawnDeathOrbsForSnake,
	createSafeOrb = createSafeOrb,
	registerExternalOrb = registerExternalOrb,
	-- New exports for LOD control
	setRenderDistance = function(dist) RENDER_DISTANCE = dist end,
	setFadeDistance = function(dist) FADE_DISTANCE = dist end,
}

-- Set the attachOrbTouched function for OrbUtils
OrbUtils.attachOrbTouched = attachOrbTouched

_G.OrbSpawner = OrbSpawner
print("OrbSpawner loaded successfully - Fixed attachment and remote event issues")

return OrbSpawner
