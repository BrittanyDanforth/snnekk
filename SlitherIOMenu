local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

-- Hide the default Roblox leaderboard
StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, false)

-- Helper to set graphics mode (attribute + remote event)
local function setGraphicsMode(mode)
	LocalPlayer:SetAttribute("GraphicsMode", mode)
	local event = ReplicatedStorage:FindFirstChild("SetGraphicsMode")
	if event then
		event:FireServer(mode)
	end
end

-- Enhanced respawn system with UI persistence
local function requestRespawn()
	local respawnEvent = ReplicatedStorage:WaitForChild("RespawnSnake")
	respawnEvent:FireServer()
end

