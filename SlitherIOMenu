		TweenService:Create(playShadow, TweenInfo.new(0.05), {Size = UDim2.new(0.38, 0, 0.11, 0)}):Play()
		task.wait(0.05)
		TweenService:Create(playButton, TweenInfo.new(0.05), {Size = UDim2.new(0.4, 0, 0.12, 0)}):Play()
		TweenService:Create(playShadow, TweenInfo.new(0.05), {Size = UDim2.new(0.4, 0, 0.12, 0)}):Play()
		task.wait(0.1)
		if onPlay then
			onPlay()
		end
		-- FADE OUT MENU INSTEAD OF IMMEDIATE DESTROY
		-- FIX: Tween the bgFrame's BackgroundTransparency instead of the ScreenGui
		local fadeTween = TweenService:Create(bgFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {BackgroundTransparency = 1})
		fadeTween:Play()
		-- Wait for character to spawn before hiding completely
		local maxWaitTime = 10 -- Maximum 10 seconds
		local startTime = tick()
		local function waitForCharacter()
			-- Check if character exists and has humanoid
			if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
				-- Character spawned, now hide menu completely
				screenGui:Destroy()
				-- Restore CoreGui after play
				StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
				-- Keep the default leaderboard hidden after play
				StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, false)
			elseif tick() - startTime > maxWaitTime then
				-- Timeout reached, hide menu anyway
				print("Menu timeout - hiding anyway")
				screenGui:Destroy()
				StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
				StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, false)
			else
				-- Check again in a moment
				task.wait(0.1)
				waitForCharacter()
			end
		end
		-- Start waiting for character spawn
		spawn(waitForCharacter)
	end)
	-- Enhanced icon button hover effects
	for _, btn in {settingsButton, shareButton, shopButton} do
		btn.MouseEnter:Connect(function()
			TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
				BackgroundTransparency = 0.88,
				Size = UDim2.new(0.085, 0, 0.085, 0)
			}):Play()
			TweenService:Create(btn:FindFirstChild("UIStroke"), TweenInfo.new(0.15), {
				Transparency = 0.75
			}):Play()
		end)
		btn.MouseLeave:Connect(function()
			TweenService:Create(btn, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
				BackgroundTransparency = 0.92,
				Size = UDim2.new(0.08, 0, 0.08, 0)
			}):Play()
			TweenService:Create(btn:FindFirstChild("UIStroke"), TweenInfo.new(0.15), {
				Transparency = 0.85
			}):Play()
		end)
	end
	-- Settings button opens settings panel
	settingsButton.MouseButton1Click:Connect(function()
		openSettingsPanel()
	end)
	-- Shop button opens shop UI
	shopButton.MouseButton1Click:Connect(function()
		-- Wait for the shop to be loaded
		task.wait(0.1)
		if _G.ShowShop then
			_G.ShowShop()
			-- Hide the menu when shop opens
			screenGui.Enabled = false
		else
			warn("Shop system not loaded yet. Please try again.")
		end
	end)
	-- Share button opens share panel
	shareButton.MouseButton1Click:Connect(function()
		openSharePanel()
	end)
	-- Parent the menu to the player's PlayerGui
	screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
	-- Block controls and CoreGui until play is pressed
	StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)
end
