local function deepCopy(orig)
	local orig_type = type(orig)
	local copy
	if orig_type == 'table' then
		copy = {}
		for orig_key, orig_value in orig do
			copy[orig_key] = deepCopy(orig_value)
		end
	else
		copy = orig
	end
	return copy
end

