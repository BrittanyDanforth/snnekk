-- 📊 MOBILE-OPTIMIZED CAMERA
local CameraController = {}
CameraController.Height = isMobile and 60 or 50  -- Higher view on mobile
CameraController.Smoothness = 0.08  -- Smoother for mobile
CameraController.FieldOfView = isMobile and 80 or 70  -- Wider FOV on mobile

function CameraController:Update(rootPart)
	if not rootPart then return end
	
	local camera = workspace.CurrentCamera
	camera.CameraType = Enum.CameraType.Scriptable
	
	local targetCFrame = CFrame.new(
		rootPart.Position + Vector3.new(0, self.Height, 0),
		rootPart.Position
	)
	
	camera.CFrame = camera.CFrame:Lerp(targetCFrame, self.Smoothness)
	camera.FieldOfView = self.FieldOfView
end

-- 🎮 JOYSTICK CONTROLLER
local JoystickController = {
	active = false,
	inputVector = Vector2.new(0, 0),
	touchId = nil,
}

function JoystickController:UpdateVisual()
	local magnitude = math.min(self.inputVector.Magnitude, 1)
	local direction = self.inputVector.Unit
	
	if magnitude < MobileConfig.DeadZone then
		magnitude = 0
		direction = Vector2.new(0, 0)
	end
	
	local offset = direction * magnitude * (MobileConfig.JoystickSize / 2 - MobileConfig.JoystickThumbSize / 2)
	
	TweenService:Create(joystickThumb, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {
		Position = UDim2.new(0.5, offset.X - MobileConfig.JoystickThumbSize/2, 0.5, offset.Y - MobileConfig.JoystickThumbSize/2)
	}):Play()
end

function JoystickController:Reset()
	self.active = false
	self.inputVector = Vector2.new(0, 0)
	self.touchId = nil
	self:UpdateVisual()
end

-- 🎯 MOBILE MOVEMENT INTEGRATION
local MobileMovement = {
	moveVector = Vector3.new(0, 0, 0),
	isBoosting = false,
}

function MobileMovement:GetMoveVector()
	if not JoystickController.active then
		return Vector3.new(0, 0, 0)
	end
	
	local input = JoystickController.inputVector
	if input.Magnitude < MobileConfig.DeadZone then
		return Vector3.new(0, 0, 0)
	end
	
	-- Convert 2D joystick input to 3D movement
	local moveX = input.X * MobileConfig.TouchSensitivity
	local moveZ = -input.Y * MobileConfig.TouchSensitivity  -- Negative for correct direction
	
	return Vector3.new(moveX, 0, moveZ).Unit
end

-- 📱 TOUCH HANDLERS
local function handleTouch(input, gameProcessed)
	if gameProcessed then return end
	
	local touchPos = input.Position
	local joystickPos = joystickFrame.AbsolutePosition
	local joystickSize = joystickFrame.AbsoluteSize
	
	-- Check if touch is within joystick
	local relativePos = touchPos - joystickPos - joystickSize / 2
	local distance = relativePos.Magnitude
	
	if distance <= joystickSize.X / 2 then
		JoystickController.active = true
		JoystickController.touchId = input.UserInputType
		
		local normalizedPos = relativePos / (joystickSize.X / 2)
		JoystickController.inputVector = Vector2.new(normalizedPos.X, normalizedPos.Y)
		JoystickController:UpdateVisual()
		
		return true
	end
	
	return false
end

-- Input handlers
UserInputService.TouchStarted:Connect(function(input, gameProcessed)
	if not isMobile then return end
	handleTouch(input, gameProcessed)
end)

UserInputService.TouchMoved:Connect(function(input, gameProcessed)
	if not isMobile then return end
	if JoystickController.touchId == input.UserInputType then
		handleTouch(input, gameProcessed)
	end
end)

UserInputService.TouchEnded:Connect(function(input)
	if not isMobile then return end
	if JoystickController.touchId == input.UserInputType then
		JoystickController:Reset()
	end
end)

-- Boost button handlers
boostButton.TouchLongPress:Connect(function()
	MobileMovement.isBoosting = true
end)

boostButton.TouchEnded:Connect(function()
	MobileMovement.isBoosting = false
end)

-- Alternative boost handling for better responsiveness
local boostActive = false
boostButton.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		boostActive = true
		MobileMovement.isBoosting = true
		boostButton.BackgroundColor3 = Color3.fromRGB(255, 150, 150)
	end
end)

boostButton.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		boostActive = false
		MobileMovement.isBoosting = false
		boostButton.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
	end
end)

-- 🔄 EXPORT FOR SNAKE MOVEMENT
_G.MobileControls = {
	Enabled = isMobile,
	GetMoveVector = function() return MobileMovement:GetMoveVector() end,
	IsBoosting = function() return MobileMovement.isBoosting end,
	UpdateCamera = function(rootPart) CameraController:Update(rootPart) end,
}

-- 📱 SCREEN ORIENTATION HANDLER
local function updateUIForOrientation()
	local viewport = workspace.CurrentCamera.ViewportSize
	local isLandscape = viewport.X > viewport.Y
	
	if isLandscape then
		-- Landscape adjustments
		joystickFrame.Position = UDim2.new(0, 20, 1, -150)
		boostButton.Position = UDim2.new(1, -120, 1, -130)
	else
		-- Portrait adjustments
		joystickFrame.Position = UDim2.new(0, 15, 1, -200)
		boostButton.Position = UDim2.new(1, -100, 1, -180)
	end
end

-- Update on orientation change
workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(updateUIForOrientation)
updateUIForOrientation()

-- 🎯 MOBILE HUD ELEMENTS
local function createMobileHUD()
	-- Mini map indicator (optional)
	local miniMapFrame = Instance.new("Frame")
	miniMapFrame.Size = UDim2.new(0, 100, 0, 100)
	miniMapFrame.Position = UDim2.new(1, -110, 0, 10)
	miniMapFrame.BackgroundTransparency = 0.5
	miniMapFrame.BackgroundColor3 = Color3.new(0, 0, 0)
	miniMapFrame.BorderSizePixel = 2
	miniMapFrame.BorderColor3 = Color3.fromRGB(100, 200, 100)
	miniMapFrame.Visible = false  -- Enable if needed
	miniMapFrame.Parent = screenGui
	
	-- FPS counter for mobile optimization
	local fpsLabel = Instance.new("TextLabel")
	fpsLabel.Size = UDim2.new(0, 60, 0, 30)
	fpsLabel.Position = UDim2.new(0, 10, 0, 10)
	fpsLabel.BackgroundTransparency = 0.5
	fpsLabel.BackgroundColor3 = Color3.new(0, 0, 0)
	fpsLabel.TextColor3 = Color3.new(1, 1, 1)
	fpsLabel.Font = Enum.Font.SourceSans
	fpsLabel.TextScaled = true
	fpsLabel.Text = "FPS: 60"
	fpsLabel.Parent = screenGui
	
	-- Update FPS counter
	local lastTime = tick()
	local frameCount = 0
	
	RunService.Heartbeat:Connect(function()
		frameCount = frameCount + 1
		local currentTime = tick()
		
		if currentTime - lastTime >= 1 then
			fpsLabel.Text = "FPS: " .. math.floor(frameCount / (currentTime - lastTime))
			frameCount = 0
			lastTime = currentTime
		end
	end)
end

if isMobile then
	createMobileHUD()
end

print("📱 Mobile Controls Initialized - Device:", isMobile and "Mobile" or "Desktop")

return _G.MobileControls