local GuiService = game:GetService("GuiService")
local TweenService = game:GetService("TweenService")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- 📱 BETTER MOBILE DETECTION
local function isMobileDevice()
	-- Multiple detection methods for reliability
	if UserInputService.TouchEnabled then
		return true
	end
	
	-- Check platform
	if GuiService:IsTenFootInterface() then
		return false -- Console
	end
	
	-- Check viewport size
	local viewport = workspace.CurrentCamera.ViewportSize
	local aspectRatio = viewport.X / viewport.Y
	
	-- Mobile devices typically have portrait or narrow landscape ratios
	if viewport.X < 1024 or (aspectRatio < 1.5 and viewport.Y > viewport.X) then
		return true
	end
	
	-- Check for gyroscope (mobile-specific)
	if UserInputService.GyroscopeEnabled or UserInputService.AccelerometerEnabled then
		return true
	end
	
	return false
end

-- Exit if not mobile
if not isMobileDevice() then
	print("Not a mobile device, MobileControls disabled")
	return
end

print("Mobile device detected! Disabling default controls...")

-- 🚫 DISABLE DEFAULT MOBILE CONTROLS
pcall(function()
	-- Disable all default mobile UI
	StarterGui:SetCore("TouchGui", false)
	StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.TouchGui, false)
	UserInputService.ModalEnabled = false
	
	-- Disable default movement
	local playerModule = require(player:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule"))
	if playerModule then
		local controls = playerModule:GetControls()
		if controls then
			controls:Disable()
		end
	end
end)

