-- Place in StarterPlayerScripts as LocalScript
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local GuiService = game:GetService("GuiService")
local TweenService = game:GetService("TweenService")
local StarterGui = game:GetService("StarterGui")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- 📱 STRICT MOBILE DETECTION
local function isMobileDevice()
	-- Check if we have touch but NO mouse (most reliable)
	if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
		return true
	end
	
	-- Check for mobile-specific sensors
	if UserInputService.GyroscopeEnabled or UserInputService.AccelerometerEnabled then
		return true
	end
	
	-- Check if on console (not mobile)
	if GuiService:IsTenFootInterface() then
		return false
	end
	
	-- Additional check for touch-only devices
	local hasMouse = UserInputService.MouseEnabled
	local hasKeyboard = UserInputService.KeyboardEnabled
	local hasTouch = UserInputService.TouchEnabled
	local hasGamepad = UserInputService.GamepadEnabled
	
	-- If we only have touch and nothing else, it's likely mobile
	if hasTouch and not hasMouse and not hasKeyboard and not hasGamepad then
		return true
	end
	
	return false
end

-- Exit if not mobile
if not isMobileDevice() then
	print("Not a mobile device (PC detected), MobileControls disabled")
	_G.IsMobile = false -- Explicitly set to false for PC
	return
end

print("Mobile device detected! Disabling default controls...")

-- 🚫 PROPERLY DISABLE DEFAULT MOBILE CONTROLS
task.spawn(function()
	-- Disable Core GUI mobile controls
	pcall(function()
		StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false) -- Disable all CoreGui
		-- Re-enable only what we need
		StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Chat, true)
		StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, true)
		
		-- Specifically disable TouchGui and TouchControlFrame
		StarterGui:SetCore("TouchGui", false)
		
		-- Extra aggressive removal of touch controls
		local touchGui = playerGui:FindFirstChild("TouchGui")
		if touchGui then
			touchGui:Destroy()
		end
		
		-- Remove TouchControlFrame if it exists
		for _, gui in pairs(playerGui:GetChildren()) do
			if gui.Name == "TouchGui" or gui.Name == "ControlGui" or gui.Name == "TouchControlFrame" then
				gui:Destroy()
			end
		end
	end)
	
	-- Wait for player scripts to load
	local playerScripts = player:WaitForChild("PlayerScripts")
	local playerModule = require(playerScripts:WaitForChild("PlayerModule"))
	local controls = playerModule:GetControls()
	
	-- Disable default movement controls completely
	controls:Disable()
	print("Default mobile controls disabled successfully!")
	
	-- Also set modal to false
	UserInputService.ModalEnabled = false
end)

