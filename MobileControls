	-- Joystick settings
	JoystickSize = isTablet and 150 or 120,
	JoystickThumbSize = isTablet and 60 or 50,
	JoystickTransparency = 0.3,
	JoystickPosition = UDim2.new(0, 20, 1, -170),
	
	-- Boost button settings
	BoostButtonSize = isTablet and 100 or 80,
	BoostButtonPosition = UDim2.new(1, -120, 1, -150),
	
	-- UI scaling
	UIScale = isTablet and 1 or 0.85,
	
	-- Sensitivity
	TouchSensitivity = 1.2,
	DeadZone = 0.15,
}

-- 🎯 CREATE MOBILE UI
