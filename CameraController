-- CameraController: Smooth top-down view with Mobile Support
-- LOCALSCRIPT INSIDE STARTERPLAYERSCRIPTS
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local GuiService = game:GetService("GuiService")
local StarterPlayer = game:GetService("StarterPlayer")

local camera = workspace.CurrentCamera
local player = Players.LocalPlayer

-- Strict mobile detection
local function isMobileDevice()
	-- Check if we have touch but NO mouse (most reliable)
	if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
		return true
	end
	
	-- Check for mobile-specific sensors
	if UserInputService.GyroscopeEnabled or UserInputService.AccelerometerEnabled then
		return true
	end
	
	-- Additional check for touch-only devices
	local hasMouse = UserInputService.MouseEnabled
	local hasKeyboard = UserInputService.KeyboardEnabled
	local hasTouch = UserInputService.TouchEnabled
	
	-- If we only have touch and nothing else, it's likely mobile
	if hasTouch and not hasMouse and not hasKeyboard then
		return true
	end
	
	return false
end

local isMobile = isMobileDevice()

-- Mobile-optimized settings
local HEIGHT = isMobile and 65 or 50  -- Higher on mobile for better view
local SMOOTHNESS = isMobile and 0.1 or 0.05  -- Smoother on mobile
local FOV = isMobile and 85 or 70  -- Wider FOV on mobile

-- Additional mobile settings
local MOBILE_HEIGHT_MULTIPLIER = 1.2  -- Extra height based on snake size
local MOBILE_DYNAMIC_FOV = true  -- Adjust FOV based on snake speed

-- 🔒 LOCK CAMERA COMPLETELY (like slither.io)
camera.CameraType = Enum.CameraType.Scriptable

-- Disable ALL camera manipulation
UserInputService.MouseBehavior = Enum.MouseBehavior.Default

-- Prevent zoom
player.CameraMinZoomDistance = 0.5
player.CameraMaxZoomDistance = 0.5
player.CameraMode = Enum.CameraMode.LockFirstPerson

-- Override camera settings every frame to prevent ANY manipulation
local function lockCamera()
	camera.CameraType = Enum.CameraType.Scriptable
	-- Force camera subject to nil to prevent any default behavior
	camera.CameraSubject = nil
end

-- Connect to multiple events to ensure camera stays locked
camera:GetPropertyChangedSignal("CameraType"):Connect(lockCamera)
camera:GetPropertyChangedSignal("CameraSubject"):Connect(function()
	camera.CameraSubject = nil
end)

-- Disable zoom on mouse wheel
UserInputService.InputChanged:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseWheel then
		-- Do nothing, prevent zoom
		return
	end
end)

-- For mobile, we don't need to block these as camera is already scriptable
-- Removing these connections to avoid interfering with touch input

-- Update mobile status on screen size change
workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
	isMobile = isMobileDevice()
	HEIGHT = isMobile and 65 or 50
	SMOOTHNESS = isMobile and 0.1 or 0.05
	FOV = isMobile and 85 or 70
end)

-- Main camera update loop
RunService.RenderStepped:Connect(function()
	local character = player.Character
	if not character then return end

	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	-- Dynamic camera adjustments for mobile
	local currentHeight = HEIGHT
	local currentFOV = FOV
	
	if isMobile then
		-- Adjust height based on snake length if available
		if _G.PlayerSnakes and _G.PlayerSnakes[player] then
			local snake = _G.PlayerSnakes[player]
			local length = snake.currentLength or 10
			
			-- Scale height with snake size on mobile
			if length > 100 then
				currentHeight = HEIGHT * (1 + math.min((length - 100) / 1000, 0.5))
			end
			
			-- Dynamic FOV based on boost
			if MOBILE_DYNAMIC_FOV and snake.isBoosting then
				currentFOV = FOV + 10  -- Wider FOV when boosting
			end
		end
	end

	-- Force camera to exact position (no lerping on position, only on FOV)
	-- This gives the locked feel like slither.io
	local targetPosition = rootPart.Position + Vector3.new(0, currentHeight, 0)
	local targetLookAt = rootPart.Position
	
	-- Set camera directly for that locked feel
	camera.CFrame = CFrame.lookAt(targetPosition, targetLookAt)
	
	-- Smooth FOV changes only
	camera.FieldOfView = camera.FieldOfView + (currentFOV - camera.FieldOfView) * 0.1
	
	-- Force camera type to stay scriptable
	camera.CameraType = Enum.CameraType.Scriptable
end)

-- Initial camera lock
lockCamera()
print("Camera Controller initialized - Camera locked like slither.io!")
