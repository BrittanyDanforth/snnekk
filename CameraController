-- CameraController: FIXED TOP-DOWN VIEW (Like Slither.io)
-- LOCALSCRIPT INSIDE STARTERPLAYERSCRIPTS
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local GuiService = game:GetService("GuiService")

local camera = workspace.CurrentCamera
local player = Players.LocalPlayer

-- Strict mobile detection
local function isMobileDevice()
	-- Check if we have touch but NO mouse (most reliable)
	if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
		return true
	end
	
	-- Check for mobile-specific sensors
	if UserInputService.GyroscopeEnabled or UserInputService.AccelerometerEnabled then
		return true
	end
	
	-- Additional check for touch-only devices
	local hasMouse = UserInputService.MouseEnabled
	local hasKeyboard = UserInputService.KeyboardEnabled
	local hasTouch = UserInputService.TouchEnabled
	
	-- If we only have touch and nothing else, it's likely mobile
	if hasTouch and not hasMouse and not hasKeyboard then
		return true
	end
	
	return false
end

local isMobile = isMobileDevice()

-- Camera settings
local HEIGHT = isMobile and 80 or 50  -- Higher on mobile for better view
local FOV = 70  -- Fixed FOV like slither.io

-- 🔒 LOCK CAMERA COMPLETELY
camera.CameraType = Enum.CameraType.Scriptable
camera.CameraSubject = nil

-- Prevent ANY camera manipulation
UserInputService.MouseBehavior = Enum.MouseBehavior.Default
player.CameraMinZoomDistance = 128
player.CameraMaxZoomDistance = 128

-- Main camera update loop - SUPER SIMPLE
RunService.RenderStepped:Connect(function()
	local character = player.Character
	if not character then return end

	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	-- Get snake position
	local snakePos = rootPart.Position
	
	-- Camera ALWAYS looks straight down from above
	-- NO ROTATION, NO SPINNING, JUST STRAIGHT DOWN
	local cameraPos = snakePos + Vector3.new(0, HEIGHT, 0)
	
	-- Look straight down at snake (with slight forward offset to ensure proper orientation)
	local lookAtPos = snakePos + Vector3.new(0, 0, 0.1)
	
	-- Set camera - FIXED ORIENTATION
	camera.CFrame = CFrame.lookAt(cameraPos, lookAtPos, Vector3.new(0, 0, -1))
	
	-- Fixed FOV
	camera.FieldOfView = FOV
	
	-- Ensure camera stays scriptable
	camera.CameraType = Enum.CameraType.Scriptable
end)

print("Camera Controller: FIXED top-down view (no rotation) initialized!")
