	return displayFrame, timer, progressBar
end

function BoostItemHandler:UseBoost(boostType)
	-- Check cooldown
	if self.cooldowns[boostType] and tick() < self.cooldowns[boostType] then
		local timeLeft = math.ceil(self.cooldowns[boostType] - tick())
		self:ShowNotification("Cooldown: " .. timeLeft .. "s", Color3.fromRGB(255, 100, 100))
		return
	end
	
	-- Check if player has the boost
	if not self.inventory[boostType] or self.inventory[boostType] <= 0 then
		self:ShowNotification("No " .. boostType .. " available!", Color3.fromRGB(255, 100, 100))
		return
	end
	
	-- Use the boost
	useBoostRemote:FireServer(boostType)
end

function BoostItemHandler:ShowNotification(text, color)
	local notification = Instance.new("TextLabel")
	notification.Size = UDim2.new(0, 300, 0, 50)
	notification.Position = UDim2.new(0.5, -150, 0.5, -25)
	notification.BackgroundColor3 = color or Color3.fromRGB(100, 200, 255)
	notification.BackgroundTransparency = 0.2
	notification.Text = text
	notification.TextColor3 = Color3.fromRGB(255, 255, 255)
	notification.TextScaled = true
	notification.Font = Enum.Font.GothamBold
	notification.Parent = self.ui.screenGui
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent = notification
	
	-- Animate
	notification:TweenPosition(UDim2.new(0.5, -150, 0.5, -100), "Out", "Quad", 0.3)
	wait(2)
	notification:TweenPosition(UDim2.new(0.5, -150, 0.5, -200), "Out", "Quad", 0.3)
	wait(0.3)
	notification:Destroy()
end

function BoostItemHandler:SetupKeybinds()
	UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		
		for boostType, config in pairs(self.BOOST_TYPES) do
			if input.KeyCode == config.keybind then
				self:UseBoost(boostType)
				break
			end
		end
	end)
end

function BoostItemHandler:ConnectRemotes()
	-- Receive boost status updates
	boostStatusRemote.OnClientEvent:Connect(function(boostType, action, data)
		if action == "activate" then
			self:ActivateBoost(boostType, data.duration)
		elseif action == "deactivate" then
			self:DeactivateBoost(boostType)
		elseif action == "update_inventory" then
			self:UpdateInventory(data.inventory)
		elseif action == "cooldown" then
			self.cooldowns[boostType] = tick() + data.cooldown
		end
	end)
end

function BoostItemHandler:ActivateBoost(boostType, duration)
	local config = self.BOOST_TYPES[boostType]
	if not config then return end
	
	-- Create active display
	local display, timer, progress = self:CreateActiveBoostDisplay(boostType, duration)
	
	-- Track active boost
	self.activeBoosts[boostType] = {
		display = display,
		timer = timer,
		progress = progress,
		startTime = tick(),
		duration = duration
	}
	
	-- Show activation effect
	self:ShowNotification(config.name .. " Activated!", config.color)
	
	-- Update timer
	local startTime = tick()
	local connection
	connection = RunService.Heartbeat:Connect(function()
		local elapsed = tick() - startTime
		local timeLeft = math.max(0, duration - elapsed)
		
		if timeLeft > 0 then
			timer.Text = math.ceil(timeLeft) .. "s"
			progress.Size = UDim2.new(timeLeft / duration, -10, 0, 4)
		else
			connection:Disconnect()
			self:DeactivateBoost(boostType)
		end
	end)
end

function BoostItemHandler:DeactivateBoost(boostType)
	local boost = self.activeBoosts[boostType]
	if boost and boost.display then
		boost.display:Destroy()
	end
	self.activeBoosts[boostType] = nil
end

function BoostItemHandler:UpdateInventory(inventory)
	self.inventory = inventory
	
	-- Clear existing items
	for _, child in pairs(self.ui.scrollFrame:GetChildren()) do
		if child:IsA("Frame") then
			child:Destroy()
		end
	end
	
	-- Create items
	for boostType, count in pairs(inventory) do
		if count > 0 then
			self:CreateBoostItem(boostType, count)
		end
	end
end

return BoostItemHandler