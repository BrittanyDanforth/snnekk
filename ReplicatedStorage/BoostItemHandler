function BoostItemHandler.new(player)
	local self = setmetatable({}, BoostItemHandler)
	
	self.player = player
	self.playerGui = player:WaitForChild("PlayerGui")
	self.activeBoosts = {}
	self.cooldowns = {}
	self.inventory = {}
	
	-- Create UI
	self:CreateBoostUI()
	self:SetupKeybinds()
	self:ConnectRemotes()
	
	return self
end

