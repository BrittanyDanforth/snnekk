-- Filter functions
function InventoryUI.setFilter(filterName)
	InventoryUI.currentFilter = filterName
	InventoryUI.refreshGrid()
	
	-- Update filter button styles
	for _, child in pairs(InventoryUI.uiElements.mainWindow.FilterBar:GetChildren()) do
		if child:IsA("TextButton") and child.Name:match("^Filter_") then
			if child.Name == "Filter_" .. filterName then
				child.BackgroundColor3 = INVENTORY_CONFIG.COLORS.ACCENT
				child.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY
			else
				child.BackgroundColor3 = INVENTORY_CONFIG.COLORS.SECONDARY
				child.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_SECONDARY
			end
		end
	end
end

-- Sort functions
function InventoryUI.setSort(sortType)
	InventoryUI.currentSort = sortType
	InventoryUI.uiElements.sortBtn.Text = "Sort: " .. sortType
	InventoryUI.refreshGrid()
end

-- Refresh inventory grid
function InventoryUI.refreshGrid()
	-- Clear existing items
	for _, child in pairs(InventoryUI.uiElements.gridFrame:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end
	
	-- Get filtered items
	local items = InventoryUI.getFilteredItems()
	
	-- Sort items
	items = InventoryUI.sortItems(items)
	
	-- Create item cards
	for i, itemData in ipairs(items) do
		local card = createItemCard(itemData, i)
		card.Parent = InventoryUI.uiElements.gridFrame
	end
	
	-- Update canvas size
	local rows = math.ceil(#items / INVENTORY_CONFIG.GRID_COLUMNS)
	InventoryUI.uiElements.gridFrame.CanvasSize = UDim2.new(0, 0, 0, 
		rows * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 40
	)
end

-- Get filtered items
function InventoryUI.getFilteredItems()
	local items = {}
	
	if InventoryUI.currentFilter == "All" then
		-- Add all skins
		for skinName, skinData in pairs(InventoryUI.inventory.skins) do
			table.insert(items, {
				name = skinName,
				type = "Skin",
				color = SnakeSkins[skinName] and SnakeSkins[skinName].HeadColor,
				quantity = skinData.quantity or 1,
				rarity = skinData.rarity,
				rarityColor = skinData.rarityColor,
				description = skinData.description or "A snake skin",
				value = skinData.value or 0,
			})
		end
		
		-- Add all items
		for itemName, itemData in pairs(InventoryUI.inventory.items) do
			table.insert(items, {
				name = itemName,
				type = "Item",
				color = itemData.color,
				quantity = itemData.quantity or 1,
				rarity = itemData.rarity,
				rarityColor = itemData.rarityColor,
				description = itemData.description or "An item",
				value = itemData.value or 0,
			})
		end
	elseif InventoryUI.currentFilter == "Skins" then
		for skinName, skinData in pairs(InventoryUI.inventory.skins) do
			table.insert(items, {
				name = skinName,
				type = "Skin",
				color = SnakeSkins[skinName] and SnakeSkins[skinName].HeadColor,
				quantity = skinData.quantity or 1,
				rarity = skinData.rarity,
				rarityColor = skinData.rarityColor,
				description = skinData.description or "A snake skin",
				value = skinData.value or 0,
			})
		end
	elseif InventoryUI.currentFilter == "Items" then
		for itemName, itemData in pairs(InventoryUI.inventory.items) do
			table.insert(items, {
				name = itemName,
				type = "Item",
				color = itemData.color,
				quantity = itemData.quantity or 1,
				rarity = itemData.rarity,
				rarityColor = itemData.rarityColor,
				description = itemData.description or "An item",
				value = itemData.value or 0,
			})
		end
	elseif InventoryUI.currentFilter == "Special" then
		-- Filter for special/rare items
		for skinName, skinData in pairs(InventoryUI.inventory.skins) do
			if skinData.rarity and (skinData.rarity == "Legendary" or skinData.rarity == "Epic") then
				table.insert(items, {
					name = skinName,
					type = "Skin",
					color = SnakeSkins[skinName] and SnakeSkins[skinName].HeadColor,
					quantity = skinData.quantity or 1,
					rarity = skinData.rarity,
					rarityColor = skinData.rarityColor,
					description = skinData.description or "A snake skin",
					value = skinData.value or 0,
				})
			end
		end
	end
	
	return items
end

-- Sort items
function InventoryUI.sortItems(items)
	if InventoryUI.currentSort == "Newest" then
		-- Reverse order (assuming newer items are added to the end)
		local sorted = {}
		for i = #items, 1, -1 do
			table.insert(sorted, items[i])
		end
		return sorted
	elseif InventoryUI.currentSort == "Name" then
		table.sort(items, function(a, b)
			return a.name < b.name
		end)
	elseif InventoryUI.currentSort == "Value" then
		table.sort(items, function(a, b)
			return (a.value or 0) > (b.value or 0)
		end)
	elseif InventoryUI.currentSort == "Rarity" then
		local rarityOrder = {
			Common = 1,
			Uncommon = 2,
			Rare = 3,
			Epic = 4,
			Legendary = 5,
		}
		table.sort(items, function(a, b)
			local aRarity = rarityOrder[a.rarity] or 0
			local bRarity = rarityOrder[b.rarity] or 0
			return aRarity > bRarity
		end)
	end
	
	return items
end

-- Select item
function InventoryUI.selectItem(itemData, card)
	InventoryUI.selectedItem = itemData
	
	-- Update details panel
	InventoryUI.uiElements.itemName.Text = itemData.name
	InventoryUI.uiElements.itemDescription.Text = itemData.description
	
	-- Update preview (you can expand this to show actual item preview)
	local previewFrame = InventoryUI.uiElements.detailsPanel.PreviewFrame
	previewFrame.BackgroundColor3 = itemData.color or INVENTORY_CONFIG.COLORS.ACCENT
	
	-- Update button states
	if itemData.type == "Skin" then
		InventoryUI.uiElements.equipBtn.Visible = true
		InventoryUI.uiElements.equipBtn.Text = "EQUIP SKIN"
	else
		InventoryUI.uiElements.equipBtn.Visible = true
		InventoryUI.uiElements.equipBtn.Text = "USE ITEM"
	end
	
	-- Highlight selected card
	for _, child in pairs(InventoryUI.uiElements.gridFrame:GetChildren()) do
		if child:IsA("TextButton") then
			local stroke = child:FindFirstChild("UIStroke")
			if stroke then
				stroke:Destroy()
			end
		end
	end
	
	createStroke(card, INVENTORY_CONFIG.COLORS.ACCENT, 3)
end

-- Equip selected item
function InventoryUI.equipSelectedItem()
	if not InventoryUI.selectedItem then return end
	
	if InventoryUI.selectedItem.type == "Skin" then
		-- Fire to server to equip skin
		local selectSkinRemote = ReplicatedStorage:FindFirstChild("SelectSkin")
		if selectSkinRemote then
			selectSkinRemote:FireServer(InventoryUI.selectedItem.name)
			
			-- Success feedback
			local successText = InventoryUI.uiElements.itemName
			local originalText = successText.Text
			successText.Text = "✅ EQUIPPED!"
			successText.TextColor3 = INVENTORY_CONFIG.COLORS.SUCCESS
			
			task.wait(1.5)
			successText.Text = originalText
			successText.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY
		end
	else
		-- Handle other item types
		print("Using item:", InventoryUI.selectedItem.name)
	end
end

-- Sell selected item
function InventoryUI.sellSelectedItem()
	if not InventoryUI.selectedItem then return end
	
	-- Confirmation dialog
	local confirmText = InventoryUI.uiElements.itemDescription
	local originalText = confirmText.Text
	confirmText.Text = "Are you sure you want to sell this item?"
	confirmText.TextColor3 = INVENTORY_CONFIG.COLORS.WARNING
	
	InventoryUI.uiElements.sellBtn.Text = "CONFIRM SELL"
	InventoryUI.uiElements.sellBtn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.ERROR
	
	local connection
	connection = InventoryUI.uiElements.sellBtn.MouseButton1Click:Connect(function()
		connection:Disconnect()
		
		-- Sell the item (implement server communication here)
		print("Selling item:", InventoryUI.selectedItem.name)
		
		-- Reset UI
		confirmText.Text = originalText
		confirmText.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_SECONDARY
		InventoryUI.uiElements.sellBtn.Text = "SELL"
		InventoryUI.uiElements.sellBtn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.WARNING
		
		-- Remove from inventory and refresh
		if InventoryUI.selectedItem.type == "Skin" then
			InventoryUI.inventory.skins[InventoryUI.selectedItem.name] = nil
		else
			InventoryUI.inventory.items[InventoryUI.selectedItem.name] = nil
		end
		
		InventoryUI.selectedItem = nil
		InventoryUI.refreshGrid()
	end)
end

-- Open inventory
function InventoryUI.open()
	if not InventoryUI.screenGui then
		InventoryUI.createUI()
	end
	
	InventoryUI.isOpen = true
	InventoryUI.screenGui.Enabled = true
	
	-- Load inventory data (this should come from server)
	InventoryUI.loadInventoryData()
	
	-- Refresh grid
	InventoryUI.refreshGrid()
	
	-- Animate opening
	local mainWindow = InventoryUI.uiElements.mainWindow
	mainWindow.Size = UDim2.new(0, 0, 0, 0)
	mainWindow.Position = UDim2.new(0.5, 0, 0.5, 0)
	
	TweenService:Create(mainWindow, TweenInfo.new(INVENTORY_CONFIG.TWEEN_TIME, Enum.EasingStyle.Back), {
		Size = UDim2.new(0.85, 0, 0.85, 0),
		Position = UDim2.new(0.075, 0, 0.075, 0)
	}):Play()
end

-- Close inventory
function InventoryUI.close()
	InventoryUI.isOpen = false
	
	-- Animate closing
	local mainWindow = InventoryUI.uiElements.mainWindow
	
	TweenService:Create(mainWindow, TweenInfo.new(INVENTORY_CONFIG.TWEEN_TIME / 2), {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0.5, 0, 0.5, 0)
	}):Play()
	
	task.wait(INVENTORY_CONFIG.TWEEN_TIME / 2)
	InventoryUI.screenGui.Enabled = false
end

-- Load inventory data
function InventoryUI.loadInventoryData()
	-- Load actual player data from ShopUI
	local ShopUI = require(ReplicatedStorage:WaitForChild("ShopUI"))
	
	-- Clear existing inventory
	InventoryUI.inventory = {
		skins = {},
		items = {},
		currency = {
			coins = ShopUI.playerData.coins or 0,
			gems = 0,
		}
	}
	
	-- Load owned skins
	for _, skinName in ipairs(ShopUI.playerData.ownedSkins or {}) do
		-- Determine rarity based on price
		local skinData = ShopUI.SKIN_DATA[skinName]
		local rarity = "Common"
		local rarityColor = Color3.fromRGB(150, 150, 150)
		
		if skinData then
			if skinData.tag == "VIP" then
				rarity = "Legendary"
				rarityColor = Color3.fromRGB(255, 215, 0)
			elseif skinData.tag == "Ultimate" then
				rarity = "Mythic"
				rarityColor = Color3.fromRGB(255, 100, 255)
			elseif skinData.robux and skinData.robux >= 200 then
				rarity = "Epic"
				rarityColor = Color3.fromRGB(200, 100, 255)
			elseif skinData.robux and skinData.robux >= 100 then
				rarity = "Rare"
				rarityColor = Color3.fromRGB(100, 150, 255)
			elseif skinData.price and skinData.price >= 5000 then
				rarity = "Uncommon"
				rarityColor = Color3.fromRGB(100, 200, 100)
			end
		end
		
		InventoryUI.inventory.skins[skinName] = {
			quantity = 1,
			rarity = rarity,
			rarityColor = rarityColor,
			description = "A " .. rarity:lower() .. " snake skin",
			value = skinData and skinData.price or 0,
		}
	end
	
	-- Items would be loaded from server in a real implementation
	-- For now, no items unless the player actually has them
	
	print("📦 Loaded inventory with", #ShopUI.playerData.ownedSkins, "skins and", ShopUI.playerData.coins, "coins")
end

-- Toggle inventory (for keybind)
function InventoryUI.toggle()
	if InventoryUI.isOpen then
		InventoryUI.close()
	else
		InventoryUI.open()
	end
end

-- Set up keybind
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == Enum.KeyCode.I then
		InventoryUI.toggle()
	end
end)

return InventoryUI