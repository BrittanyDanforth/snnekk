	closeBtn.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY
	closeBtn.TextScaled = true
	closeBtn.Font = INVENTORY_CONFIG.FONTS.BUTTON
	closeBtn.Parent = header
	
	createCorner(closeBtn, 8)
	
	InventoryUI.uiElements.closeBtn = closeBtn
	
	-- Filter/Sort bar
