	local filters = {
		{name = "All", icon = "🏠"},
		{name = "Skins", icon = "🎨"},
		{name = "Items", icon = "🎒"},
		{name = "Special", icon = "✨"}
	}
	
	for i, filterData in ipairs(filters) do
		local filterBtn = Instance.new("TextButton")
		filterBtn.Name = "Filter_" .. filterData.name
		filterBtn.Size = UDim2.new(0.15, -5, 1, 0)
		filterBtn.Position = UDim2.new(0.02 + (i-1) * 0.16, 0, 0, 0)
		filterBtn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.SECONDARY
		filterBtn.Text = ""
		filterBtn.AutoButtonColor = false
		filterBtn.Parent = filterBar
		
		createCorner(filterBtn, 12)
		createGlassPanel(filterBtn, 0.9)
		
		-- Modern hover effect
		local isSelected = i == 1
		if isSelected then
			filterBtn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.ACCENT
			createShadow(filterBtn, 0.6, 8)
		end
		
		-- Icon
		local icon = Instance.new("TextLabel")
		icon.Name = "Icon"
		icon.Size = UDim2.new(0.3, 0, 0.6, 0)
		icon.Position = UDim2.new(0.1, 0, 0.2, 0)
