		text.BackgroundTransparency = 1
		text.Text = filterData.name
		text.TextScaled = true
		text.TextColor3 = isSelected and INVENTORY_CONFIG.COLORS.TEXT_PRIMARY or INVENTORY_CONFIG.COLORS.TEXT_SECONDARY
		text.Font = INVENTORY_CONFIG.FONTS.BUTTON
		text.TextXAlignment = Enum.TextXAlignment.Left
		text.Parent = filterBtn
		
		-- Hover effects
		filterBtn.MouseEnter:Connect(function()
			if not isSelected then
				TweenService:Create(filterBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
					BackgroundColor3 = INVENTORY_CONFIG.COLORS.TERTIARY
				}):Play()
			end
		end)
		
		filterBtn.MouseLeave:Connect(function()
			if not isSelected then
				TweenService:Create(filterBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
					BackgroundColor3 = INVENTORY_CONFIG.COLORS.SECONDARY
				}):Play()
			end
		end)
		
		filterBtn.MouseButton1Click:Connect(function()
			InventoryUI.setFilter(filterData.name)
			
			-- Update all filter button states
			for _, btn in pairs(filterBar:GetChildren()) do
				if btn:IsA("TextButton") then
					local btnIcon = btn:FindFirstChild("Icon")
					local btnText = btn:FindFirstChild("Text")
					if btn == filterBtn then
						btn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.ACCENT
						if btnIcon then btnIcon.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY end
						if btnText then btnText.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY end
						createShadow(btn, 0.6, 8)
					else
						btn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.SECONDARY
						if btnIcon then btnIcon.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_MUTED end
						if btnText then btnText.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_SECONDARY end
						local shadow = btn.Parent:FindFirstChild("Shadow")
						if shadow then shadow:Destroy() end
					end
				end
			end
		end)
	end
	
	-- Modern sort dropdown
	local sortBtn = Instance.new("TextButton")
	sortBtn.Name = "SortButton"
	sortBtn.Size = UDim2.new(0.15, 0, 1, 0)
	sortBtn.Position = UDim2.new(0.83, 0, 0, 0)
	sortBtn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.SECONDARY
	sortBtn.Text = ""
	sortBtn.AutoButtonColor = false
	sortBtn.Parent = filterBar
	
	createCorner(sortBtn, 12)
	createGlassPanel(sortBtn, 0.9)
	
	-- Sort icon
	local sortIcon = Instance.new("TextLabel")
	sortIcon.Name = "Icon"
	sortIcon.Size = UDim2.new(0.25, 0, 0.6, 0)
	sortIcon.Position = UDim2.new(0.05, 0, 0.2, 0)
	sortIcon.BackgroundTransparency = 1
	sortIcon.Text = "↕"
	sortIcon.TextScaled = true
