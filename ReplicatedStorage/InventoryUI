		end
	end
	
	createStroke(card, INVENTORY_CONFIG.COLORS.ACCENT, 3)
end

-- Equip selected item
function InventoryUI.equipSelectedItem()
	if not InventoryUI.selectedItem then 
		warn("❌ No item selected to equip")
		return 
	end
	
	if InventoryUI.selectedItem.type == "Skin" then
		-- Don't do anything if already equipped
		if InventoryUI.selectedItem.equipped then
			print("⚠️ Skin already equipped:", InventoryUI.selectedItem.name)
			return
		end
		
		-- Fire to server to equip skin
		local selectSkinRemote = ReplicatedStorage:FindFirstChild("SelectSkin")
		if not selectSkinRemote then
			warn("❌ SelectSkin remote not found!")
			return
		end
		
		-- Fire server event with error handling
		local success, err = pcall(function()
			selectSkinRemote:FireServer(InventoryUI.selectedItem.name)
		end)
		
		if not success then
			warn("❌ Failed to fire SelectSkin remote:", err)
			return
		end
		
		-- Update local data immediately
		if ShopUI and ShopUI.playerData then
			ShopUI.playerData.currentSkin = InventoryUI.selectedItem.name
		end
		
		-- Update equipped status immediately in the current inventory
		local previousEquipped = nil
		for skinName, skinData in pairs(InventoryUI.inventory.skins) do
			if skinData.equipped then
				previousEquipped = skinName
				skinData.equipped = false
			end
		end
		
		-- Set the new equipped skin
		if InventoryUI.inventory.skins[InventoryUI.selectedItem.name] then
			InventoryUI.inventory.skins[InventoryUI.selectedItem.name].equipped = true
		end
		
		-- Refresh grid immediately for instant visual update
		InventoryUI.refreshGrid()
		
		-- Success feedback
		local successText = InventoryUI.uiElements.itemName
		local originalText = successText.Text
		successText.Text = "✅ EQUIPPED!"
		successText.TextColor3 = INVENTORY_CONFIG.COLORS.SUCCESS
		
		-- Update shop if it's open
		pcall(function()
			if ShopUI then
				ShopUI.updateSkinGrid()
				ShopUI.updateInfo()
			end
		end)
		
		-- Reset text after delay
		task.spawn(function()
			task.wait(1)
			if successText and successText.Parent then
				successText.Text = originalText
				successText.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY
			end
		end)
	else
		-- Handle other item types
		print("Using item:", InventoryUI.selectedItem.name)
	end
end

