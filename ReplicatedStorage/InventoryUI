-- Helper functions from ShopUI
local function createCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = parent
end

local function createGlassPanel(parent, transparency)
	local glass = Instance.new("Frame")
	glass.Name = "GlassEffect"
	glass.Size = UDim2.new(1, 0, 1, 0)
	glass.BackgroundColor3 = INVENTORY_CONFIG.COLORS.GLASS_TINT
	glass.BackgroundTransparency = transparency or 0.9
	glass.BorderSizePixel = 0
	glass.Parent = parent
	
	createCorner(glass, 20)
	
	-- Gradient overlay
	local gradient = Instance.new("UIGradient")
	gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
		ColorSequenceKeypoint.new(0.5, Color3.new(0.9, 0.9, 0.95)),
		ColorSequenceKeypoint.new(1, Color3.new(0.8, 0.8, 0.9))
	})
	gradient.Rotation = 45
	gradient.Parent = glass
	
	return glass
end

local function createStroke(parent, color, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color or INVENTORY_CONFIG.COLORS.ACCENT
	stroke.Thickness = thickness or 2
	stroke.Transparency = 0.5
	stroke.Parent = parent
	return stroke
end

-- Create animated background
local function createAnimatedBackground(parent)
	local bgFrame = Instance.new("Frame")
	bgFrame.Name = "AnimatedBackground"
	bgFrame.Size = UDim2.new(1, 0, 1, 0)
	bgFrame.BackgroundColor3 = INVENTORY_CONFIG.COLORS.BACKGROUND
	bgFrame.Parent = parent
	
	-- Moving gradient orbs
	for i = 1, 3 do
		local orb = Instance.new("ImageLabel")
		orb.Name = "Orb" .. i
		orb.Size = UDim2.new(0.4, 0, 0.4, 0)
		orb.Position = UDim2.new(math.random(), 0, math.random(), 0)
		orb.BackgroundTransparency = 1
		orb.Image = "rbxassetid://5028857084"
		orb.ImageColor3 = INVENTORY_CONFIG.COLORS.GLOW
		orb.ImageTransparency = 0.7
		orb.Parent = bgFrame
		
		-- Animate orb movement
		task.spawn(function()
			local startTime = tick()
			local speed = 0.1 + (i * 0.05)
			
			RunService.Heartbeat:Connect(function()
				local elapsed = tick() - startTime
				local x = 0.5 + math.sin(elapsed * speed) * 0.3
				local y = 0.5 + math.cos(elapsed * speed * 0.8) * 0.3
				
				orb.Position = UDim2.new(x - 0.2, 0, y - 0.2, 0)
			end)
		end)
	end
	
	return bgFrame
end

-- Create inventory item card
local function createItemCard(itemData, index)
	local card = Instance.new("TextButton")
	card.Name = "ItemCard_" .. index
	card.Size = UDim2.new(0, INVENTORY_CONFIG.ITEM_SIZE, 0, INVENTORY_CONFIG.ITEM_SIZE)
	card.BackgroundColor3 = INVENTORY_CONFIG.COLORS.PRIMARY
	card.Text = ""
	card.AutoButtonColor = false
	
	-- Calculate grid position
	local col = (index - 1) % INVENTORY_CONFIG.GRID_COLUMNS
	local row = math.floor((index - 1) / INVENTORY_CONFIG.GRID_COLUMNS)
	card.Position = UDim2.new(
		0, col * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 20,
		0, row * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 20
	)
	
	createCorner(card, 12)
	createGlassPanel(card, 0.8)
	
	-- Item icon/preview
	local icon = Instance.new("Frame")
	icon.Name = "Icon"
	icon.Size = UDim2.new(0.7, 0, 0.7, 0)
	icon.Position = UDim2.new(0.15, 0, 0.1, 0)
	icon.BackgroundColor3 = itemData.color or INVENTORY_CONFIG.COLORS.ACCENT
	icon.Parent = card
	
	createCorner(icon, 8)
	
	-- Item name
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "ItemName"
	nameLabel.Size = UDim2.new(0.9, 0, 0.15, 0)
	nameLabel.Position = UDim2.new(0.05, 0, 0.82, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = itemData.name
	nameLabel.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY
	nameLabel.TextScaled = true
	nameLabel.Font = INVENTORY_CONFIG.FONTS.BODY
	nameLabel.Parent = card
	
	-- Quantity badge (if applicable)
	if itemData.quantity and itemData.quantity > 1 then
		local quantityBadge = Instance.new("Frame")
		quantityBadge.Name = "QuantityBadge"
		quantityBadge.Size = UDim2.new(0.3, 0, 0.3, 0)
		quantityBadge.Position = UDim2.new(0.65, 0, 0.05, 0)
		quantityBadge.BackgroundColor3 = INVENTORY_CONFIG.COLORS.ACCENT
		quantityBadge.Parent = card
		
		createCorner(quantityBadge, 15)
		
		local quantityText = Instance.new("TextLabel")
		quantityText.Size = UDim2.new(1, 0, 1, 0)
		quantityText.BackgroundTransparency = 1
		quantityText.Text = tostring(itemData.quantity)
		quantityText.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY
		quantityText.TextScaled = true
		quantityText.Font = INVENTORY_CONFIG.FONTS.BUTTON
		quantityText.Parent = quantityBadge
	end
	
	-- Rarity indicator
	if itemData.rarity then
		local rarityGlow = Instance.new("ImageLabel")
		rarityGlow.Name = "RarityGlow"
		rarityGlow.Size = UDim2.new(1.1, 0, 1.1, 0)
		rarityGlow.Position = UDim2.new(-0.05, 0, -0.05, 0)
		rarityGlow.BackgroundTransparency = 1
		rarityGlow.Image = "rbxassetid://5028857084"
		rarityGlow.ImageColor3 = itemData.rarityColor or INVENTORY_CONFIG.COLORS.ACCENT
		rarityGlow.ImageTransparency = 0.7
		rarityGlow.ZIndex = card.ZIndex - 1
		rarityGlow.Parent = card
	end
	
	-- Hover effects
	card.MouseEnter:Connect(function()
		TweenService:Create(card, TweenInfo.new(INVENTORY_CONFIG.HOVER_TIME), {
			Size = UDim2.new(0, INVENTORY_CONFIG.ITEM_SIZE * 1.05, 0, INVENTORY_CONFIG.ITEM_SIZE * 1.05),
			Position = card.Position - UDim2.new(0, INVENTORY_CONFIG.ITEM_SIZE * 0.025, 0, INVENTORY_CONFIG.ITEM_SIZE * 0.025)
		}):Play()
		
		if itemData.rarity then
			TweenService:Create(card.RarityGlow, TweenInfo.new(INVENTORY_CONFIG.HOVER_TIME), {
				ImageTransparency = 0.4
			}):Play()
		end
	end)
	
	card.MouseLeave:Connect(function()
		TweenService:Create(card, TweenInfo.new(INVENTORY_CONFIG.HOVER_TIME), {
			Size = UDim2.new(0, INVENTORY_CONFIG.ITEM_SIZE, 0, INVENTORY_CONFIG.ITEM_SIZE),
			Position = UDim2.new(
				0, col * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 20,
				0, row * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 20
			)
		}):Play()
		
		if itemData.rarity then
			TweenService:Create(card.RarityGlow, TweenInfo.new(INVENTORY_CONFIG.HOVER_TIME), {
				ImageTransparency = 0.7
			}):Play()
		end
	end)
	
	-- Click handler
	card.MouseButton1Click:Connect(function()
		InventoryUI.selectItem(itemData, card)
	end)
	
	return card
end

