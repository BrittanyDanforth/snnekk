-- Load inventory data
function InventoryUI.loadInventoryData()
	-- Validate ShopUI exists
	if not ShopUI or not ShopUI.playerData then
		warn("❌ ShopUI not ready, using defaults")
		InventoryUI.inventory = {
			skins = {["Default"] = {quantity = 1, rarity = "Common", equipped = true}},
			items = {},
			currency = {coins = 0, gems = 0}
		}
		return
	end
	
	-- Clear existing inventory
	InventoryUI.inventory = {
		skins = {},
		items = {},
		currency = {
			coins = tonumber(ShopUI.playerData.coins) or 0,
			gems = 0,
		}
	}
	
	-- Load owned skins with validation
	local currentSkin = ShopUI.playerData.currentSkin or "Default"
	local ownedSkins = ShopUI.playerData.ownedSkins or {"Default"}
	
	print("📦 Loading inventory - Current skin:", currentSkin)
	print("📦 Owned skins:", table.concat(ownedSkins, ", "))
	
	-- Ensure Default is always owned
	local hasDefault = false
	for _, skin in ipairs(ownedSkins) do
		if skin == "Default" then
			hasDefault = true
			break
		end
	end
	if not hasDefault then
		table.insert(ownedSkins, 1, "Default")
	end
	
	for _, skinName in ipairs(ownedSkins) do
		-- Determine rarity based on price
		local skinData = ShopUI.SKIN_DATA[skinName]
		local rarity = "Common"
		local rarityColor = Color3.fromRGB(150, 150, 150)
		
		if skinData then
			if skinData.tag == "VIP" then
				rarity = "Legendary"
				rarityColor = Color3.fromRGB(255, 215, 0)
			elseif skinData.tag == "Ultimate" then
				rarity = "Mythic"
				rarityColor = Color3.fromRGB(255, 100, 255)
			elseif skinData.robux and skinData.robux >= 200 then
				rarity = "Epic"
				rarityColor = Color3.fromRGB(200, 100, 255)
			elseif skinData.robux and skinData.robux >= 100 then
				rarity = "Rare"
				rarityColor = Color3.fromRGB(100, 150, 255)
			elseif skinData.price and skinData.price >= 5000 then
				rarity = "Uncommon"
				rarityColor = Color3.fromRGB(100, 200, 100)
			end
		end
		
		InventoryUI.inventory.skins[skinName] = {
			quantity = 1,
			rarity = rarity,
			rarityColor = rarityColor,
			description = "A " .. rarity:lower() .. " snake skin",
			value = skinData and skinData.price or 0,
			equipped = (skinName == currentSkin),
		}
		
		-- Debug log
		if skinName == currentSkin then
			print("✅ Marked", skinName, "as equipped!")
		end
	end
	
	-- Items would be loaded from server in a real implementation
	-- For now, no items unless the player actually has them
	
	print("📦 Loaded inventory with", #ShopUI.playerData.ownedSkins, "skins and", ShopUI.playerData.coins, "coins")
end

