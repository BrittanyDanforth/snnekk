-- Helper functions from ShopUI
local function createCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = parent
end

-- Modern shadow effect
local function createShadow(parent, transparency, size)
	local shadow = Instance.new("Frame")
	shadow.Name = "Shadow"
	shadow.Size = UDim2.new(1, size or 10, 1, size or 10)
	shadow.Position = UDim2.new(0, -(size or 10)/2, 0, -(size or 10)/2)
	shadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	shadow.BackgroundTransparency = transparency or 0.7
	shadow.ZIndex = parent.ZIndex - 1
	shadow.Parent = parent.Parent
	parent.Parent = shadow.Parent
	shadow.Parent = parent.Parent
	
	createCorner(shadow, parent:FindFirstChild("UICorner") and parent.UICorner.CornerRadius.Offset or 12)
	
	return shadow
end

local function createGlassPanel(parent, transparency)
	local glass = Instance.new("Frame")
	glass.Name = "GlassEffect"
	glass.Size = UDim2.new(1, 0, 1, 0)
	glass.BackgroundColor3 = INVENTORY_CONFIG.COLORS.GLASS_TINT
	glass.BackgroundTransparency = transparency or 0.9
	glass.BorderSizePixel = 0
	glass.Parent = parent
	
	createCorner(glass, 20)
	
	-- Gradient overlay
	local gradient = Instance.new("UIGradient")
	gradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
		ColorSequenceKeypoint.new(0.5, Color3.new(0.9, 0.9, 0.95)),
		ColorSequenceKeypoint.new(1, Color3.new(0.8, 0.8, 0.9))
	})
	gradient.Rotation = 45
	gradient.Parent = glass
	
	return glass
end

local function createStroke(parent, color, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color or INVENTORY_CONFIG.COLORS.ACCENT
	stroke.Thickness = thickness or 2
	stroke.Transparency = 0.5
	stroke.Parent = parent
	return stroke
end

-- Create animated background
local function createAnimatedBackground(parent)
	local bgFrame = Instance.new("Frame")
	bgFrame.Name = "AnimatedBackground"
	bgFrame.Size = UDim2.new(1, 0, 1, 0)
	bgFrame.BackgroundColor3 = INVENTORY_CONFIG.COLORS.BACKGROUND
	bgFrame.Parent = parent
	
	-- Moving gradient orbs
	for i = 1, 3 do
		local orb = Instance.new("ImageLabel")
		orb.Name = "Orb" .. i
		orb.Size = UDim2.new(0.4, 0, 0.4, 0)
		orb.Position = UDim2.new(math.random(), 0, math.random(), 0)
		orb.BackgroundTransparency = 1
		orb.Image = "rbxassetid://5028857084"
		orb.ImageColor3 = INVENTORY_CONFIG.COLORS.GLOW
		orb.ImageTransparency = 0.7
		orb.Parent = bgFrame
		
		-- Animate orb movement
		task.spawn(function()
			local startTime = tick()
			local speed = 0.1 + (i * 0.05)
			
			RunService.Heartbeat:Connect(function()
				local elapsed = tick() - startTime
				local x = 0.5 + math.sin(elapsed * speed) * 0.3
				local y = 0.5 + math.cos(elapsed * speed * 0.8) * 0.3
				
				orb.Position = UDim2.new(x - 0.2, 0, y - 0.2, 0)
			end)
		end)
	end
	
	return bgFrame
end

-- Create inventory item card
local function createItemCard(itemData, index)
	-- Validate input
	if not itemData or type(itemData) ~= "table" then
		warn("❌ Invalid item data for card", index)
		return nil
	end
	
	local success, card = pcall(function()
		local card = Instance.new("TextButton")
		card.Name = "ItemCard_" .. tostring(index)
		card.Size = UDim2.new(0, INVENTORY_CONFIG.ITEM_SIZE, 0, INVENTORY_CONFIG.ITEM_SIZE)
		card.BackgroundColor3 = INVENTORY_CONFIG.COLORS.PRIMARY
		card.Text = ""
		card.AutoButtonColor = false
		card.ZIndex = 2
		return card
	end)
	
	if not success then
		warn("❌ Failed to create card:", card)
		return nil
	end
	
	-- Calculate grid position
	local col = (index - 1) % INVENTORY_CONFIG.GRID_COLUMNS
	local row = math.floor((index - 1) / INVENTORY_CONFIG.GRID_COLUMNS)
	card.Position = UDim2.new(
		0, col * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 20,
		0, row * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 20
	)
	
	createCorner(card, 12)
	createGlassPanel(card, 0.8)
	
	-- Add rarity border
	local rarityColor = itemData.rarityColor or INVENTORY_CONFIG.COLORS[string.upper(itemData.rarity or "COMMON")] or INVENTORY_CONFIG.COLORS.COMMON
	local rarityStroke = Instance.new("UIStroke")
	rarityStroke.Name = "RarityBorder"
	rarityStroke.Color = rarityColor
	rarityStroke.Thickness = 2
	rarityStroke.Transparency = 0.3
	rarityStroke.Parent = card
	
	-- Add subtle shadow
	createShadow(card, 0.8, 6)
	
	-- Item icon/preview with gradient
	local icon = Instance.new("Frame")
	icon.Name = "Icon"
	icon.Size = UDim2.new(0.7, 0, 0.7, 0)
	icon.Position = UDim2.new(0.15, 0, 0.1, 0)
	icon.BackgroundColor3 = itemData.color or INVENTORY_CONFIG.COLORS.ACCENT
	icon.Parent = card
	
	createCorner(icon, 8)
	
	-- Add gradient to icon
	local iconGradient = Instance.new("UIGradient")
	iconGradient.Rotation = 45
	iconGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 200, 200))
	})
	iconGradient.Parent = icon
	
	-- Add shimmer effect for rare+ items
	if itemData.rarity and (itemData.rarity == "Rare" or itemData.rarity == "Epic" or itemData.rarity == "Legendary" or itemData.rarity == "Mythic") then
		local shimmer = Instance.new("Frame")
		shimmer.Name = "Shimmer"
		shimmer.Size = UDim2.new(0.5, 0, 2, 0)
		shimmer.Position = UDim2.new(-0.5, 0, -0.5, 0)
		shimmer.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		shimmer.BackgroundTransparency = 0.7
		shimmer.Rotation = 45
		shimmer.Parent = icon
		
		local shimmerGradient = Instance.new("UIGradient")
		shimmerGradient.Transparency = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 1),
			NumberSequenceKeypoint.new(0.5, 0.5),
			NumberSequenceKeypoint.new(1, 1)
		})
		shimmerGradient.Parent = shimmer
		
		-- Animate shimmer
		task.spawn(function()
			while shimmer.Parent do
				shimmer.Position = UDim2.new(-0.5, 0, -0.5, 0)
				TweenService:Create(shimmer, TweenInfo.new(3, Enum.EasingStyle.Linear), {
					Position = UDim2.new(1, 0, -0.5, 0)
				}):Play()
				task.wait(3)
			end
		end)
	end
	
	-- Item name (with validation)
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "ItemName"
	nameLabel.Size = UDim2.new(0.9, 0, 0.15, 0)
	nameLabel.Position = UDim2.new(0.05, 0, 0.82, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = tostring(itemData.name or "Unknown")
	nameLabel.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY
	nameLabel.TextScaled = true
	nameLabel.Font = INVENTORY_CONFIG.FONTS.BODY
	nameLabel.Parent = card
	
	-- Equipped indicator - modern minimalist style
	if itemData.equipped then
		-- Outer glow effect
		local glowFrame = Instance.new("Frame")
		glowFrame.Name = "EquippedGlow"
		glowFrame.Size = UDim2.new(1.05, 0, 1.05, 0)
		glowFrame.Position = UDim2.new(-0.025, 0, -0.025, 0)
		glowFrame.BackgroundColor3 = INVENTORY_CONFIG.COLORS.SUCCESS
		glowFrame.BackgroundTransparency = 0.7
		glowFrame.ZIndex = card.ZIndex - 1
		glowFrame.Parent = card
		createCorner(glowFrame, 14)
		
		-- Small corner badge
		local equippedBadge = Instance.new("Frame")
		equippedBadge.Name = "EquippedBadge"
		equippedBadge.Size = UDim2.new(0.35, 0, 0.12, 0)
		equippedBadge.Position = UDim2.new(0.62, 0, 0.02, 0)
		equippedBadge.BackgroundColor3 = INVENTORY_CONFIG.COLORS.SUCCESS
		equippedBadge.Parent = card
		
		createCorner(equippedBadge, 6)
		
		local equippedText = Instance.new("TextLabel")
		equippedText.Size = UDim2.new(1, 0, 1, 0)
		equippedText.BackgroundTransparency = 1
		equippedText.Text = "✓"
		equippedText.TextColor3 = Color3.fromRGB(255, 255, 255)
		equippedText.TextScaled = true
		equippedText.Font = INVENTORY_CONFIG.FONTS.BUTTON
		equippedText.Parent = equippedBadge
		
		-- Add a subtle animation
		task.spawn(function()
			while equippedBadge.Parent do
				TweenService:Create(glowFrame, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
					BackgroundTransparency = 0.85
				}):Play()
				task.wait(2)
				TweenService:Create(glowFrame, TweenInfo.new(2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
					BackgroundTransparency = 0.7
				}):Play()
				task.wait(2)
			end
		end)
	end
	
	-- Quantity badge (if applicable)
	if itemData.quantity and itemData.quantity > 1 then
		local quantityBadge = Instance.new("Frame")
		quantityBadge.Name = "QuantityBadge"
		quantityBadge.Size = UDim2.new(0.3, 0, 0.3, 0)
		quantityBadge.Position = UDim2.new(0.65, 0, 0.05, 0)
		quantityBadge.BackgroundColor3 = INVENTORY_CONFIG.COLORS.ACCENT
		quantityBadge.Parent = card
		
		createCorner(quantityBadge, 15)
		
		local quantityText = Instance.new("TextLabel")
		quantityText.Size = UDim2.new(1, 0, 1, 0)
		quantityText.BackgroundTransparency = 1
		quantityText.Text = tostring(itemData.quantity)
		quantityText.TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY
		quantityText.TextScaled = true
		quantityText.Font = INVENTORY_CONFIG.FONTS.BUTTON
		quantityText.Parent = quantityBadge
	end
	
	-- Rarity indicator
	if itemData.rarity then
		local rarityGlow = Instance.new("ImageLabel")
		rarityGlow.Name = "RarityGlow"
		rarityGlow.Size = UDim2.new(1.1, 0, 1.1, 0)
		rarityGlow.Position = UDim2.new(-0.05, 0, -0.05, 0)
		rarityGlow.BackgroundTransparency = 1
		rarityGlow.Image = "rbxassetid://5028857084"
		rarityGlow.ImageColor3 = itemData.rarityColor or INVENTORY_CONFIG.COLORS.ACCENT
		rarityGlow.ImageTransparency = 0.7
		rarityGlow.ZIndex = card.ZIndex - 1
		rarityGlow.Parent = card
	end
	
	-- Modern hover effects
	card.MouseEnter:Connect(function()
		-- Scale up with spring animation
		TweenService:Create(card, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, INVENTORY_CONFIG.ITEM_SIZE * 1.08, 0, INVENTORY_CONFIG.ITEM_SIZE * 1.08),
			BackgroundColor3 = INVENTORY_CONFIG.COLORS.SECONDARY
		}):Play()
		
		-- Enhance glow
		if rarityStroke then
			TweenService:Create(rarityStroke, TweenInfo.new(0.3), {
				Transparency = 0,
				Thickness = 3
			}):Play()
		end
		
		-- Show hover info
		TweenService:Create(nameLabel, TweenInfo.new(0.2), {
			TextColor3 = rarityColor
		}):Play()
		
		if itemData.rarity then
			TweenService:Create(card.RarityGlow, TweenInfo.new(INVENTORY_CONFIG.HOVER_TIME), {
				ImageTransparency = 0.4
			}):Play()
		end
	end)
	
	card.MouseLeave:Connect(function()
		-- Reset with smooth animation
		TweenService:Create(card, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, INVENTORY_CONFIG.ITEM_SIZE, 0, INVENTORY_CONFIG.ITEM_SIZE),
			Position = card:GetAttribute("OriginalPosition") or UDim2.new(
				0, col * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 20,
				0, row * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 20
			),
			BackgroundColor3 = INVENTORY_CONFIG.COLORS.PRIMARY
		}):Play()
		
		-- Reset glow
		if rarityStroke then
			TweenService:Create(rarityStroke, TweenInfo.new(0.3), {
				Transparency = 0.3,
				Thickness = 2
			}):Play()
		end
		
		-- Reset text color
		TweenService:Create(nameLabel, TweenInfo.new(0.2), {
			TextColor3 = INVENTORY_CONFIG.COLORS.TEXT_PRIMARY
		}):Play()
		
		if itemData.rarity and card:FindFirstChild("RarityGlow") then
			TweenService:Create(card.RarityGlow, TweenInfo.new(0.3), {
				ImageTransparency = 0.7
			}):Play()
		end
	end)
	
	-- Click handler
	card.MouseButton1Click:Connect(function()
		InventoryUI.selectItem(itemData, card)
	end)
	
	return card
end

