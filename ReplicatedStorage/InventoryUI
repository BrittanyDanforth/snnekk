	local btnIcon = InventoryUI.uiElements.equipBtn:FindFirstChild("Content") and InventoryUI.uiElements.equipBtn.Content:FindFirstChild("Icon")
	
	if itemData.type == "Skin" then
		InventoryUI.uiElements.equipBtn.Visible = true
		if itemData.equipped then
			if btnText then btnText.Text = "EQUIPPED" end
			if btnIcon then btnIcon.Text = "✓" end
			InventoryUI.uiElements.equipBtn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.SECONDARY
		else
			if btnText then btnText.Text = "EQUIP" end
			if btnIcon then btnIcon.Text = "⚡" end
			InventoryUI.uiElements.equipBtn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.SUCCESS
		end
	else
		InventoryUI.uiElements.equipBtn.Visible = true
		if btnText then btnText.Text = "USE" end
		if btnIcon then btnIcon.Text = "🎯" end
		InventoryUI.uiElements.equipBtn.BackgroundColor3 = INVENTORY_CONFIG.COLORS.SUCCESS
