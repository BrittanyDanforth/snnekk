-- Refresh inventory grid
function InventoryUI.refreshGrid()
	-- Validate UI elements exist
	if not InventoryUI.uiElements or not InventoryUI.uiElements.gridFrame then
		warn("❌ Grid frame not ready for refresh")
		return
	end
	
	-- Clear existing items safely
	local success, err = pcall(function()
		for _, child in pairs(InventoryUI.uiElements.gridFrame:GetChildren()) do
			if child:IsA("TextButton") then
				child:Destroy()
			end
		end
	end)
	
	if not success then
		warn("❌ Failed to clear grid:", err)
		return
	end
	
	-- Get filtered items
	local items = InventoryUI.getFilteredItems()
	
	-- Sort items
	items = InventoryUI.sortItems(items)
	
	-- Create item cards with validation
	for i, itemData in ipairs(items) do
		local card = createItemCard(itemData, i)
		if card then
			card.Parent = InventoryUI.uiElements.gridFrame
		end
	end
	
	-- Update canvas size
	local rows = math.ceil(#items / INVENTORY_CONFIG.GRID_COLUMNS)
	InventoryUI.uiElements.gridFrame.CanvasSize = UDim2.new(0, 0, 0, 
		rows * (INVENTORY_CONFIG.ITEM_SIZE + INVENTORY_CONFIG.ITEM_SPACING) + 40
	)
end

-- Get filtered items
function InventoryUI.getFilteredItems()
	local items = {}
	
	if InventoryUI.currentFilter == "All" then
		-- Add all skins
		for skinName, skinData in pairs(InventoryUI.inventory.skins) do
			table.insert(items, {
				name = skinName,
				type = "Skin",
				color = SnakeSkins[skinName] and SnakeSkins[skinName].HeadColor,
				quantity = skinData.quantity or 1,
				rarity = skinData.rarity,
				rarityColor = skinData.rarityColor,
				description = skinData.description or "A snake skin",
				value = skinData.value or 0,
				equipped = skinData.equipped or false,
			})
		end
		
		-- Add all items
		for itemName, itemData in pairs(InventoryUI.inventory.items) do
			table.insert(items, {
				name = itemName,
				type = "Item",
				color = itemData.color,
				quantity = itemData.quantity or 1,
				rarity = itemData.rarity,
				rarityColor = itemData.rarityColor,
				description = itemData.description or "An item",
				value = itemData.value or 0,
			})
		end
	elseif InventoryUI.currentFilter == "Skins" then
		for skinName, skinData in pairs(InventoryUI.inventory.skins) do
			table.insert(items, {
				name = skinName,
				type = "Skin",
				color = SnakeSkins[skinName] and SnakeSkins[skinName].HeadColor,
				quantity = skinData.quantity or 1,
				rarity = skinData.rarity,
				rarityColor = skinData.rarityColor,
				description = skinData.description or "A snake skin",
				value = skinData.value or 0,
				equipped = skinData.equipped or false,
			})
		end
	elseif InventoryUI.currentFilter == "Items" then
		for itemName, itemData in pairs(InventoryUI.inventory.items) do
			table.insert(items, {
				name = itemName,
				type = "Item",
				color = itemData.color,
				quantity = itemData.quantity or 1,
				rarity = itemData.rarity,
				rarityColor = itemData.rarityColor,
				description = itemData.description or "An item",
				value = itemData.value or 0,
			})
		end
	elseif InventoryUI.currentFilter == "Special" then
		-- Filter for special/rare items
		for skinName, skinData in pairs(InventoryUI.inventory.skins) do
			if skinData.rarity and (skinData.rarity == "Legendary" or skinData.rarity == "Epic") then
				table.insert(items, {
					name = skinName,
					type = "Skin",
					color = SnakeSkins[skinName] and SnakeSkins[skinName].HeadColor,
					quantity = skinData.quantity or 1,
					rarity = skinData.rarity,
					rarityColor = skinData.rarityColor,
					description = skinData.description or "A snake skin",
					value = skinData.value or 0,
					equipped = skinData.equipped or false,
				})
			end
		end
	end
	
	return items
end

-- Sort items
function InventoryUI.sortItems(items)
	if InventoryUI.currentSort == "Newest" then
		-- Reverse order (assuming newer items are added to the end)
		local sorted = {}
		for i = #items, 1, -1 do
			table.insert(sorted, items[i])
		end
		return sorted
	elseif InventoryUI.currentSort == "Name" then
		table.sort(items, function(a, b)
			return a.name < b.name
		end)
	elseif InventoryUI.currentSort == "Value" then
		table.sort(items, function(a, b)
			return (a.value or 0) > (b.value or 0)
		end)
	elseif InventoryUI.currentSort == "Rarity" then
		local rarityOrder = {
			Common = 1,
			Uncommon = 2,
			Rare = 3,
			Epic = 4,
			Legendary = 5,
		}
		table.sort(items, function(a, b)
			local aRarity = rarityOrder[a.rarity] or 0
			local bRarity = rarityOrder[b.rarity] or 0
			return aRarity > bRarity
		end)
	end
	
	return items
end

