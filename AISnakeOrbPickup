-- This module augments the existing AISnake logic to allow AI snakes to pick up orbs.
-- OPTIMIZED VERSION for better FPS and reduced ping
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local OrbUtils = require(ReplicatedStorage:WaitForChild("OrbUtils"))

local ORB_PICKUP_RADIUS = 12  -- Increased for death orbs
local ORB_PICKUP_RADIUS_SQ = ORB_PICKUP_RADIUS * ORB_PICKUP_RADIUS  -- Pre-calculated

-- Cache math functions
local mathAbs = math.abs
local mathMax = math.max

local AISnakeOrbPickup = {}

-- Cache for orb folder
local cachedOrbFolder = nil
local lastOrbFolderCheck = 0

-- Get or cache the orb folder
local function getOrbFolder()
    local now = tick()
    if now - lastOrbFolderCheck > 1 then  -- Check every second
        cachedOrbFolder = Workspace:FindFirstChild("Orbs")
        lastOrbFolderCheck = now
    end
    return cachedOrbFolder
end

-- Optimized orb pickup function
function AISnakeOrbPickup.PickupNearbyOrbs(orbFolder, snakeHead, aiSnake)
    if not snakeHead then return end
    
    -- Use cached orb folder if not provided
    orbFolder = orbFolder or getOrbFolder()
    if not orbFolder then 
        -- If no orb folder, check workspace but limit search
        local orbsFound = 0
        for _, obj in Workspace:GetChildren() do
            if obj.Name == "Orb" and obj:IsA("BasePart") and orbsFound < 10 then
                orbsFound = orbsFound + 1
                local delta = snakeHead.Position - obj.Position
                -- Quick bounds check first
                if mathAbs(delta.X) < ORB_PICKUP_RADIUS and 
                   mathAbs(delta.Y) < ORB_PICKUP_RADIUS and 
                   mathAbs(delta.Z) < ORB_PICKUP_RADIUS then
                    -- Precise distance check
                    if delta.X * delta.X + delta.Y * delta.Y + delta.Z * delta.Z <= ORB_PICKUP_RADIUS_SQ then
                        -- Use OrbUtils for proper collection
                        if OrbUtils.checkAISnakeHeadPickup then
                            -- Let OrbUtils handle it properly
                            OrbUtils.checkAISnakeHeadPickup(snakeHead)
                            return  -- Exit after first pickup to prevent lag
                        else
                            obj:Destroy()
                        end
                    end
                end
            end
        end
        return
    end

    -- Optimized loop through orb folder
    local headPos = snakeHead.Position
    local orbs = orbFolder:GetChildren()
    
    -- Limit checks per frame for performance
    local maxChecks = mathMax(5, #orbs / 10)  -- Check at most 10% of orbs or 5 minimum
    local checked = 0
    
    for i = 1, #orbs do
        if checked >= maxChecks then break end
        
        local orb = orbs[i]
        if orb and orb:IsA("BasePart") and orb.Parent then
            checked = checked + 1
            local delta = headPos - orb.Position
            
            -- Quick bounds check (cheaper than distance)
            if mathAbs(delta.X) < ORB_PICKUP_RADIUS and 
               mathAbs(delta.Y) < ORB_PICKUP_RADIUS and 
               mathAbs(delta.Z) < ORB_PICKUP_RADIUS then
                -- Now do precise squared distance check
                if delta.X * delta.X + delta.Y * delta.Y + delta.Z * delta.Z <= ORB_PICKUP_RADIUS_SQ then
                    -- Use OrbUtils for proper orb collection with growth
                    if OrbUtils.checkAISnakeHeadPickup then
                        OrbUtils.checkAISnakeHeadPickup(snakeHead)
                        return  -- Exit after pickup to prevent multiple pickups per frame
                    else
                        -- Fallback
                        orb:Destroy()
                        if aiSnake and aiSnake.grow then
                            aiSnake:grow(1)  -- Default growth
                        end
                    end
                end
            end
        end
    end
end

return AISnakeOrbPickup