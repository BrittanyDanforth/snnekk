--[[
CLIENT GRAPHICS HANDLER
Handles client-side graphics settings for orbs and snake glows
This goes in StarterPlayerScripts as a LocalScript
--]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- Graphics presets for orbs and snakes
local GRAPHICS_PRESETS = {
	Low = {
		-- Orb settings
		RENDER_DISTANCE = 80,
		MATERIAL = Enum.Material.SmoothPlastic,
		DISABLE_LIGHTS = true,
		PARTICLE_RATE_MULTIPLIER = 0.3,
		DISABLE_SHADOWS = true,
		ORB_TRANSPARENCY_MODIFIER = 0.2,
		-- Snake glow settings
		SNAKE_GLOW_ENABLED = false,        -- Completely disable glow
		SNAKE_GLOW_BRIGHTNESS = 0,         -- No brightness
		SNAKE_GLOW_RANGE = 0,              -- No range
		SNAKE_MATERIAL = Enum.Material.SmoothPlastic  -- Less glowy material
	},
	Medium = {
		-- Orb settings
		RENDER_DISTANCE = 120,
		MATERIAL = Enum.Material.Neon,
		DISABLE_LIGHTS = false,
		PARTICLE_RATE_MULTIPLIER = 0.7,
		DISABLE_SHADOWS = false,
		ORB_TRANSPARENCY_MODIFIER = 0,
		-- Snake glow settings
		SNAKE_GLOW_ENABLED = true,         -- Glow enabled but reduced
		SNAKE_GLOW_BRIGHTNESS = 0.5,       -- Half brightness
		SNAKE_GLOW_RANGE = 4,              -- Reduced range
		SNAKE_MATERIAL = Enum.Material.Neon
	},
	High = {
		-- Orb settings
		RENDER_DISTANCE = 150,
		MATERIAL = Enum.Material.Neon,
		DISABLE_LIGHTS = false,
		PARTICLE_RATE_MULTIPLIER = 1,
		DISABLE_SHADOWS = false,
		ORB_TRANSPARENCY_MODIFIER = 0,
		-- Snake glow settings
		SNAKE_GLOW_ENABLED = true,         -- Full glow
		SNAKE_GLOW_BRIGHTNESS = 1,         -- Full brightness (server default)
		SNAKE_GLOW_RANGE = 8,              -- Full range (server default)
		SNAKE_MATERIAL = Enum.Material.Neon
	}
}

local currentPreset = GRAPHICS_PRESETS.High
local orbCache = {}  -- Track modified orbs
local snakeCache = {}  -- Track modified snake segments

-- Function to get player's position
local function getPlayerPosition()
	if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
		return LocalPlayer.Character.HumanoidRootPart.Position
	end
	return nil
end

-- Function to apply graphics settings to an orb
local function applyOrbGraphics(orb, distance)
	if not orb or not orb.Parent then return end
	
	local mode = LocalPlayer:GetAttribute("GraphicsMode") or "High"
	local preset = GRAPHICS_PRESETS[mode] or GRAPHICS_PRESETS.High
	
	-- Client-side material override
	if orb.Material ~= preset.MATERIAL then
		orb.Material = preset.MATERIAL
	end
	
	-- Handle lights
	local light = orb:FindFirstChild("PointLight")
	if light then
		if preset.DISABLE_LIGHTS then
			light.Enabled = false
		else
			-- Let server handle the actual light state, but we can disable it client-side
			if distance and distance > preset.RENDER_DISTANCE * 0.7 then
				light.Enabled = false
			end
		end
	end
	
	-- Apply transparency modifier for distant orbs in low graphics
	if preset.ORB_TRANSPARENCY_MODIFIER > 0 and distance then
		local fadeFactor = math.clamp((distance - 50) / (preset.RENDER_DISTANCE - 50), 0, 1)
		local extraTransparency = preset.ORB_TRANSPARENCY_MODIFIER * fadeFactor
		orb.LocalTransparencyModifier = extraTransparency
	else
		orb.LocalTransparencyModifier = 0
	end
	
	-- Hide orbs beyond render distance
	if distance and distance > preset.RENDER_DISTANCE then
		orb.LocalTransparencyModifier = 1  -- Completely hide
		if light then light.Enabled = false end
	end
end

-- Function to apply graphics settings to snake segments
local function applySnakeGraphics(segment, preset)
	if not segment or not segment.Parent then return end
	
	-- Check if it's a snake segment
	if not segment:GetAttribute("IsSnakeSegment") and segment.Name ~= "AISnakeHead" then
		return
	end
	
	-- Apply material
	segment.Material = preset.SNAKE_MATERIAL
	
	-- Handle glow light
	local glow = segment:FindFirstChild("Glow")
	if glow and glow:IsA("PointLight") then
		if preset.SNAKE_GLOW_ENABLED then
			glow.Enabled = true
			glow.Brightness = glow:GetAttribute("OriginalBrightness") or glow.Brightness
			glow.Brightness = glow.Brightness * preset.SNAKE_GLOW_BRIGHTNESS
			glow.Range = glow:GetAttribute("OriginalRange") or glow.Range
			glow.Range = glow.Range * preset.SNAKE_GLOW_RANGE
		else
			-- Store original values before disabling
			if not glow:GetAttribute("OriginalBrightness") then
				glow:SetAttribute("OriginalBrightness", glow.Brightness)
				glow:SetAttribute("OriginalRange", glow.Range)
			end
			glow.Enabled = false
		end
	end
	
	snakeCache[segment] = true
end

-- Function to handle particle effects
local function adjustParticleEffects(mode)
	local preset = GRAPHICS_PRESETS[mode] or GRAPHICS_PRESETS.High
	
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("ParticleEmitter") and obj.Parent and obj.Parent.Name == "OrbVFX" then
			-- Reduce particle rate for lower graphics
			local originalRate = obj:GetAttribute("OriginalRate")
			if not originalRate then
				originalRate = obj.Rate
				obj:SetAttribute("OriginalRate", originalRate)
			end
			obj.Rate = originalRate * preset.PARTICLE_RATE_MULTIPLIER
		end
	end
end

-- Main update loop
local lastUpdate = 0
local lastSnakeUpdate = 0
RunService.Heartbeat:Connect(function()
	local now = tick()
	if now - lastUpdate < 0.1 then return end  -- Update every 0.1 seconds
	lastUpdate = now
	
	local playerPos = getPlayerPosition()
	if not playerPos then return end
	
	local mode = LocalPlayer:GetAttribute("GraphicsMode") or "High"
	currentPreset = GRAPHICS_PRESETS[mode] or GRAPHICS_PRESETS.High
	
	-- Find and update all orbs
	for _, obj in ipairs(workspace:GetChildren()) do
		if obj:IsA("BasePart") and (obj.Name == "Orb" or obj.Name == "UpgradeOrb" or obj.Name == "DeathOrb") then
			local distance = (obj.Position - playerPos).Magnitude
			applyOrbGraphics(obj, distance)
			orbCache[obj] = true
		end
	end
	
	-- Update snake segments less frequently (every 0.5 seconds)
	if now - lastSnakeUpdate > 0.5 then
		lastSnakeUpdate = now
		
		-- Find all snake segments and AI snake heads
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") then
				-- Check for player snake segments
				if obj:GetAttribute("IsSnakeSegment") then
					applySnakeGraphics(obj, currentPreset)
				-- Check for AI snake heads and segments
				elseif obj.Name == "AISnakeHead" or (obj.Parent and obj.Parent.Name == "AISnake") then
					applySnakeGraphics(obj, currentPreset)
				end
			end
		end
		
		-- Also check player characters for snake segments
		for _, player in ipairs(Players:GetPlayers()) do
			if player.Character then
				for _, obj in ipairs(player.Character:GetDescendants()) do
					if obj:IsA("BasePart") and obj:GetAttribute("IsSnakeSegment") then
						applySnakeGraphics(obj, currentPreset)
					end
				end
			end
		end
	end
	
	-- Clean up cache for destroyed orbs
	for orb, _ in pairs(orbCache) do
		if not orb.Parent then
			orbCache[orb] = nil
		end
	end
	
	-- Clean up cache for destroyed snake segments
	for segment, _ in pairs(snakeCache) do
		if not segment.Parent then
			snakeCache[segment] = nil
		end
	end
end)

-- Handle graphics mode changes
LocalPlayer.AttributeChanged:Connect(function(attribute)
	if attribute == "GraphicsMode" then
		local mode = LocalPlayer:GetAttribute("GraphicsMode") or "High"
		print("Client graphics mode changed to:", mode)
		
		currentPreset = GRAPHICS_PRESETS[mode] or GRAPHICS_PRESETS.High
		
		-- Immediately update all orbs
		local playerPos = getPlayerPosition()
		if playerPos then
			for orb, _ in pairs(orbCache) do
				if orb.Parent then
					local distance = (orb.Position - playerPos).Magnitude
					applyOrbGraphics(orb, distance)
				end
			end
		end
		
		-- Immediately update all snake segments
		for segment, _ in pairs(snakeCache) do
			if segment.Parent then
				applySnakeGraphics(segment, currentPreset)
			end
		end
		
		-- Force a full snake update
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("BasePart") then
				if obj:GetAttribute("IsSnakeSegment") or obj.Name == "AISnakeHead" or (obj.Parent and obj.Parent.Name == "AISnake") then
					applySnakeGraphics(obj, currentPreset)
				end
			end
		end
		
		-- Adjust particle effects
		adjustParticleEffects(mode)
		
		-- Apply general graphics settings
		if mode == "Low" then
			settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
		elseif mode == "Medium" then
			settings().Rendering.QualityLevel = Enum.QualityLevel.Level10
		else
			settings().Rendering.QualityLevel = Enum.QualityLevel.Level21
		end
	end
end)

-- Initial setup
local initialMode = LocalPlayer:GetAttribute("GraphicsMode") or "High"
adjustParticleEffects(initialMode)

print("Client Graphics Handler initialized for:", LocalPlayer.Name)