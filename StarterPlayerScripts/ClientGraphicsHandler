--[[
CLIENT GRAPHICS HANDLER
Applies graphics settings based on the selected mode
--]]

local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

-- Graphics presets
local GraphicsPresets = {
	Low = {
		-- Lighting settings
		GlobalShadows = false,
		FogEnd = 500,
		Brightness = 2,
		-- Render settings
		QualityLevel = Enum.QualityLevel.Level01,
		-- Effects
		DisableBlur = true,
		DisableBloom = true,
		DisableSunRays = true
	},
	Medium = {
		-- Lighting settings
		GlobalShadows = true,
		FogEnd = 1000,
		Brightness = 1.5,
		-- Render settings
		QualityLevel = Enum.QualityLevel.Level10,
		-- Effects
		DisableBlur = false,
		DisableBloom = true,
		DisableSunRays = true
	},
	High = {
		-- Lighting settings
		GlobalShadows = true,
		FogEnd = 2000,
		Brightness = 1,
		-- Render settings
		QualityLevel = Enum.QualityLevel.Level21,
		-- Effects
		DisableBlur = false,
		DisableBloom = false,
		DisableSunRays = false
	}
}

-- Function to apply graphics settings
local function applyGraphicsSettings(mode)
	local preset = GraphicsPresets[mode]
	if not preset then
		warn("Invalid graphics mode:", mode)
		return
	end
	
	-- Apply lighting settings
	Lighting.GlobalShadows = preset.GlobalShadows
	Lighting.FogEnd = preset.FogEnd
	Lighting.Brightness = preset.Brightness
	
	-- Apply quality level
	settings().Rendering.QualityLevel = preset.QualityLevel
	
	-- Handle post-processing effects
	for _, effect in ipairs(Lighting:GetChildren()) do
		if effect:IsA("BlurEffect") then
			effect.Enabled = not preset.DisableBlur
		elseif effect:IsA("BloomEffect") then
			effect.Enabled = not preset.DisableBloom
		elseif effect:IsA("SunRaysEffect") then
			effect.Enabled = not preset.DisableSunRays
		end
	end
	
	-- Notify the user
	print("Graphics settings applied:", mode)
end

-- Apply graphics when attribute changes
LocalPlayer.AttributeChanged:Connect(function(attribute)
	if attribute == "GraphicsMode" then
		local mode = LocalPlayer:GetAttribute("GraphicsMode") or "High"
		applyGraphicsSettings(mode)
	end
end)

-- Apply initial graphics settings
local initialMode = LocalPlayer:GetAttribute("GraphicsMode") or "High"
applyGraphicsSettings(initialMode)