local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local processedObjects = {}

local function removeRootOutline()
    local character = player.Character
    if character then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            -- Direct check on rootPart children (fastest)
            local rootOutline = rootPart:FindFirstChild("RootOutline")
            if rootOutline then
                rootOutline:Destroy()
                return true -- Found and removed
            end
            
            -- Check only direct children of rootPart
            for _, child in ipairs(rootPart:GetChildren()) do
                if (child:IsA("SelectionBox") or child:IsA("Highlight")) and 
                   not processedObjects[child] then
                    processedObjects[child] = true
                    child:Destroy()
                end
            end
        end
    end
    return false
end

-- INSTANT removal on character spawn (before it's even visible)
player.CharacterAdded:Connect(function(character)
    -- Don't wait at all - check immediately
    local rootPart = character:WaitForChild("HumanoidRootPart", 5)
    if rootPart then
        -- Connect to ChildAdded to catch RootOutline AS SOON as it's created
        local childConnection
        childConnection = rootPart.ChildAdded:Connect(function(child)
            if child.Name == "RootOutline" or child:IsA("SelectionBox") or child:IsA("Highlight") then
                child:Destroy()
            end
        end)
        
        -- Aggressive checking for first 0.5 seconds (10 checks)
        for i = 1, 10 do
            removeRootOutline()
            if i < 10 then
                RunService.Heartbeat:Wait() -- Wait just one frame
            end
        end
        
        -- Disconnect the ChildAdded after initial spawn
        wait(0.5)
        if childConnection then
            childConnection:Disconnect()
        end
    end
end)

-- Initial aggressive removal for existing character
if player.Character then
    for i = 1, 5 do
        removeRootOutline()
        RunService.Heartbeat:Wait()
    end
end

-- Regular cleanup (less frequent)
task.spawn(function()
    wait(1) -- Wait for initial checks
    while true do
        removeRootOutline()
        wait(0.5) -- Check twice per second
    end
end)

-- Clean cache periodically
task.spawn(function()
    while true do
        wait(30)
        processedObjects = {}
    end
end)