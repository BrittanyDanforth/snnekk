-- This module augments the existing AISnake logic to allow AI snakes to pick up orbs.
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local OrbUtils = require(ReplicatedStorage:WaitForChild("OrbUtils"))

local ORB_PICKUP_RADIUS = 6  -- Adjust as needed for pickup range

local AISnakeOrbPickup = {}

-- Active AI snake tracking
local trackedSnakes = {}

-- Track an AI snake for orb collection
function AISnakeOrbPickup.TrackSnake(aiSnake)
    if not aiSnake or not aiSnake.HeadParts or not aiSnake.HeadParts.head then return end
    trackedSnakes[aiSnake] = true
    print("🎯 AISnakeOrbPickup: Now tracking AI snake")
end

-- Stop tracking an AI snake
function AISnakeOrbPickup.UntrackSnake(aiSnake)
    trackedSnakes[aiSnake] = nil
end

-- Main pickup function that runs for each AI snake
function AISnakeOrbPickup.PickupNearbyOrbs(orbFolder, snakeHead, aiSnakeId)
    if not orbFolder or not snakeHead then return end

    for _, orb in pairs(orbFolder:GetChildren()) do
        if orb:IsA("BasePart") and orb.Parent then
            local dist = (orb.Position - snakeHead.Position).Magnitude
            if dist <= ORB_PICKUP_RADIUS then
                -- Get orb value before collection
                local valueObj = orb:FindFirstChild("Value")
                local orbValue = valueObj and valueObj.Value or 1
                
                -- Collect orb using OrbUtils (assuming it has a CollectOrb function)
                if OrbUtils.CollectOrb then
                    OrbUtils.CollectOrb(orb, "AI", aiSnakeId)
                else
                    -- Fallback: just destroy the orb
                    orb:Destroy()
                end
                
                return orbValue -- Return the value collected
            end
        end
    end
    
    return 0
end

-- Debug counter
local frameCount = 0

-- Heartbeat loop to check all tracked AI snakes
RunService.Heartbeat:Connect(function()
    frameCount = frameCount + 1
    
    -- First try to find orb container in workspace
    local orbContainer = workspace:FindFirstChild("OrbContainer") or workspace:FindFirstChild("Orbs")
    
    -- If no container, check workspace directly
    if not orbContainer then
         -- Create a virtual container with all orbs
        local allOrbs = {}
        for _, obj in pairs(workspace:GetChildren()) do
            if obj:IsA("BasePart") and obj.Name == "Orb" then
                table.insert(allOrbs, obj)
            end
        end
        
        -- Debug print every 60 frames (1 second)
        if frameCount % 60 == 0 then
            local snakeCount = 0
            for _ in pairs(trackedSnakes) do snakeCount = snakeCount + 1 end
            print("🔍 AI Orb Pickup: Found", #allOrbs, "orbs in workspace, tracking", snakeCount, "AI snakes")
        end
        
        -- Process each tracked snake
        for snake, _ in pairs(trackedSnakes) do
            if snake and snake.HeadParts and snake.HeadParts.head and snake.HeadParts.head.Parent then
                local head = snake.HeadParts.head
                
                -- Check each orb
                for _, orb in pairs(allOrbs) do
                    if orb and orb.Parent then
                        local dist = (orb.Position - head.Position).Magnitude
                        if dist <= ORB_PICKUP_RADIUS then
                            -- Get orb value
                            local valueObj = orb:FindFirstChild("Value")
                            local orbValue = valueObj and valueObj.Value or 1
                            
                            -- Grow the snake
                            if snake.grow then
                                snake:grow(orbValue)
                                print("🍴 AI Snake collected", orb.Name, "worth", orbValue, "at position", orb.Position)
                            end
                            
                            -- Destroy the orb
                            orb:Destroy()
                            break -- Only eat one orb per frame
                        end
                    end
                end
            else
                -- Remove invalid snake
                trackedSnakes[snake] = nil
            end
        end
    else
        -- Use the orb container
        for snake, _ in pairs(trackedSnakes) do
            if snake and snake.HeadParts and snake.HeadParts.head and snake.HeadParts.head.Parent then
                local head = snake.HeadParts.head
                local value = AISnakeOrbPickup.PickupNearbyOrbs(orbContainer, head, snake)
                
                if value > 0 and snake.grow then
                    snake:grow(value)
                end
            else
                trackedSnakes[snake] = nil
            end
        end
    end
end)

return AISnakeOrbPickup