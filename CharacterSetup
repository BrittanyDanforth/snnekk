--[[
SIMPLE & STABLE SLITHER.IO SNAKE SYSTEM
- Simplified for maximum stability
- Works with SnakeMovement LocalScript
- No complex optimizations that break things
--]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Fast aliases
local Vector3new = Vector3.new
local CFramenew = CFrame.new
local CFramelookAt = CFrame.lookAt

-- Simple config
local Config = {
	HeadSize = Vector3new(3, 3, 3),
	SegmentSize = Vector3new(2.5, 2.5, 2.5),
	SegmentSpacing = 2.2,
	InitialLength = 35,
	MaxSegments = 2500,
	HeadColor = Color3.fromRGB(76, 217, 100),
	BodyColors = {
		Color3.fromRGB(60, 180, 80),
		Color3.fromRGB(80, 200, 100),
		Color3.fromRGB(100, 220, 120),
		Color3.fromRGB(80, 200, 100),
		Color3.fromRGB(60, 180, 80),
	},
	FollowSpeed = 0.94,  -- Smooth following
	HeadMaterial = Enum.Material.ForceField,
	BodyMaterial = Enum.Material.Neon,
	GlowIntensity = 1.5,
	GlowRange = 4,
}

-- Load skins if available
local SnakeSkins = {}
pcall(function()
	SnakeSkins = require(script.Parent:WaitForChild("SnakeSkinsData", 2))
end)

-- Get active config with skin
local function getActiveConfig(player)
	local selectedSkin = player:GetAttribute("SelectedSkin") or "Classic"
	local skinData = SnakeSkins[selectedSkin]
	
	if skinData then
		local config = {}
		for k, v in pairs(Config) do
			config[k] = skinData[k] or v
		end
		return config
	end
	
	return Config
end

-- Simple segment pool
local segmentPool = {}
local function getSegment()
	local segment = table.remove(segmentPool)
	if not segment then
		segment = Instance.new("Part")
		segment.Shape = Enum.PartType.Ball
		segment.TopSurface = Enum.SurfaceType.Smooth
		segment.BottomSurface = Enum.SurfaceType.Smooth
		segment.CanCollide = false
		segment.CanQuery = false
		segment.CanTouch = false
		segment.Anchored = true
		
		local light = Instance.new("PointLight")
		light.Name = "Glow"
		light.Parent = segment
	end
	return segment
end

local function returnSegment(segment)
	if segment and segment.Parent then
		segment.Parent = nil
		table.insert(segmentPool, segment)
	end
end

-- Get or create snake model
local function getOrCreateSnakeModel(player)
	local modelName = "SnakeModel_" .. player.UserId
	local existing = workspace:FindFirstChild(modelName)
	if existing then
		return existing
	end
	
	local model = Instance.new("Model")
	model.Name = modelName
	model.Parent = workspace
	return model
end

-- Create segment
local function createSegment(index, position, color, config, parentModel)
	local segment = getSegment()
	segment.Name = "Segment" .. index
	segment.Size = config.SegmentSize
	segment.Material = config.BodyMaterial
	segment.Color = color
	segment.CFrame = CFramenew(position)
	segment.Parent = parentModel
	
	segment:SetAttribute("IsSnakeSegment", true)
	segment:SetAttribute("SegmentIndex", index)
	
	local light = segment:FindFirstChild("Glow")
	if light then
		light.Brightness = config.GlowIntensity
		light.Color = color
		light.Range = config.GlowRange
		light.Enabled = true
	end
	
	return segment
end

-- Create visual head
local function createVisualHead(rootPart, config, parentModel)
	local headPart = Instance.new("Part")
	headPart.Name = "SnakeHead"
	headPart.Size = config.HeadSize
	headPart.Material = config.HeadMaterial
	headPart.Color = config.HeadColor
	headPart.Shape = Enum.PartType.Ball
	headPart.CanCollide = false
	headPart.CanQuery = false
	headPart.CanTouch = false
	headPart.Anchored = true
	headPart.Parent = parentModel
	
	headPart:SetAttribute("IsSnakeHead", true)
	
	local headLight = Instance.new("PointLight")
	headLight.Color = config.HeadColor
	headLight.Brightness = config.GlowIntensity + 1
	headLight.Range = config.GlowRange + 2
	headLight.Parent = headPart
	
	-- Simple eyes
	local function createEye(name, position)
		local eye = Instance.new("Part")
		eye.Name = name
		eye.Size = Vector3new(0.6, 0.6, 0.6)
		eye.Material = Enum.Material.Neon
		eye.Color = Color3.fromRGB(255, 255, 255)
		eye.Shape = Enum.PartType.Ball
		eye.CanCollide = false
		eye.CanQuery = false
		eye.CanTouch = false
		eye.Anchored = false
		eye.Parent = headPart
		
		local weld = Instance.new("WeldConstraint")
		weld.Part0 = headPart
		weld.Part1 = eye
		weld.Parent = headPart
		
		eye.CFrame = headPart.CFrame * CFramenew(position)
		
		return eye
	end
	
	createEye("LeftEye", Vector3new(-0.6, 0.55, 0.8))
	createEye("RightEye", Vector3new(0.6, 0.55, 0.8))
	
	return headPart
end

-- Player snakes storage
local playerSnakes = {}
if not _G.PlayerSnakes then
	_G.PlayerSnakes = {}
end

-- Main snake creation function
local function createSimpleSnake(character)
	print("🐍 Creating simple snake for:", character.Name)
	
	local humanoid = character:WaitForChild("Humanoid", 5)
	local rootPart = character:WaitForChild("HumanoidRootPart", 5)
	
	if not humanoid or not rootPart then
		warn("Missing humanoid or rootpart")
		return
	end
	
	local player = Players:GetPlayerFromCharacter(character)
	if not player then
		warn("No player found")
		return
	end
	
	-- Get config
	local activeConfig = getActiveConfig(player)
	
	-- Setup leaderstats
	local leaderstats = player:FindFirstChild("leaderstats")
	if leaderstats then
		local lengthValue = leaderstats:FindFirstChild("Length")
		if lengthValue then
			lengthValue.Value = activeConfig.InitialLength
		end
	end
	
	-- Hide character
	rootPart.Transparency = 1
	rootPart.CanCollide = false
	
	for _, part in character:GetChildren() do
		if part:IsA("BasePart") then
			part.Transparency = 1
			part.CanCollide = false
		elseif part:IsA("Accessory") then
			part:Destroy()
		end
	end
	
	-- Create snake model
	local snakeModel = getOrCreateSnakeModel(player)
	
	-- Initialize
	local segments = {}
	local currentLength = 0
	local targetLength = activeConfig.InitialLength
	local isActive = true
	local connections = {}
	
	-- Growth queue to handle rapid orb collection
	local growthQueue = 0
	local lastGrowthTime = 0
	local growthCooldown = 0.05 -- Process growth every 50ms
	
	-- Position history (simple circular buffer)
	local positionHistory = {}
	local historySize = 5000  -- Increased for very long snakes
	local historyIndex = 1
	
	-- Initialize history
	for i = 1, historySize do
		positionHistory[i] = {
			position = rootPart.Position,
			lookVector = rootPart.CFrame.LookVector
		}
	end
	
	local function addToHistory(data)
		positionHistory[historyIndex] = data
		historyIndex = (historyIndex % historySize) + 1
	end
	
	local function getFromHistory(steps)
		local index = historyIndex - steps
		if index < 1 then
			index = index + historySize
		end
		return positionHistory[index]
	end
	
	-- Growth function
	local function growSnake(amount)
		amount = amount or 5
		growthQueue = growthQueue + amount
	end
	
	-- Process growth queue smoothly
	local function processGrowthQueue()
		if growthQueue <= 0 or tick() - lastGrowthTime < growthCooldown then
			return
		end
		
		-- Process up to 2 segments per frame for smooth growth
		local toGrow = math.min(2, growthQueue)
		
		for i = 1, toGrow do
			if currentLength < activeConfig.MaxSegments then
				currentLength = currentLength + 1
				growthQueue = growthQueue - 1
				lastGrowthTime = tick()
				
				local colorIndex = ((currentLength - 1) % #activeConfig.BodyColors) + 1
				local color = activeConfig.BodyColors[colorIndex]
				
				-- Find the best position for new segment
				local spawnPos
				if currentLength > 1 then
					-- Get the tail segment's target position from history
					local tailDelay = math.floor((currentLength - 1) * 1.5)
					local tailTarget = getFromHistory(tailDelay)
					if tailTarget then
						spawnPos = tailTarget.position - tailTarget.lookVector * activeConfig.SegmentSpacing
					else
						-- Fallback to last segment position
						spawnPos = segments[currentLength - 1] and segments[currentLength - 1].Position or rootPart.Position
					end
				else
					spawnPos = rootPart.Position
				end
				
				local segment = createSegment(currentLength, spawnPos, color, activeConfig, snakeModel)
				segments[currentLength] = segment
				
				-- Smooth growth animation
				segment.Size = Vector3new(0.1, 0.1, 0.1)
				segment.Transparency = 1
				
				-- Animate the growth
				task.spawn(function()
					local startTime = tick()
					local duration = 0.3
					
					while segment.Parent and tick() - startTime < duration do
						local progress = (tick() - startTime) / duration
						local smoothProgress = math.sin(progress * math.pi / 2) -- Smooth ease-out
						
						segment.Size = segment.Size:Lerp(activeConfig.SegmentSize, smoothProgress * 0.15)
						segment.Transparency = 1 - smoothProgress
						
						task.wait()
					end
					
					if segment.Parent then
						segment.Size = activeConfig.SegmentSize
						segment.Transparency = 0
					end
				end)
				
				-- Update leaderstats
				if leaderstats then
					local lengthValue = leaderstats:FindFirstChild("Length")
					if lengthValue then
						lengthValue.Value = currentLength
					end
				end
			else
				growthQueue = 0 -- Clear queue if at max length
			end
		end
	end
	
	-- Cleanup function
	local function cleanup()
		if not isActive then return end
		isActive = false
		
		for _, conn in connections do
			if conn then
				conn:Disconnect()
			end
		end
		
		for _, segment in segments do
			returnSegment(segment)
		end
		
		if snakeModel then
			snakeModel:Destroy()
		end
		
		playerSnakes[player] = nil
		_G.PlayerSnakes[player] = nil
	end
	
	-- Death handling
	local diedConn = humanoid.Died:Connect(cleanup)
	table.insert(connections, diedConn)
	
	-- Character removal handling
	local ancestryConn = character.AncestryChanged:Connect(function()
		if not character.Parent then
			cleanup()
		end
	end)
	table.insert(connections, ancestryConn)
	
	-- Create head
	local headPart = createVisualHead(rootPart, activeConfig, snakeModel)
	
	-- Main update loop
	local frameCount = 0
	local heartbeatConn = RunService.Heartbeat:Connect(function()
		if not isActive or not rootPart.Parent then return end
		
		frameCount = frameCount + 1
		
		-- Process growth queue smoothly
		processGrowthQueue()
		
		local currentPos = rootPart.Position
		local currentCFrame = rootPart.CFrame
		local lookVector = currentCFrame.LookVector
		local headPos = currentPos + lookVector * 1.5
		
		-- Update head
		if headPart and headPart.Parent then
			headPart.CFrame = CFramelookAt(headPos, headPos + lookVector)
		end
		
		-- Add to history
		local lastPoint = getFromHistory(1)
		if (currentPos - lastPoint.position).Magnitude > 0.05 then  -- Record more frequently
			addToHistory({
				position = currentPos,
				lookVector = lookVector
			})
		end
		
		-- Create initial segments
		if currentLength < targetLength and frameCount > 5 then
			local toCreate = math.min(5, targetLength - currentLength)
			for i = 1, toCreate do
				currentLength = currentLength + 1
				local colorIndex = ((currentLength - 1) % #activeConfig.BodyColors) + 1
				local color = activeConfig.BodyColors[colorIndex]
				
				local segment = createSegment(currentLength, headPos, color, activeConfig, snakeModel)
				segments[currentLength] = segment
			end
			
			if leaderstats then
				local lengthValue = leaderstats:FindFirstChild("Length")
				if lengthValue then
					lengthValue.Value = currentLength
				end
			end
		end
		
		-- Update segments - SIMPLE VERSION FOR STABILITY
		for i = 1, currentLength do
			local segment = segments[i]
			if segment and segment.Parent then
				-- Fixed delay based on position
				local delay = math.floor(i * 1.2)  -- Reduced from 2 for tighter following
				local targetData = getFromHistory(delay)
				
				if targetData then
					-- Just follow the history position
					local targetPos = targetData.position
					
					-- Only apply anti-stretch to prevent breaking
					if i > 1 and segments[i-1] and segments[i-1].Parent then
						local prevPos = segments[i-1].Position
						local dist = (targetPos - prevPos).Magnitude
						
						-- If too far, clamp it
						if dist > activeConfig.SegmentSpacing * 1.8 then
							local dir = (targetPos - prevPos).Unit
							targetPos = prevPos + dir * activeConfig.SegmentSpacing
						end
					end
					
					-- Simple lerp for smoothness
					segment.CFrame = CFramenew(segment.Position:Lerp(targetPos, 0.88))  -- Reduced for stability
				end
			end
		end
	end)
	table.insert(connections, heartbeatConn)
	
	-- Store snake instance
	local snakeInstance = {
		segments = segments,
		cleanup = cleanup,
		grow = growSnake,
		model = snakeModel,
		isActive = function() return isActive end
	}
	
	playerSnakes[player] = snakeInstance
	_G.PlayerSnakes[player] = snakeInstance
	
	return snakeInstance
end

-- Handle players
local function handlePlayer(player)
	-- Setup leaderstats
	local leaderstats = player:FindFirstChild("leaderstats")
	if not leaderstats then
		leaderstats = Instance.new("Folder")
		leaderstats.Name = "leaderstats"
		leaderstats.Parent = player
	end
	
	local length = leaderstats:FindFirstChild("Length")
	if not length then
		length = Instance.new("NumberValue")
		length.Name = "Length"
		length.Value = 0
		length.Parent = leaderstats
	end
	
	-- Handle character spawn
	local function onCharacterAdded(character)
		task.wait(0.1)
		createSimpleSnake(character)
	end
	
	player.CharacterAdded:Connect(onCharacterAdded)
	if player.Character then
		onCharacterAdded(player.Character)
	end
end

-- Connect all current and future players
Players.PlayerAdded:Connect(handlePlayer)
for _, player in Players:GetPlayers() do
	handlePlayer(player)
end

-- Cleanup disconnected players
RunService.Heartbeat:Connect(function()
	for player, snake in pairs(playerSnakes) do
		if not player.Parent or not snake.isActive() then
			if snake.cleanup then
				snake.cleanup()
			end
			playerSnakes[player] = nil
			_G.PlayerSnakes[player] = nil
		end
	end
end)