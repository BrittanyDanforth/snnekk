-- SlitherIOMapBuilder: Builds a large, visually appealing map with invisible boundary walls
-- this is a script inside workspace
-- Now supports High/Low graphics mode and multiplayer-safe decoration toggling

local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Lighting = game:GetService("Lighting")

-- CONFIGURABLE MAP SIZE
local MAP_SIZE = 800      -- Map is MAP_SIZE x MAP_SIZE studs
local MAP_HEIGHT = 1      -- Height of the ground
local WALL_THICKNESS = 20  -- Thickness of invisible walls (increased)
local WALL_HEIGHT = 200    -- Height of invisible walls (much taller)

-- GROUP NAMES for easy cleanup/toggling
local DECOR_GROUP_NAME = "SlitherIOMapDecor"
local GRID_GROUP_NAME = "SlitherIOMapGrid"

-- Function to set up slither.io style DARK lighting
local function setupSlitherEnvironment()
	local Lighting = game:GetService("Lighting")
	
	-- Remove skybox for dark background
	local sky = Lighting:FindFirstChildOfClass("Sky")
	if sky then
		sky:Destroy()
	end
	
	-- Dark slither.io style lighting
	Lighting.Ambient = Color3.fromRGB(15, 15, 20)  -- Very dark ambient
	Lighting.Brightness = 0.1  -- Low brightness for night
	Lighting.ColorShift_Bottom = Color3.fromRGB(10, 10, 15)
	Lighting.ColorShift_Top = Color3.fromRGB(20, 20, 25)
	Lighting.EnvironmentDiffuseScale = 0.2
	Lighting.EnvironmentSpecularScale = 0.1
	Lighting.GlobalShadows = false
	Lighting.OutdoorAmbient = Color3.fromRGB(20, 20, 25)
	Lighting.ShadowSoftness = 1
	Lighting.ClockTime = 20  -- 8 PM - Dark evening
	Lighting.GeographicLatitude = 0
	
	-- Dark fog for atmosphere
	Lighting.FogEnd = 500
	Lighting.FogStart = 50
	Lighting.FogColor = Color3.fromRGB(15, 15, 20)
	
	-- Remove atmosphere if exists
	local atmosphere = Lighting:FindFirstChildOfClass("Atmosphere")
	if atmosphere then
		atmosphere:Destroy()
	end
end

-- Helper: Remove all map decor (grid lines, hexagons, spots, corners)
local function removeDecor()
	local decor = Workspace:FindFirstChild(DECOR_GROUP_NAME)
	if decor then
		decor:Destroy()
	end
	local grid = Workspace:FindFirstChild(GRID_GROUP_NAME)
	if grid then
		grid:Destroy()
	end
end

-- Helper: Remove old map parts (ground, walls)
local function removeMapParts()
	for _, obj in pairs(Workspace:GetChildren()) do
		if obj:IsA("Part") and (obj.Name == "SlitherIOGround" or obj.Name:match("^SlitherIOWall")) then
			obj:Destroy()
		end
	end
end

-- Helper: Create the ground part with enhanced texture
local function createGround()
	local ground = Instance.new("Part")
	ground.Name = "SlitherIOGround"
	ground.Size = Vector3.new(MAP_SIZE, MAP_HEIGHT, MAP_SIZE)
	ground.Position = Vector3.new(0, MAP_HEIGHT/2, 0)
	ground.Anchored = true
	ground.CanCollide = true
	ground.Locked = true
	ground.TopSurface = Enum.SurfaceType.Smooth
	ground.BottomSurface = Enum.SurfaceType.Smooth
	ground.Material = Enum.Material.SmoothPlastic  -- Less textured
	ground.Color = Color3.fromRGB(25, 25, 32)  -- Darker for night but not black
	ground.Parent = Workspace

	-- Create texture overlay using multiple parts for authentic slither.io look
	local textureGroup = Instance.new("Folder")
	textureGroup.Name = "GroundTexture"
	textureGroup.Parent = ground

	-- Base texture layer - subtle noise pattern (LESS TRANSPARENT for dark)
	local baseTexture = Instance.new("Part")
	baseTexture.Name = "BaseTexture"
	baseTexture.Size = Vector3.new(MAP_SIZE, 0.1, MAP_SIZE)
	baseTexture.Position = Vector3.new(0, MAP_HEIGHT + 0.05, 0)
	baseTexture.Anchored = true
	baseTexture.CanCollide = false
	baseTexture.Transparency = 0.75  -- Less transparent so you can't see through in dark
	baseTexture.Material = Enum.Material.SmoothPlastic
	baseTexture.Color = Color3.fromRGB(28, 28, 35)
	baseTexture.Parent = textureGroup

	-- Enhanced hexagonal pattern using Texture object
	local hexPattern = Instance.new("Part")
	hexPattern.Name = "HexPattern"
	hexPattern.Size = Vector3.new(MAP_SIZE, 0.05, MAP_SIZE)
	hexPattern.Position = Vector3.new(0, MAP_HEIGHT + 0.1, 0)
	hexPattern.Anchored = true
	hexPattern.CanCollide = false
	hexPattern.Transparency = 1
	hexPattern.Parent = textureGroup

	-- Apply texture to hex pattern (SUBTLE BUT VISIBLE)
	local texture = Instance.new("Texture")
	texture.Texture = "rbxasset://textures/water/caustics_00.dds"  -- Built-in texture that creates hex-like pattern
	texture.StudsPerTileU = 50  -- Adjusted size
	texture.StudsPerTileV = 50
	texture.Transparency = 0.93  -- Subtle but visible in dark
	texture.Color3 = Color3.fromRGB(35, 35, 45)
	texture.Face = Enum.NormalId.Top
	texture.Parent = hexPattern

	-- Secondary texture layer for depth
	local texture2 = Instance.new("Texture")
	texture2.Texture = "rbxasset://textures/water/caustics_01.dds"
	texture2.StudsPerTileU = 70
	texture2.StudsPerTileV = 70
	texture2.Transparency = 0.96  -- Very subtle
	texture2.Color3 = Color3.fromRGB(30, 30, 40)
	texture2.Face = Enum.NormalId.Top
	texture2.Parent = hexPattern

	-- Add subtle grid overlay using SurfaceGui for fine details
	local surfaceGui = Instance.new("SurfaceGui")
	surfaceGui.Face = Enum.NormalId.Top
	surfaceGui.AlwaysOnTop = false
	surfaceGui.ResetOnSpawn = false
	surfaceGui.Parent = ground

	-- Create gradient overlay for depth (ADJUSTED FOR DARK)
	local gradient = Instance.new("Frame")
	gradient.Size = UDim2.new(1, 0, 1, 0)
	gradient.BackgroundTransparency = 0.85  -- Less transparent
	gradient.BorderSizePixel = 0
	gradient.Parent = surfaceGui

	local uiGradient = Instance.new("UIGradient")
	uiGradient.Rotation = 45
	uiGradient.Transparency = NumberSequence.new{
		NumberSequenceKeypoint.new(0, 0.85),
		NumberSequenceKeypoint.new(0.5, 0.9),
		NumberSequenceKeypoint.new(1, 0.85)
	}
	uiGradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 20, 28)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(25, 25, 32)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(20, 20, 28))
	}
	uiGradient.Parent = gradient

	-- Add performance-optimized hexagonal details in high graphics mode
	if shouldShowDecor() then
		-- Create sparse hexagonal accents
		for i = 1, 20 do  -- Slightly fewer for performance
			local hexAccent = Instance.new("ImageLabel")
			hexAccent.Size = UDim2.new(0.08, 0, 0.08, 0)
			hexAccent.Position = UDim2.new(math.random() * 0.9, 0, math.random() * 0.9, 0)
			hexAccent.BackgroundTransparency = 1
			hexAccent.Image = "rbxasset://textures/ui/LuaChat/icons/ic-back.png"  -- Hexagon-like shape
			hexAccent.ImageColor3 = Color3.fromRGB(32, 32, 40)
			hexAccent.ImageTransparency = 0.9 + (math.random() * 0.05)  -- Visible but subtle
			hexAccent.Rotation = math.random(0, 60) * 6  -- Hexagonal rotations
			hexAccent.Parent = surfaceGui
		end
	end
end

-- Helper: Create invisible boundary walls with better collision
local function createWalls()
	local function createWall(name, size, position)
		local wall = Instance.new("Part")
		wall.Name = name
		wall.Size = size
		wall.Position = position
		wall.Anchored = true
		wall.CanCollide = true
		wall.CanTouch = true  -- Ensure touch detection works
		wall.CanQuery = true  -- Ensure raycasts work
		wall.Locked = true
		wall.Transparency = 0.8  -- More visible
		wall.Material = Enum.Material.ForceField  -- Better collision detection
		wall.BrickColor = BrickColor.new("Really red")  -- Red like slither.io
		wall.Parent = Workspace

		-- Add a SelectionBox for better visibility
		local selectionBox = Instance.new("SelectionBox")
		selectionBox.Adornee = wall
		selectionBox.Color3 = Color3.new(0.8, 0, 0)  -- Darker red
		selectionBox.LineThickness = 0.1  -- Thicker lines
		selectionBox.Transparency = 0.3  -- More visible
		selectionBox.Parent = wall

		-- Add invisible barrier below map to catch falling players
		if name == "SlitherIOWall_Bottom" then
			local floor = Instance.new("Part")
			floor.Name = "SlitherIOFloor"
			floor.Size = Vector3.new(MAP_SIZE + 100, 10, MAP_SIZE + 100)
			floor.Position = Vector3.new(0, -20, 0)  -- Below the map
			floor.Anchored = true
			floor.CanCollide = true
			floor.CanTouch = true
			floor.CanQuery = true
			floor.Transparency = 1
			floor.Parent = Workspace
		end

		return wall
	end
	local half = MAP_SIZE/2
	-- Position walls to extend from below ground to high above
	local wallY = WALL_HEIGHT/2 - 20  -- Start 20 studs below ground
	createWall("SlitherIOWall_Left", Vector3.new(WALL_THICKNESS, WALL_HEIGHT, MAP_SIZE+WALL_THICKNESS*2), Vector3.new(-half-WALL_THICKNESS/2, wallY, 0))
	createWall("SlitherIOWall_Right", Vector3.new(WALL_THICKNESS, WALL_HEIGHT, MAP_SIZE+WALL_THICKNESS*2), Vector3.new(half+WALL_THICKNESS/2, wallY, 0))
	createWall("SlitherIOWall_Top", Vector3.new(MAP_SIZE+WALL_THICKNESS*2, WALL_HEIGHT, WALL_THICKNESS), Vector3.new(0, wallY, -half-WALL_THICKNESS/2))
	createWall("SlitherIOWall_Bottom", Vector3.new(MAP_SIZE+WALL_THICKNESS*2, WALL_HEIGHT, WALL_THICKNESS), Vector3.new(0, wallY, half+WALL_THICKNESS/2))
end

-- Helper: Create map decorations (only in High graphics)
local function createDecor()
	-- PERFORMANCE FIX: Set to false to disable hexagon decorations
	local ENABLE_HEXAGONS = false
	
	if not ENABLE_HEXAGONS then
		print("⚡ Hexagon decorations disabled for better performance")
		return
	end
	
	local decorGroup = Instance.new("Folder")
	decorGroup.Name = DECOR_GROUP_NAME
	decorGroup.Parent = Workspace

	-- Create proper tessellating hexagonal pattern like slither.io
	local hexRadius = 100  -- Larger hexagons = fewer needed
	local hexHeight = hexRadius * math.sqrt(3)  -- Height of hexagon
	local hexWidth = hexRadius * 2  -- Width of hexagon

	-- Calculate spacing for perfect tessellation
	local xSpacing = hexWidth * 3/4  -- Hexagons overlap horizontally
	local ySpacing = hexHeight  -- Vertical spacing

	-- Create hexagonal grid across the map (REDUCED FOR PERFORMANCE)
	for row = -8, 8, 2 do  -- Much fewer rows, skip every other
		for col = -8, 8, 2 do  -- Much fewer columns, skip every other
			-- Calculate position with offset for odd rows
			local xOffset = (row % 2) * (xSpacing / 2)
			local x = col * xSpacing + xOffset
			local z = row * ySpacing

			-- Skip if outside map bounds
			if math.abs(x) > MAP_SIZE/2 - 50 or math.abs(z) > MAP_SIZE/2 - 50 then
				continue
			end

			-- Create hexagon using 6 lines
			for i = 0, 5 do
				local angle1 = (i * 60) * math.pi / 180
				local angle2 = ((i + 1) * 60) * math.pi / 180

				local x1 = x + hexRadius * math.cos(angle1)
				local z1 = z + hexRadius * math.sin(angle1)
				local x2 = x + hexRadius * math.cos(angle2)
				local z2 = z + hexRadius * math.sin(angle2)

				local line = Instance.new("Part")
				line.Name = "HexLine"
				line.Size = Vector3.new(
					math.sqrt((x2-x1)^2 + (z2-z1)^2) + 2,  -- Length with small overlap
					0.1,
					3  -- Line thickness
				)
				line.CFrame = CFrame.lookAt(
					Vector3.new((x1+x2)/2, MAP_HEIGHT + 0.1, (z1+z2)/2),
					Vector3.new(x2, MAP_HEIGHT + 0.1, z2)
				) * CFrame.Angles(0, math.pi/2, 0)
				line.Anchored = true
				line.CanCollide = false
				line.Transparency = 0.88  -- Just a tiny bit more visible
				line.Color = Color3.fromRGB(40, 40, 50)  -- Darker for night theme
				line.Material = Enum.Material.SmoothPlastic
				line.Parent = decorGroup
			end
		end
	end

	-- Add some circular spots like slither.io
	for i = 1, 15 do  -- Reduced from 40 to 15
		local spot = Instance.new("Part")
		spot.Name = "GroundSpot"
		spot.Shape = Enum.PartType.Cylinder
		spot.Size = Vector3.new(0.2, math.random(30, 60), math.random(30, 60))
		spot.Position = Vector3.new(
			math.random(-MAP_SIZE/2+50, MAP_SIZE/2-50),
			MAP_HEIGHT+0.1,
			math.random(-MAP_SIZE/2+50, MAP_SIZE/2-50)
		)
		spot.Orientation = Vector3.new(0, 0, 90)
		spot.Anchored = true
		spot.CanCollide = false
		spot.Locked = true
		spot.Transparency = 0.92
		spot.Color = Color3.fromRGB(35, 35, 45)  -- Darker for night
		spot.Material = Enum.Material.SmoothPlastic
		spot.Parent = decorGroup
	end
end

-- Helper: Create grid lines (only in High graphics)
local function createGrid()
	local gridGroup = Instance.new("Folder")
	gridGroup.Name = GRID_GROUP_NAME
	gridGroup.Parent = Workspace

	for i = -MAP_SIZE/2, MAP_SIZE/2, 50 do
		-- Vertical grid lines
		local vLine = Instance.new("Part")
		vLine.Name = "GroundCircle"
		vLine.Size = Vector3.new(0.3, 0.05, MAP_SIZE)
		vLine.Position = Vector3.new(i, MAP_HEIGHT + 0.025, 0)
		vLine.Anchored = true
		vLine.CanCollide = false
		vLine.Locked = true
		vLine.Transparency = 0.97
		vLine.Color = Color3.fromRGB(20, 20, 30)  -- Darker
		vLine.Material = Enum.Material.SmoothPlastic
		vLine.Parent = gridGroup

		-- Horizontal grid lines
		local hLine = Instance.new("Part")
		hLine.Name = "GroundCircle"
		hLine.Size = Vector3.new(MAP_SIZE, 0.05, 0.3)
		hLine.Position = Vector3.new(0, MAP_HEIGHT + 0.025, i)
		hLine.Anchored = true
		hLine.CanCollide = false
		hLine.Locked = true
		hLine.Transparency = 0.97
		hLine.Color = Color3.fromRGB(20, 20, 30)  -- Darker
		hLine.Material = Enum.Material.SmoothPlastic
		hLine.Parent = gridGroup
	end
end

-- Helper: Remove the default Baseplate if present
local function removeBaseplate()
	local baseplate = Workspace:FindFirstChild("Baseplate")
	if baseplate then
		baseplate:Destroy()
	end
end

-- Helper: Determine if majority of players are on High graphics
local function shouldShowDecor()
	local highCount = 0
	local total = 0
	for _, player in pairs(Players:GetPlayers()) do
		total = total + 1
		local mode = player:GetAttribute("GraphicsMode")
		if mode == nil or mode == "High" then
			highCount = highCount + 1
		end
	end
	if total == 0 then return true end
	return highCount >= (total / 2)
end

-- Main: Build the map (ground, walls, and decor based on graphics)
local function buildMap()
	removeMapParts()
	removeDecor()
	createGround()
	createWalls()
	removeBaseplate()
	setupSlitherEnvironment() -- Call the new lighting setup function
	if shouldShowDecor() then
		createDecor()
		createGrid()
	end
end

-- Helper: Update only the decor (for graphics mode changes)
local function updateDecor()
	removeDecor()
	if shouldShowDecor() then
		createDecor()
		createGrid()
	end
end

-- Listen for player graphics mode changes and player join/leave
for _, player in pairs(Players:GetPlayers()) do
	player:GetAttributeChangedSignal("GraphicsMode"):Connect(function()
		updateDecor()
	end)
end
Players.PlayerAdded:Connect(function(player)
	player:GetAttributeChangedSignal("GraphicsMode"):Connect(function()
		updateDecor()
	end)
	updateDecor()
end)
Players.PlayerRemoving:Connect(function()
	updateDecor()
end)

-- Listen for remote event to rebuild the map (e.g. after a round or admin command)
local rebuildEvent = ReplicatedStorage:FindFirstChild("RequestMapRebuild")
if rebuildEvent then
	rebuildEvent.OnServerEvent:Connect(function()
		buildMap()
	end)
end

-- === BOUNDARY CHECK SYSTEM ===
local RunService = game:GetService("RunService")

-- Function to check and reset players who fall off map
local function checkPlayerBoundaries()
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			local root = player.Character.HumanoidRootPart
			local pos = root.Position

			-- Check if player is outside map boundaries or fell below
			local halfMap = MAP_SIZE / 2 + 100 -- More lenient boundary
			if math.abs(pos.X) > halfMap or math.abs(pos.Z) > halfMap or pos.Y < -50 then
				print("Player", player.Name, "out of bounds at", pos)
				-- Teleport back to spawn
				root.CFrame = CFrame.new(0, 10, 0)
				root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)

				-- Fire respawn if needed
				if player.Character:FindFirstChild("Humanoid") then
					player.Character.Humanoid.Health = 0
				end
			end
		end
	end
end

-- Run boundary check periodically using task.spawn
task.spawn(function()
	while true do
		task.wait(0.5) -- Check every half second
		checkPlayerBoundaries()
	end
end)

-- Initial build
buildMap()
print("SlitherIOMapBuilder: Map built successfully!")

-- Add chat command to rebuild map for testing
Players.PlayerAdded:Connect(function(player)
	player.Chatted:Connect(function(message)
		if message:lower() == "/rebuildmap" then
			buildMap()
			print("Map rebuilt with updated walls!")
		end
	end)
end)

